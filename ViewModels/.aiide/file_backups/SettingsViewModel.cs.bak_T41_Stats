        ? (_startupDiag.IsAllGood ? "✅ 所有环境就绪" : "⚠️ 部分环境缺失，可能影响功能")
        : "⏳ 检测中...";

    // ===== 网络诊断方法 =====

    private async Task RunNetworkDiagnosticsAsync()
    {
        if (IsDiagRunning) return;
        IsDiagRunning = true;
        DiagResults.Clear();
        DiagSummary = "正在诊断网络连接...";

        try
        {
            var results = await _networkService.RunDiagnosticsAsync();
            foreach (var r in results)
                DiagResults.Add(r);

            var success = results.Count(r => r.Status == DiagStatus.Success);
            var failed = results.Count(r => r.Status == DiagStatus.Failed);
            DiagSummary = failed == 0
                ? $"✅ 全部通过 ({success}/{results.Count})"
                : $"⚠️ {success} 通过, {failed} 失败 ({results.Count} 项)";
        }
        catch (Exception ex)
        {
            DiagSummary = $"❌ 诊断异常: {ex.Message}";
        }
        finally
        {
            IsDiagRunning = false;
        }
    }

