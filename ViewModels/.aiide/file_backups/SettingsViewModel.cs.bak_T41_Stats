    private void StartAddCustomModel()
    {
        if (!_modelManager.CanAddMoreModels)
        {
            MessageBox.Show($"已达到模型数量上限（{ModelManager.MaxTotalModels} 个），请先删除不常用的模型再添加。",
                "模型数量超限", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        SelectedProvider = null;
        EditProviderId = string.Empty;
        EditProviderName = string.Empty;
        EditBaseUrl = string.Empty;
        EditProviderApiKey = string.Empty;
        EditModelId = string.Empty;
        EditModelName = string.Empty;
        EditModelMaxTokens = 0;
        EditAgentMode = true;
        EditQAMode = true;
        IsEditingModel = true;
    }

    private void EditCustomModel(object? param)
    {
        if (SelectedProvider == null || !SelectedProvider.IsCustom) return;
        EditProviderId = SelectedProvider.Id;
        EditProviderName = SelectedProvider.Name;
        EditBaseUrl = SelectedProvider.BaseUrl;
        EditProviderApiKey = SelectedProvider.ApiKey;
        if (SelectedProvider.Models.Count > 0)
        {
            var firstModel = SelectedProvider.Models[0];
            EditModelId = firstModel.Id;
            EditModelName = firstModel.Name;
            EditModelMaxTokens = firstModel.MaxTokens;
            EditAgentMode = firstModel.AgentMode;
            EditQAMode = firstModel.QAMode;
        }
        else
        {
            EditModelId = string.Empty;
            EditModelName = string.Empty;
            EditModelMaxTokens = 0;
            EditAgentMode = true;
            EditQAMode = true;
        }
        IsEditingModel = true;
    }

    private void SaveCustomModel()
    {
        if (string.IsNullOrWhiteSpace(EditProviderId))
        {
            MessageBox.Show("请输入提供商 ID", "验证", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(EditProviderName))
        {
            MessageBox.Show("请输入提供商名称", "验证", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(EditBaseUrl))
        {
            MessageBox.Show("请输入 API 基础 URL", "验证", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(EditModelId))
        {
            MessageBox.Show("请输入模型 ID", "验证", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(EditModelName))
        {
            MessageBox.Show("请输入模型名称", "验证", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }

        // 检查是否会超过上限（新增提供商/模型时）
        var existing = _modelManager.GetProvider(EditProviderId);
        if (existing == null && !_modelManager.CanAddMoreModels)
        {
            MessageBox.Show($"已达到模型数量上限（{ModelManager.MaxTotalModels} 个），请先删除不常用的模型。",
                "模型数量超限", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }

        try
        {
            _modelManager.RegisterOrUpdate(EditProviderId, EditProviderName, EditBaseUrl, EditProviderApiKey,
                EditModelId, EditModelName, EditAgentMode, EditQAMode, EditModelMaxTokens, isCustom: true);
            RefreshModels();
            IsEditingModel = false;
        }
        catch (Exception ex)
        {
            MessageBox.Show(ex.Message, "添加失败", MessageBoxButton.OK, MessageBoxImage.Error);
        }
    }

    private void DeleteCustomModel(object? param)
    {
        if (SelectedProvider == null || !SelectedProvider.IsCustom) return;
        var result = MessageBox.Show(
            $"确定要删除自定义模型「{SelectedProvider.Name}」吗？\n此操作不可撤销。",
            "确认删除", MessageBoxButton.YesNo, MessageBoxImage.Question);
        if (result != MessageBoxResult.Yes) return;

        _modelManager.RemoveProvider(SelectedProvider.Id);
        RefreshModels();
        SelectedProvider = null;
    }

