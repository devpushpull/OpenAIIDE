    /// <summary>用量追踪器引用（从 MainViewModel 传入）</summary>
    private UsageTrackerService? _usageTracker;
    public void SetUsageTracker(UsageTrackerService? tracker)
    {
        if (_usageTracker != null)
            _usageTracker.OnStatusChanged -= OnUsageChanged;
        _usageTracker = tracker;
        if (_usageTracker != null)
            _usageTracker.OnStatusChanged += OnUsageChanged;
        RefreshUsageData();
    }

    private void OnUsageChanged()
    {
        Application.Current?.Dispatcher.Invoke(() => RefreshUsageData());
    }

    public void RefreshUsageData()
    {
        if (_usageTracker == null) return;
        OnPropertyChanged(nameof(UsageStatusText));
        OnPropertyChanged(nameof(UsageSessionInput));
        OnPropertyChanged(nameof(UsageSessionOutput));
        OnPropertyChanged(nameof(UsageSessionTotal));
        OnPropertyChanged(nameof(UsageApiRemaining));
        OnPropertyChanged(nameof(UsageApiTotal));
        OnPropertyChanged(nameof(UsageApiPercent));
        OnPropertyChanged(nameof(UsageApiPercentText));
        OnPropertyChanged(nameof(UsageWarningThreshold));
        OnPropertyChanged(nameof(UsageCriticalThreshold));
        OnPropertyChanged(nameof(UsageSessionWarningLimit));
        OnPropertyChanged(nameof(UsageWarningMessage));
        OnPropertyChanged(nameof(UsageStatusLevel));
        OnPropertyChanged(nameof(UsageHasApiInfo));
        OnPropertyChanged(nameof(UsageSessionPercentText));
    }

    public string UsageStatusText => _usageTracker?.StatusText ?? "（暂无数据，请先发起一次 AI 对话）";
    public string UsageSessionInput => _usageTracker != null ? Services.CommonUtils.FormatTokens(_usageTracker.SessionInputTokens) : "—";
    public string UsageSessionOutput => _usageTracker != null ? Services.CommonUtils.FormatTokens(_usageTracker.SessionOutputTokens) : "—";
    public string UsageSessionTotal => _usageTracker != null ? Services.CommonUtils.FormatTokens(_usageTracker.SessionTotalTokens) : "—";
    public string UsageApiRemaining => _usageTracker != null && _usageTracker.RateLimitRemainingTokens > 0 ? Services.CommonUtils.FormatTokens(_usageTracker.RateLimitRemainingTokens) : "—";
    public string UsageApiTotal => _usageTracker != null && _usageTracker.RateLimitTotalTokens > 0 ? Services.CommonUtils.FormatTokens(_usageTracker.RateLimitTotalTokens) : "—";
    public double UsageApiPercent => _usageTracker?.RateLimitUsagePercent ?? -1;
    public string UsageApiPercentText => UsageApiPercent >= 0 ? $"{UsageApiPercent:F1}%" : "—";
    public int UsageWarningThreshold => (int)(_usageTracker?.WarningThresholdPercent ?? 80);
    public int UsageCriticalThreshold => (int)(_usageTracker?.CriticalThresholdPercent ?? 95);
    public int UsageSessionWarningLimit => _usageTracker?.SessionTokenWarningLimit ?? 100_000;
    public string UsageWarningMessage => _usageTracker?.WarningMessage ?? "";
    public bool HasUsageWarning => !string.IsNullOrEmpty(UsageWarningMessage);
    public string UsageStatusLevel => UsageApiPercent switch
    {
        >= 95 => "🚨 严重",
        >= 80 => "⚠️ 警告",
        >= 0 => "✅ 正常",
        _ => "📊 未知"
    };
    public bool UsageHasApiInfo => _usageTracker?.HasRateLimitInfo ?? false;
    public string UsageSessionPercentText
    {
        get
        {
            if (_usageTracker == null || _usageTracker.SessionTokenWarningLimit <= 0) return "—";
            var pct = _usageTracker.SessionTotalTokens * 100.0 / _usageTracker.SessionTokenWarningLimit;
            return $"{pct:F1}% (上限 {Services.CommonUtils.FormatTokens(_usageTracker.SessionTokenWarningLimit)})";
        }
    }

