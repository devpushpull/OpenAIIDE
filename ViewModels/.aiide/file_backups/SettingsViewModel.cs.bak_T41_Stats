/// <summary>规则管理 ViewModel</summary>
public class RulesViewModel : INotifyPropertyChanged
{
    public RulesViewModel()
    {
        AddCommand = new RelayCommand(_ => StartAdd());
        DeleteCommand = new RelayCommand(Delete, _ => SelectedRule != null);
        SaveCommand = new RelayCommand(_ => Save());
        CancelEditCommand = new RelayCommand(_ => CancelEdit());
    }

    private ObservableCollection<RuleItem> _rules = new();
    public ObservableCollection<RuleItem> Rules { get => _rules; set { _rules = value; OnPropertyChanged(); } }

    private RuleItem? _selectedRule;
    public RuleItem? SelectedRule { get => _selectedRule; set { _selectedRule = value; OnPropertyChanged(); OnPropertyChanged(nameof(IsEditing)); } }

    private string _editName = string.Empty;
    public string EditName { get => _editName; set { _editName = value; OnPropertyChanged(); } }

    private string _editContent = string.Empty;
    public string EditContent { get => _editContent; set { _editContent = value; OnPropertyChanged(); } }

    private string _editRuleType = "always";
    public string EditRuleType { get => _editRuleType; set { _editRuleType = value; OnPropertyChanged(); } }

    private string _editGlob = string.Empty;
    public string EditGlob { get => _editGlob; set { _editGlob = value; OnPropertyChanged(); } }

    private string _editDescription = string.Empty;
    public string EditDescription { get => _editDescription; set { _editDescription = value; OnPropertyChanged(); } }

    private bool _isEditing;
    public bool IsEditing { get => _isEditing; set { _isEditing = value; OnPropertyChanged(); OnPropertyChanged(nameof(IsNotEditing)); } }
    public bool IsNotEditing => !_isEditing;

    public static List<string> RuleTypes { get; } = new() { "always", "manual", "model_decision", "glob" };
    public static Dictionary<string, string> RuleTypeNames { get; } = new()
    {
        ["always"] = "始终生效",
        ["manual"] = "手动引入",
        ["model_decision"] = "模型决策",
        ["glob"] = "按文件匹配"
    };

    public ICommand AddCommand { get; }
    public ICommand DeleteCommand { get; }
    public ICommand SaveCommand { get; }
    public ICommand CancelEditCommand { get; }

    public void LoadRules(List<RuleItem> rules) => Rules = new ObservableCollection<RuleItem>(rules);
    public List<RuleItem> GetRules() => Rules.ToList();

    private void StartAdd()
    {
        SelectedRule = null;
        EditName = string.Empty;
        EditContent = string.Empty;
        EditRuleType = "always";
        EditGlob = string.Empty;
        EditDescription = string.Empty;
        IsEditing = true;
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(EditName) || string.IsNullOrWhiteSpace(EditContent)) return;
        Rules.Add(new RuleItem { Name = EditName, Content = EditContent, RuleType = EditRuleType, GlobPattern = string.IsNullOrWhiteSpace(EditGlob) ? null : EditGlob, Description = string.IsNullOrWhiteSpace(EditDescription) ? null : EditDescription });
        IsEditing = false;
    }

    private void CancelEdit() => IsEditing = false;

    private void Delete(object? param)
    {
        if (SelectedRule != null)
            Rules.Remove(SelectedRule);
    }

    public event PropertyChangedEventHandler? PropertyChanged;
    protected void OnPropertyChanged([CallerMemberName] string? name = null)
        => PropertyChanged?.Invoke(this, new PropertyChangedEventArgs(name));
}
