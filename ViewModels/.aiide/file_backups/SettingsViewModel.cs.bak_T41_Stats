    private void SaveAll()
    {
        var config = _configService.GetConfig();
        config.Editor.FontSize = FontSize;
        config.Editor.WordWrap = WordWrap;
        config.Editor.ShowMinimap = ShowMinimap;
        config.Editor.TabSize = TabSize;
        config.Appearance.Theme = Theme;
        config.Appearance.ResponseLanguage = ResponseLanguage;
        config.Appearance.AutoCheckUpdates = AutoCheckUpdates;
        config.AI.ApiKey = ApiKey;
        config.AI.Model = DefaultModel;
        config.AI.MaxTokens = MaxTokens;
        config.AI.Stream = StreamMode;
        config.AI.AutoWebSearch = AutoWebSearch;

        // 终端设置
        config.Terminal.FontFamily = TerminalFontFamily;
        config.Terminal.FontSize = TerminalFontSize;
        config.Terminal.CursorStyle = TerminalCursorStyle;
        config.Terminal.ShellPath = TerminalShellPath;
        config.Terminal.ScrollbackLines = TerminalScrollbackLines;
        config.Terminal.EnableColors = TerminalEnableColors;
        config.Terminal.EnableSyntaxHighlighting = TerminalSyntaxHighlight;

        // 文件排除设置
        config.FileExclude.ExcludePatterns = FileExcludePatterns;
        config.FileExclude.SearchExcludePatterns = SearchExcludePatterns;
        config.FileExclude.UseGitIgnore = UseGitIgnore;
        config.FileExclude.HideDotFiles = HideDotFiles;

        // 隐私设置
        config.Privacy.EnableTelemetry = EnableTelemetry;
        config.Privacy.EnableCrashReports = EnableCrashReports;
        config.Privacy.EnableUsageAnalytics = EnableUsageAnalytics;
        config.Privacy.ShareCodeSnippets = ShareCodeSnippets;
        config.Privacy.AutoClearHistoryOnExit = AutoClearHistoryOnExit;
        config.Privacy.HistoryRetentionDays = HistoryRetentionDays;

        // 代理设置
        config.Proxy.EnableProxy = EnableProxy;
        config.Proxy.ProxyType = ProxyType;
        config.Proxy.Host = ProxyHost;
        config.Proxy.Port = ProxyPort;
        config.Proxy.UseAuth = ProxyUseAuth;
        config.Proxy.Username = ProxyUsername;
        config.Proxy.Password = ProxyPassword;

        _configService.Save();

        MessageBox.Show("设置已保存", "AI IDE", MessageBoxButton.OK, MessageBoxImage.Information);
        RequestClose?.Invoke();
    }

