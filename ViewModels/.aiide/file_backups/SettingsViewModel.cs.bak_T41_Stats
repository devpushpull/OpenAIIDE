    // ===== MCP 服务管理 =====

    public ObservableCollection<MCPServerDisplay> MCPServers { get; } = new();
    public ObservableCollection<MCPMarketItem> MCPMarketItems { get; } = new();

    private bool _mcpIsLoading;
    public bool MCPIsLoading { get => _mcpIsLoading; set { _mcpIsLoading = value; OnPropertyChanged(); OnPropertyChanged(nameof(MCPNotLoading)); } }
    public bool MCPNotLoading => !_mcpIsLoading;

    private string _mcpMarketStatus = "点击刷新加载工具市场";
    public string MCPMarketStatus { get => _mcpMarketStatus; set { _mcpMarketStatus = value; OnPropertyChanged(); } }

    public ICommand RefreshMCPServersCommand { get; private set; } = null!;
    public ICommand RefreshMCPMarketCommand { get; private set; } = null!;
    public ICommand InstallMCPCommand { get; private set; } = null!;
    public ICommand UninstallMCPCommand { get; private set; } = null!;
    public ICommand AddMCPServerCommand { get; private set; } = null!;
    public ICommand EditMCPServerCommand { get; private set; } = null!;

    private void InitMCPCommands()
    {
        RefreshMCPServersCommand = new RelayCommand(_ => LoadMCPServers());
        RefreshMCPMarketCommand = new RelayCommand(async _ => await LoadMCPMarketplaceAsync());
        InstallMCPCommand = new RelayCommand(param =>
        {
            if (param is MCPMarketItem item)
                InstallMCPServer(item);
        });
        UninstallMCPCommand = new RelayCommand(param =>
        {
            if (param is MCPServerDisplay display)
                UninstallMCPServer(display);
        });
        AddMCPServerCommand = new RelayCommand(_ =>
        {
            var dlg = new MCPEditDialog();
            if (dlg.ShowDialog() == true && dlg.Result != null)
            {
                _mcpService.Add(dlg.Result);
                LoadMCPServers();
            }
        });
        EditMCPServerCommand = new RelayCommand(param =>
        {
            if (param is MCPServerDisplay display)
            {
                var dlg = new MCPEditDialog(display.ToConfig());
                if (dlg.ShowDialog() == true && dlg.Result != null)
                {
                    _mcpService.Update(dlg.Result);
                    LoadMCPServers();
                }
            }
        });
    }

    public void LoadMCPServers()
    {
        MCPServers.Clear();
        foreach (var s in _mcpService.Servers)
            MCPServers.Add(new MCPServerDisplay(s));
        SyncMCPInstallStatus();
    }

    public async Task LoadMCPMarketplaceAsync()
    {
        MCPIsLoading = true;
        MCPMarketStatus = "正在加载工具市场...";
        try
        {
            var items = await MarketplaceService.GetMCPMarketplaceAsync();
            MCPMarketItems.Clear();
            foreach (var item in items)
                MCPMarketItems.Add(item);
            SyncMCPInstallStatus();
            MCPMarketStatus = $"共 {MCPMarketItems.Count} 个工具";
        }
        catch (Exception ex)
        {
            MCPMarketStatus = $"加载失败: {ex.Message}";
        }
        finally
        {
            MCPIsLoading = false;
        }
    }

    private void SyncMCPInstallStatus()
    {
        var installedIds = _mcpService.Servers.Select(s => s.Id).ToHashSet();
        foreach (var item in MCPMarketItems)
            item.IsInstalled = installedIds.Contains(item.Id);
    }

    private void InstallMCPServer(MCPMarketItem item)
    {
        if (item.IsInstalled)
        {
            MessageBox.Show($"{item.Name} 已安装。", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
            return;
        }

        var config = new MCPServerConfig
        {
            Id = item.Id,
            Name = item.Name,
            Command = item.Command,
            Args = item.Args.Split(' ', StringSplitOptions.RemoveEmptyEntries),
            Enabled = true,
            Description = item.Description
        };

        _mcpService.Add(config);
        item.IsInstalled = true;
        LoadMCPServers();
        MessageBox.Show($"✅ {item.Name} 安装成功！\n命令: {item.Command} {item.Args}",
            "安装成功", MessageBoxButton.OK, MessageBoxImage.Information);
    }

    private void UninstallMCPServer(MCPServerDisplay display)
    {
        var result = MessageBox.Show(
            $"确认卸载 MCP 服务 \"{display.Name}\"?\n\n" +
            "卸载操作将：\n" +
            "1. 删除服务器配置\n" +
            "2. 清理 npx/npm 缓存中的相关包\n\n" +
            "是否继续？",
            "卸载确认", MessageBoxButton.YesNo, MessageBoxImage.Warning);

        if (result != MessageBoxResult.Yes) return;

        try
        {
            // 1. 删除服务器配置
            _mcpService.Delete(display.Id);

            // 2. 尝试清理 npm/npx 缓存（异步执行，不影响主流程）
            _ = CleanupMCPPackageAsync(display);

            LoadMCPServers();
            MessageBox.Show($"✅ {display.Name} 已卸载。", "卸载成功", MessageBoxButton.OK, MessageBoxImage.Information);
        }
        catch (Exception ex)
        {
            MessageBox.Show($"卸载失败: {ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
        }
    }

    private async Task CleanupMCPPackageAsync(MCPServerDisplay display)
    {
        try
        {
            // 从 Args 中提取包名（npx 参数格式: -y @scope/package-name ...）
            string? packageName = null;
            foreach (var arg in display.Args)
            {
                if (arg.StartsWith("@") || (!arg.StartsWith("-") && arg.Contains('/')))
                {
                    packageName = arg;
                    break;
                }
                // 也匹配普通包名（非 - 开头，非路径）
                if (!arg.StartsWith("-") && !arg.StartsWith("/") && !arg.Contains('='))
                {
                    packageName = arg;
                    break;
                }
            }

            if (packageName != null)
            {
                // 清理 npx 缓存
                var psi = new System.Diagnostics.ProcessStartInfo
                {
                    FileName = "npm",
                    Arguments = $"cache clean {packageName} --force",
                    UseShellExecute = false,
                    CreateNoWindow = true,
                    RedirectStandardOutput = true,
                    RedirectStandardError = true
                };
                var proc = System.Diagnostics.Process.Start(psi);
                if (proc != null)
                {
                    await proc.WaitForExitAsync();
                    LogService.Instance.Info($"MCP包缓存已清理: {packageName}", "MCP");
                }
            }
        }
        catch (Exception ex)
        {
            LogService.Instance.Warn($"MCP包缓存清理失败（可忽略）: {ex.Message}", "MCP");
        }
    }
