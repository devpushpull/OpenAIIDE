    public string EnvGitStatus => _startupDiag?.Environment?.Git.DisplayText ?? "检测中...";
    public string EnvNetworkStatus => _startupDiag != null
        ? (_startupDiag.IsNetworkAvailable ? "✅ 已连接" : "❌ 未连接")
        : "⏳ 检测中...";
    public bool EnvAllReady => _startupDiag?.IsAllGood ?? false;
