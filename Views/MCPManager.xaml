<Window x:Class="AIIDEWPF.Views.MCPManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AIIDEWPF.Converters"
        Title="🔗 MCP 服务器管理" Height="540" Width="700"
        Background="#1e1e1e" Foreground="#d4d4d4"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:IsNotNullConverter x:Key="IsNotNull"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🔗 MCP 服务器管理" FontSize="16" FontWeight="Bold" Foreground="#e0e0e0"/>
            <TextBlock Text="管理 MCP 工具服务器，从市场发现并安装新工具。" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="#252526" BorderBrush="#454545" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2d2d2d"/>
                    <Setter Property="Foreground" Value="#aaa"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                        Cursor="Hand">
                                    <ContentPresenter Content="{TemplateBinding Header}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3a3a3a"/>
                                        <Setter Property="Foreground" Value="#4ec9b0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: 我的服务器 -->
            <TabItem Header="🖥 我的服务器">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="➕ 新增" Width="72" Height="28" Background="#1a5a1a" Foreground="#90ee90"
                                BorderThickness="0" FontSize="11" Click="Add_Click"/>
                        <Button Content="🔄 刷新" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="11" Margin="8,0,0,0" Click="Refresh_Click"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ServerList" ItemsSource="{Binding Servers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" Background="#252526" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#4ec9b0"
                                                           VerticalAlignment="Center" Text="{Binding Name}"/>
                                                <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                        Visibility="{Binding Enabled, Converter={StaticResource BoolToVis}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1a3a1a"/>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="启用" FontSize="10" Foreground="#90ee90"/>
                                                </Border>
                                                <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                        Visibility="{Binding Enabled, Converter={StaticResource InverseBoolToVis}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#3a1a1a"/>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="禁用" FontSize="10" Foreground="#f0a0a0"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" FontSize="11" Foreground="#569cd6" Margin="0,4,0,0"
                                                       FontFamily="Consolas,monospace">
                                                <Run Text="{Binding Command, Mode=OneWay}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding ArgsDisplay, Mode=OneWay}" Foreground="#888"/>
                                            </TextBlock>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"
                                                           VerticalAlignment="Center" MaxWidth="320" TextTrimming="CharacterEllipsis"/>
                                                <Button Content="编辑" Width="48" Height="22" FontSize="10"
                                                        Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                                                        Margin="12,0,4,0" Click="Edit_Click" Tag="{Binding .}"/>
                                                <Button Content="删除" Width="48" Height="22" FontSize="10"
                                                        Background="#5a1a1a" Foreground="#f0a0a0" BorderThickness="0"
                                                        Click="Delete_Click" Tag="{Binding .}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 2: 工具市场 -->
            <TabItem Header="🛒 工具市场">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="发现 MCP 工具" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="MarketCount" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <Button Content="🔄 刷新" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="11" Margin="16,0,0,0" Click="MarketRefresh_Click"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="MarketList" ItemsSource="{Binding MarketItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" Background="#252526" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="12" FontWeight="Bold" Foreground="#569cd6"
                                                               VerticalAlignment="Center" Text="{Binding Name}"/>
                                                    <Border Background="#3a3a3a" CornerRadius="3" Padding="6,1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#aaa"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"
                                                           TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="420"/>
                                                <TextBlock FontSize="10" Foreground="#4ec9b0" Margin="0,3,0,0"
                                                           FontFamily="Consolas,monospace" TextTrimming="CharacterEllipsis">
                                                    <Run Text="{Binding Command, Mode=OneWay}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Args, Mode=OneWay}" Foreground="#888"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding InstallNote}" FontSize="10" Foreground="#f0c040" Margin="0,2,0,0"
                                                           Visibility="{Binding InstallNote, Converter={StaticResource IsNotNull}}"/>
                                                <TextBlock Text="{Binding EnvNote}" FontSize="10" Foreground="#60c0ff" Margin="0,2,0,0"
                                                           Visibility="{Binding EnvNote, Converter={StaticResource IsNotNull}}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Width="72" Height="28"
                                                    Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0"
                                                    FontSize="11" VerticalAlignment="Center"
                                                    Content="{Binding InstallStatus}"
                                                    Click="InstallMCP_Click" Tag="{Binding .}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
