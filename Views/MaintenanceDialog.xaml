<Window x:Class="AIIDEWPF.Views.MaintenanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛠️ 自动维护建议" Width="580" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinWidth="400" MinHeight="300" MaxHeight="800"
        Background="#252526" Foreground="#d4d4d4">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题区 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontSize="18" FontWeight="Bold" Foreground="#e8c050">
                🛠️ 自动维护建议
            </TextBlock>
            <TextBlock x:Name="SubtitleLabel" FontSize="13" Foreground="#c0c0c0"
                       TextWrapping="Wrap" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- 内容区（带滚动条） -->
        <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="6"
                Padding="14,12" BorderBrush="#3a3a3a" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="ContentText" FontSize="13" Foreground="#d4d4d4"
                           TextWrapping="Wrap" LineHeight="22"
                           FontFamily="Microsoft YaHei UI, Segoe UI, sans-serif"/>
            </ScrollViewer>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="FixBtn" Content="✅ 备份并修复"
                    Background="#3a6a3a" Foreground="#a0d0a0"
                    Width="130" Click="FixBtn_Click"/>
            <Button x:Name="ViewOnlyBtn" Content="📋 仅查看"
                    Background="#4a4a4a" Foreground="#aaa"
                    Width="110" Margin="8,0,0,0" Click="ViewOnlyBtn_Click"/>
            <Button x:Name="CancelBtn" Content="关闭"
                    Background="#4a3030" Foreground="#f0a0a0"
                    Width="80" Margin="8,0,0,0" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
