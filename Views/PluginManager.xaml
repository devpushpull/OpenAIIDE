<Window x:Class="AIIDEWPF.Views.PluginManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AIIDEWPF.Converters"
        Title="🔌 插件管理" Height="520" Width="680"
        Background="#1e1e1e" Foreground="#d4d4d4"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🔌 插件管理" FontSize="16" FontWeight="Bold" Foreground="#e0e0e0"/>
            <TextBlock FontSize="11" Foreground="#888" Margin="0,4,0,0">
                <Run Text="插件目录: "/><Run Text="{Binding PluginDir, Mode=OneWay}" Foreground="#569cd6"/>
            </TextBlock>
        </StackPanel>

        <TabControl Grid.Row="1" Background="#252526" BorderBrush="#454545" BorderThickness="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="#2d2d2d"/>
                    <Setter Property="Foreground" Value="#aaa"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                        Cursor="Hand">
                                    <ContentPresenter Content="{TemplateBinding Header}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#3a3a3a"/>
                                        <Setter Property="Foreground" Value="#4ec9b0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Tab 1: 已安装 -->
            <TabItem Header="📦 已安装">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="🔄 刷新" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="11" Click="Refresh_Click"/>
                        <Button Content="📂 打开目录" Width="100" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="11" Margin="8,0,0,0" Click="OpenDir_Click"/>
                        <Button Content="🗑 清除缓存" Width="100" Height="28" Background="#3a1a1a" Foreground="#f0a0a0"
                                BorderThickness="0" FontSize="11" Margin="8,0,0,0" Click="ClearCache_Click"
                                ToolTip="清除所有插件下载缓存"/>
                        <TextBlock x:Name="CacheSizeText" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PluginList" ItemsSource="{Binding Plugins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" Background="#2d2d2d" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#569cd6"
                                                           VerticalAlignment="Center">
                                                    <Run Text="{Binding Name}"/>
                                                    <Run Text=" v" Foreground="#888"/>
                                                    <Run Text="{Binding Version, Mode=OneWay}" Foreground="#888"/>
                                                </TextBlock>
                                                <Border Background="#1a3a1a" CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                        Visibility="{Binding Enabled, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="已启用" FontSize="10" Foreground="#90ee90"/>
                                                </Border>
                                                <Border Background="#3a1a1a" CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                        Visibility="{Binding Enabled, Converter={StaticResource InverseBoolToVis}}">
                                                    <TextBlock Text="已禁用" FontSize="10" Foreground="#f0a0a0"/>
                                                </Border>
                                                <!-- 有更新可用标记 -->
                                                <Border Background="#5a3a00" CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                        Visibility="{Binding HasUpdateAvailable, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock FontSize="10" Foreground="#f0c040">
                                                        <Run Text="🔼 更新 "/><Run Text="{Binding LatestVersion, Mode=OneWay}"/><Run Text=" 可用"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                            <!-- 操作按钮 -->
                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Width="52" Height="26" Background="#3a3a3a" Foreground="#d4d4d4"
                                                        BorderThickness="0" FontSize="11"
                                                        Content="{Binding EnableText}"
                                                        Click="TogglePlugin_Click" Tag="{Binding .}"/>
                                                <Button Width="52" Height="26" Background="#5a1a1a" Foreground="#f06060"
                                                        BorderThickness="0" FontSize="11" Margin="6,0,0,0"
                                                        Content="🗑 卸载"
                                                        Click="UninstallPlugin_Click" Tag="{Binding .}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock FontSize="10" Foreground="#666" Margin="0,2,0,0">
                                                    <Run Text="作者: "/><Run Text="{Binding Author, Mode=OneWay}"/>
                                                    <Run Text="  |  能力: "/>
                                                    <Run Text="{Binding CapabilitiesStr, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab 2: 发现插件 -->
            <TabItem Header="🌟 发现插件">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="推荐插件" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DiscoveryCount" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <Button Content="🔄 刷新" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="11" Margin="16,0,0,0" Click="DiscoveryRefresh_Click"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DiscoveryList" ItemsSource="{Binding DiscoveryItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" Background="#252526" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="12" FontWeight="Bold" Foreground="#569cd6"
                                                               VerticalAlignment="Center" Text="{Binding Name}"/>
                                                    <TextBlock FontSize="10" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Run Text="v"/><Run Text="{Binding Version}"/>
                                                    </TextBlock>
                                                    <Border Background="#3a3a3a" CornerRadius="3" Padding="6,1" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#aaa"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"
                                                           TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="400"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Rating}" FontSize="10" Foreground="#f0c040" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Run Text="{Binding Author}"/><Run Text=" · "/><Run Text="{Binding InstallSize}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            <Button Grid.Column="1" Width="72" Height="28"
                                                    Background="{Binding InstallButtonBg}" Foreground="{Binding InstallButtonFg}" BorderThickness="0"
                                                    FontSize="11" VerticalAlignment="Center"
                                                    Content="{Binding InstallStatus}"
                                                    Click="InstallPlugin_Click" Tag="{Binding .}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
