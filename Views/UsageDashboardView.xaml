<UserControl x:Class="AIIDEWPF.Views.UsageDashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AIIDEWPF.Converters"
        Background="#1e1e1e" Foreground="#d4d4d4">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:StringHasContentToVisibilityConverter x:Key="HasContentToVis"/>

        <!-- Token使用率→颜色转换器 -->
        <conv:UsagePercentToColorConverter x:Key="PercentToColor"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24">
            <StackPanel>

                <!-- 标题 -->
                <Grid Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊 大模型用量看板" FontSize="20" FontWeight="Bold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ModelFilterBox" Width="180" Height="28"
                                      Background="#3a3a3a" Foreground="#d4d4d4" FontSize="12"
                                      VerticalContentAlignment="Center" Margin="16,0,0,0"
                                      SelectionChanged="ModelFilter_SelectionChanged"
                                      ToolTip="切换查看不同模型的用量数据">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#2d2d2d"/>
                                        <Setter Property="Foreground" Value="#d4d4d4"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="实时追踪 API Token 消耗与配额使用情况" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="90" Height="30" Background="#555" Foreground="#d4d4d4"
                            BorderThickness="0" FontSize="12" Content="🔄 刷新" Cursor="Hand"
                            Click="Refresh_Click"/>
                </Grid>

                <!-- ===== 概览卡片行 ===== -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 会话总Token -->
                    <Border Grid.Column="0" Background="#2a2a2a" CornerRadius="8" Padding="16,14" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="📝 会话总Token" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TotalTokensText" FontSize="22" FontWeight="Bold" Foreground="#569cd6" Text="0"/>
                            <TextBlock Text="本次会话累计消耗" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- API调用次数 -->
                    <Border Grid.Column="1" Background="#2a2a2a" CornerRadius="8" Padding="16,14" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="🔗 API调用" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ApiCallsText" FontSize="22" FontWeight="Bold" Foreground="#d4d4d4" Text="0"/>
                            <TextBlock x:Name="SuccessRateText" FontSize="10" Foreground="#666" Margin="0,2,0,0" Text=""/>
                        </StackPanel>
                    </Border>

                    <!-- 估算费用 -->
                    <Border Grid.Column="2" Background="#2a2a2a" CornerRadius="8" Padding="16,14" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="💰 估算费用" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBlock x:Name="CostText" FontSize="22" FontWeight="Bold" Foreground="#d4a843" Text="¥0.00"/>
                            <TextBlock Text="DeepSeek标准定价" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 活跃模型 -->
                    <Border Grid.Column="3" Background="#2a2a2a" CornerRadius="8" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="🤖 活跃模型" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ActiveModelText" FontSize="14" FontWeight="Bold" Foreground="#569cd6"
                                       TextTrimming="CharacterEllipsis" Text="—"/>
                            <TextBlock x:Name="ProviderText" FontSize="10" Foreground="#666" Margin="0,2,0,0" Text=""/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== 平台余额（从大模型开放平台拉取） ===== -->
                <Border x:Name="BalanceSection" Background="#2a2a2a" CornerRadius="8" Padding="18,16" Margin="0,0,0,16"
                        Visibility="Visible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="💳 平台余额" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0"/>
                            <TextBlock x:Name="BalanceProviderText" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="BalanceTotalText" FontSize="22" FontWeight="Bold" Foreground="#4ec94e"
                                       Text="—" Margin="0,0,0,2"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="BalanceGrantedText" FontSize="11" Foreground="#888" Margin="0,0,12,0"/>
                                <TextBlock x:Name="BalanceToppedUpText" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock x:Name="BalanceFetchTimeText" FontSize="10" Foreground="#555"
                                       HorizontalAlignment="Right"/>
                            <TextBlock x:Name="NoBalanceText" FontSize="11" Foreground="#666"
                                       Text="发送一次对话后自动拉取余额..." TextWrapping="Wrap"
                                       HorizontalAlignment="Right" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== 输入/输出 Token 分布 ===== -->
                <Border Background="#2a2a2a" CornerRadius="8" Padding="18,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📥📤 Token 分布" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,12"/>
                        
                        <!-- 可视化进度条 -->
                        <Grid Height="32" Margin="0,0,0,8">
                            <Border Background="#333" CornerRadius="4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="InputBarCol" Width="*"/>
                                    <ColumnDefinition x:Name="OutputBarCol" Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#569cd6" CornerRadius="4,0,0,4" x:Name="InputBar"
                                        Visibility="Collapsed"/>
                                <Border Grid.Column="1" Background="#d4a843" CornerRadius="0,4,4,0" x:Name="OutputBar"
                                        Visibility="Collapsed"/>
                            </Grid>
                            <!-- 中间的数值 -->
                            <TextBlock x:Name="DistributionLabel" Text="0 / 0" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontSize="12" Foreground="#aaa"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Rectangle Width="12" Height="12" Fill="#569cd6" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                                <TextBlock Text=" 输入" FontSize="12" Foreground="#aaa" VerticalAlignment="Center" Margin="0,0,20,0"/>
                            </StackPanel>
                            <TextBlock x:Name="InputDetailText" Grid.Column="1" FontSize="12" Foreground="#d4d4d4" Text="0 tokens"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="2">
                                <Rectangle Width="12" Height="12" Fill="#d4a843" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                                <TextBlock Text=" 输出" FontSize="12" Foreground="#aaa" VerticalAlignment="Center" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="OutputDetailText" FontSize="12" Foreground="#d4d4d4" Margin="88,0,0,0" Text="0 tokens"/>
                    </StackPanel>
                </Border>

                <!-- ===== API 配额状态 ===== -->
                <Border Background="#2a2a2a" CornerRadius="8" Padding="18,16" Margin="0,0,0,16"
                        x:Name="QuotaSection">
                    <StackPanel>
                        <TextBlock Text="🌐 API 配额状态" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,12"/>

                        <!-- 有配额信息时 -->
                        <Grid x:Name="QuotaInfoGrid" Visibility="Collapsed">
                            <StackPanel>
                                <!-- Token配额进度条 -->
                                <TextBlock Text="Token 配额使用率" FontSize="12" Foreground="#aaa" Margin="0,0,0,6"/>
                                <Grid Height="20" Margin="0,0,0,12">
                                    <Border Background="#333" CornerRadius="4"/>
                                    <Border x:Name="TokenQuotaBar" Background="#569cd6" CornerRadius="4"
                                            HorizontalAlignment="Left" Width="0"/>
                                    <TextBlock x:Name="TokenQuotaPercentText" Text="0%" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" FontSize="11" Foreground="#fff"/>
                                </Grid>
                                <TextBlock x:Name="TokenQuotaDetailText" FontSize="11" Foreground="#888" Margin="0,0,0,12"
                                           Text="剩余: — / 总计: —"/>

                                <!-- 请求配额进度条 -->
                                <TextBlock Text="请求配额使用率" FontSize="12" Foreground="#aaa" Margin="0,0,0,6"/>
                                <Grid Height="20" Margin="0,0,0,8">
                                    <Border Background="#333" CornerRadius="4"/>
                                    <Border x:Name="RequestQuotaBar" Background="#6a9955" CornerRadius="4"
                                            HorizontalAlignment="Left" Width="0"/>
                                    <TextBlock x:Name="RequestQuotaPercentText" Text="0%" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" FontSize="11" Foreground="#fff"/>
                                </Grid>
                                <TextBlock x:Name="RequestQuotaDetailText" FontSize="11" Foreground="#888"
                                           Text="剩余: — / 总计: —"/>

                                <!-- 警告状态 -->
                                <Border x:Name="QuotaWarningBorder" Background="#5a3a00" CornerRadius="4"
                                        Padding="10,8" Margin="0,10,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="QuotaWarningText" FontSize="12" Foreground="#e8a800" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- 无配额信息时 -->
                        <TextBlock x:Name="NoQuotaInfoText" FontSize="12" Foreground="#666"
                                   Text="当前 API 提供商未返回速率限制信息。部分提供商（如 DeepSeek 官方）会通过响应头返回配额数据。"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ===== 会话用量警戒线 ===== -->
                <Border Background="#2a2a2a" CornerRadius="8" Padding="18,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="⚡ 会话用量警戒" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,12"/>
                        <Grid Height="24" Margin="0,0,0,8">
                            <Border Background="#333" CornerRadius="4"/>
                            <Border x:Name="SessionUsageBar" Background="#d4a843" CornerRadius="4"
                                    HorizontalAlignment="Left" Width="0"/>
                            <TextBlock x:Name="SessionUsagePercentText" Text="0%" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" FontSize="11" Foreground="#fff"/>
                        </Grid>
                        <TextBlock x:Name="SessionUsageDetailText" FontSize="11" Foreground="#888" Text="0 / 100K tokens (建议上限)"/>
                        <TextBlock FontSize="10" Foreground="#666" Margin="0,4,0,0"
                                   Text="单次会话超过建议上限时，大模型响应质量可能下降，建议开启新对话。"/>
                    </StackPanel>
                </Border>

                <!-- ===== 最近调用历史 ===== -->
                <Border Background="#2a2a2a" CornerRadius="8" Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="📋 最近调用记录" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,12"/>

                        <!-- 表头 -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="时间" FontSize="11" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Text="输入" FontSize="11" Foreground="#666" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="输出" FontSize="11" Foreground="#666" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="耗时" FontSize="11" Foreground="#666" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="模型" FontSize="11" Foreground="#666" Margin="12,0,0,0"/>
                        </Grid>

                        <!-- 历史列表 -->
                        <ItemsControl x:Name="CallHistoryList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Time, StringFormat='{}{0:HH:mm:ss}'}"
                                                   FontSize="11" Foreground="#aaa"/>
                                        <TextBlock Grid.Column="1" Text="{Binding InputTokens, StringFormat='{}{0:N0}'}"
                                                   FontSize="11" Foreground="#569cd6" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="2" Text="{Binding OutputTokens, StringFormat='{}{0:N0}'}"
                                                   FontSize="11" Foreground="#d4a843" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" FontSize="11" Foreground="#888" HorizontalAlignment="Right">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0:F0}ms">
                                                    <Binding Path="ResponseTimeMs"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Column="4" Text="{Binding ModelName}" FontSize="11"
                                                   Foreground="#888" Margin="12,0,0,0" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 空状态 -->
                        <TextBlock x:Name="NoHistoryText" Text="暂无调用记录，开始对话后会自动记录。"
                                   FontSize="12" Foreground="#666" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
