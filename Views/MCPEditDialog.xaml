<Window x:Class="AIIDEWPF.Views.MCPEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCP 服务器配置" Height="420" Width="500"
        Background="#1e1e1e" Foreground="#d4d4d4"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="名称" FontSize="12" Foreground="#aaa" Margin="0,0,0,2"/>
        <TextBox x:Name="TxtName" Grid.Row="1" Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                 Padding="8,4" FontSize="13" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Text="命令（如 npx @modelcontextprotocol/server-filesystem）" FontSize="12" Foreground="#aaa" Margin="0,0,0,2"/>
        <TextBox x:Name="TxtCommand" Grid.Row="3" Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                 Padding="8,4" FontSize="13" FontFamily="Consolas,monospace" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="4" Text="参数（每行一个）" FontSize="12" Foreground="#aaa" Margin="0,0,0,2"/>
        <TextBox x:Name="TxtArgs" Grid.Row="5" Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                 Padding="8,4" FontSize="12" FontFamily="Consolas,monospace" Margin="0,0,0,8"
                 AcceptsReturn="True" MinHeight="60"/>

        <CheckBox x:Name="ChkEnabled" Grid.Row="6" Content="启用" Foreground="#d4d4d4" IsChecked="True" Margin="0,4,0,0"/>

        <TextBlock Grid.Row="7" Text="描述" FontSize="12" Foreground="#aaa" Margin="0,8,0,2"/>
        <TextBox x:Name="TxtDescription" Grid.Row="7" Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                 Padding="8,4" FontSize="12" Margin="0,24,0,0" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                    BorderThickness="0" Click="Cancel_Click"/>
            <Button Content="保存" Width="72" Height="28" Background="#007acc" Foreground="White"
                    BorderThickness="0" Margin="8,0,0,0" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
