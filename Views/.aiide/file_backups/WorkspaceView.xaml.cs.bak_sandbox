    /// <summary>Containers：启动容器</summary>
    private void ContainerStart_Click(object sender, System.Windows.RoutedEventArgs e)
    {
        if (sender is FrameworkElement fe && fe.Tag is string containerId)
        {
            try
            {
                var psi = new System.Diagnostics.ProcessStartInfo("docker", $"start {containerId}")
                {
                    RedirectStandardOutput = true,
                    UseShellExecute = false,
                    CreateNoWindow = true
                };
                using var p = System.Diagnostics.Process.Start(psi);
                p?.WaitForExit(5000);
                _viewModel.RefreshContainersCommand.Execute(null);
                _viewModel.Chat.AddMessage("system", $"✅ 容器 {containerId} 已启动");
            }
            catch (Exception ex)
            {
                _viewModel.Chat.AddMessage("system", $"❌ 启动容器失败: {ex.Message}");
            }
        }
    }

    /// <summary>Containers：停止容器</summary>
    private void ContainerStop_Click(object sender, System.Windows.RoutedEventArgs e)
    {
        if (sender is FrameworkElement fe && fe.Tag is string containerId)
        {
            try
            {
                var psi = new System.Diagnostics.ProcessStartInfo("docker", $"stop {containerId}")
                {
                    RedirectStandardOutput = true,
                    UseShellExecute = false,
                    CreateNoWindow = true
                };
                using var p = System.Diagnostics.Process.Start(psi);
                p?.WaitForExit(5000);
                _viewModel.RefreshContainersCommand.Execute(null);
                _viewModel.Chat.AddMessage("system", $"⏹ 容器 {containerId} 已停止");
            }
            catch (Exception ex)
            {
                _viewModel.Chat.AddMessage("system", $"❌ 停止容器失败: {ex.Message}");
            }
        }
    }

    // ===== 余额提醒 =====

    private UsageTrackerService? _chatUsageTracker;

    private void SetupBalanceBar()
    {
        _chatUsageTracker = _viewModel.UsageTracker;
        if (_chatUsageTracker != null)
        {
            _chatUsageTracker.OnStatusChanged += OnChatUsageStatusChanged;
            _chatUsageTracker.OnBalanceUpdated += OnChatUsageBalanceUpdated;
            _chatUsageTracker.OnWarning += OnChatUsageWarning;
            _chatUsageTracker.OnCritical += OnChatUsageCritical;
            _chatUsageTracker.OnQuotaExhausted += OnChatUsageQuotaExhausted;
            Dispatcher.InvokeAsync(UpdateChatBalanceStatus);
        }
    }

    private void OnChatUsageStatusChanged() => Dispatcher.InvokeAsync(UpdateChatBalanceStatus);
    private void OnChatUsageBalanceUpdated() => Dispatcher.InvokeAsync(UpdateChatBalanceStatus);

    private void OnChatUsageWarning(string msg)
    {
        Dispatcher.InvokeAsync(() =>
        {
            ChatBalanceWarningText.Text = msg;
            ChatBalanceWarningText.Foreground = new SolidColorBrush(Color.FromRgb(0xfd, 0x7e, 0x14));
        });
    }

    private void OnChatUsageCritical(string msg)
    {
        Dispatcher.InvokeAsync(() =>
        {
            ChatBalanceWarningText.Text = msg;
            ChatBalanceWarningText.Foreground = new SolidColorBrush(Color.FromRgb(0xf4, 0x47, 0x47));
        });
    }

    private void OnChatUsageQuotaExhausted(string msg)
    {
        Dispatcher.InvokeAsync(() =>
        {
            ChatBalanceBar.Visibility = Visibility.Visible;
            ChatBalanceWarningText.Text = "❌ 余额已耗尽，无法继续处理";
            ChatBalanceWarningText.Foreground = new SolidColorBrush(Color.FromRgb(0xf4, 0x47, 0x47));

            MessageBox.Show(
                $"{msg}\n\n" +
                "💡 建议操作：\n" +
                "  1. 前往大模型开放平台充值余额\n" +
                "  2. 切换到其他可用模型（设置 → 模型管理）\n" +
                "  3. 更换 API Key\n" +
                "  4. 等待配额周期重置（每小时/每天自动重置）",
                "⚠ 余额已耗尽",
                MessageBoxButton.OK,
                MessageBoxImage.Error);
        });
    }

    private void UpdateChatBalanceStatus()
    {
        if (_chatUsageTracker == null)
        {
            ChatBalanceBar.Visibility = Visibility.Collapsed;
            return;
        }

        ChatBalanceBar.Visibility = Visibility.Visible;

        // 模型名称
        var modelName = ModelMgr.ActiveModel?.Name ?? ModelMgr.ActiveModel?.Id ?? "当前模型";
        ChatBalanceModelName.Text = modelName;

        // 会话费用
        var cost = _chatUsageTracker.EstimatedCostYuan;
        ChatBalanceSessionCost.Text = $"会话: ¥{cost:F2}";

        // 用量百分比
        var usagePercent = _chatUsageTracker.RateLimitUsagePercent;
        if (usagePercent >= 0)
        {
            ChatBalanceProgressBar.Width = Math.Min(60, usagePercent * 0.6);
            ChatBalancePercentText.Text = $"{usagePercent:F0}%";

            if (usagePercent >= _chatUsageTracker.CriticalThresholdPercent)
            {
                ChatBalanceProgressBar.Background = new SolidColorBrush(Color.FromRgb(0xf4, 0x47, 0x47));
                ChatBalancePercentText.Foreground = new SolidColorBrush(Color.FromRgb(0xf4, 0x47, 0x47));
            }
            else if (usagePercent >= _chatUsageTracker.WarningThresholdPercent)
            {
                ChatBalanceProgressBar.Background = new SolidColorBrush(Color.FromRgb(0xfd, 0x7e, 0x14));
                ChatBalancePercentText.Foreground = new SolidColorBrush(Color.FromRgb(0xfd, 0x7e, 0x14));
            }
            else
            {
                ChatBalanceProgressBar.Background = new SolidColorBrush(Color.FromRgb(0x4e, 0xc9, 0xb0));
                ChatBalancePercentText.Foreground = new SolidColorBrush(Color.FromRgb(0x88, 0x88, 0x88));
            }
        }
        else
        {
            ChatBalanceProgressBar.Width = 0;
            ChatBalancePercentText.Text = "";
        }
    }

    // ===== 编辑器内快捷键辅助方法 =====

    /// <summary>在编辑器中打开查找</summary>
    private void OpenSearchInEditor()
    {
        // AvalonEdit 自带 SearchPanel，通过 Ctrl+F 触发原生查找
        var searchPanel = ICSharpCode.AvalonEdit.Search.SearchPanel.Install(CodeEditor.TextArea);
        searchPanel.Open();
    }

    /// <summary>在编辑器中打开替换（打开搜索面板，用户可点击展开替换）</summary>
    private void OpenReplaceInEditor()
    {
        var searchPanel = ICSharpCode.AvalonEdit.Search.SearchPanel.Install(CodeEditor.TextArea);
        searchPanel.Open();
        // 通过反射设置替换模式可见（AvalonEdit 内部字段）
        try
        {
            var isReplaceProp = typeof(ICSharpCode.AvalonEdit.Search.SearchPanel)
                .GetProperty("IsReplaceMode", System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance);
            if (isReplaceProp != null && isReplaceProp.CanWrite)
            {
                isReplaceProp.SetValue(searchPanel, true);
            }
        }
        catch { /* 反射失败则仅打开搜索 */ }
    }

    /// <summary>显示快捷键参考对话框</summary>
    private void ShowKeyboardShortcuts()
    {
        var dlg = new KeyboardShortcutsDialog
        {
            Owner = Window.GetWindow(this)
        };
        dlg.ShowDialog();
    }

    // ============================================================
    // 文件树右键菜单 & 增强功能
    // ============================================================

    private FileItem? _lastSelectedFileItem;

    private void FileTree_SelectedItemChanged(object sender, RoutedPropertyChangedEventArgs<object> e)
    {
        if (e.NewValue is FileItem item)
            _lastSelectedFileItem = item;
    }

    private FileItem? GetContextFileItem()
    {
        return FileTreeView.SelectedItem as FileItem ?? _lastSelectedFileItem;
    }

    private string GetContextDir()
    {
        var item = GetContextFileItem();
        if (item == null) return _viewModel.FileTree.ProjectPath ?? Environment.CurrentDirectory;
        return item.IsDirectory ? item.FullPath : Path.GetDirectoryName(item.FullPath) ?? item.FullPath;
    }

    private void ContextNewFile_Click(object sender, RoutedEventArgs e)
    {
        var dir = GetContextDir();
        var baseName = "新建文件.txt";
        var filePath = Path.Combine(dir, baseName);
        if (File.Exists(filePath) || Directory.Exists(filePath))
            filePath = _viewModel.ResolveNameConflict(dir, baseName, false);
        if (string.IsNullOrEmpty(filePath)) return;
        try
        {
            File.WriteAllText(filePath, "");
            _viewModel.RefreshFileTree(_viewModel.FileTree.ProjectPath);
            _viewModel.OpenFile(filePath);
        }
        catch (Exception ex)
        {
            MessageBox.Show($"创建文件失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
        }
    }

    private void ContextNewFolder_Click(object sender, RoutedEventArgs e)
    {
        var dir = GetContextDir();
        var baseName = "新建文件夹";
        var folderPath = Path.Combine(dir, baseName);
        if (Directory.Exists(folderPath) || File.Exists(folderPath))
            folderPath = _viewModel.ResolveNameConflict(dir, baseName, true);
        if (string.IsNullOrEmpty(folderPath)) return;
        try
        {
            Directory.CreateDirectory(folderPath);
            _viewModel.RefreshFileTree(_viewModel.FileTree.ProjectPath);
        }
        catch (Exception ex)
        {
            MessageBox.Show($"创建文件夹失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
        }
    }

    private void ContextRevealInExplorer_Click(object sender, RoutedEventArgs e)
    {
        var item = GetContextFileItem();
        if (item == null) return;
        try
        {
            System.Diagnostics.Process.Start("explorer.exe", $"/select,\"{item.FullPath}\"");
        }
        catch (Exception ex)
        {
            MessageBox.Show($"打开资源管理器失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
        }
    }

    private void ContextOpenToSide_Click(object sender, RoutedEventArgs e)
    {
        var item = GetContextFileItem();
        if (item == null || item.IsDirectory) return;
        _viewModel.OpenFile(item.FullPath);
    }

    private void ContextCopyPath_Click(object sender, RoutedEventArgs e)
    {
        var item = GetContextFileItem();
        if (item == null) return;
        Clipboard.SetText(item.FullPath);
    }

    private void ContextCopyRelativePath_Click(object sender, RoutedEventArgs e)
    {
        var item = GetContextFileItem();
        if (item == null) return;
        Clipboard.SetText(string.IsNullOrEmpty(item.RelativePath) ? item.FullPath : item.RelativePath);
    }

    private void ContextRename_Click(object sender, RoutedEventArgs e)
    {
        var item = GetContextFileItem();
        if (item == null) return;
        var oldName = item.Name;
        var newName = Interaction.InputBox("输入新名称：", "重命名", oldName);
        if (string.IsNullOrEmpty(newName) || newName == oldName) return;

        var dir = Path.GetDirectoryName(item.FullPath) ?? "";
        var newPath = Path.Combine(dir, newName);
        if (File.Exists(newPath) || Directory.Exists(newPath))
        {
            MessageBox.Show($"名称 \"{newName}\" 已存在，请使用其他名称。", "重命名", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }
        try
        {
            if (item.IsDirectory)
                Directory.Move(item.FullPath, newPath);
            else
                File.Move(item.FullPath, newPath);
            _viewModel.RefreshFileTree(_viewModel.FileTree.ProjectPath);
        }
        catch (Exception ex)
        {
            MessageBox.Show($"重命名失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
        }
    }

    private void ContextDelete_Click(object sender, RoutedEventArgs e)
    {
        var item = GetContextFileItem();
        if (item == null) return;
        var msg = item.IsDirectory
            ? $"确定要删除文件夹 \"{item.Name}\" 及其所有内容吗？此操作不可撤销。"
            : $"确定要删除文件 \"{item.Name}\" 吗？此操作不可撤销。";
        var result = MessageBox.Show(msg, "删除确认", MessageBoxButton.YesNo, MessageBoxImage.Warning);
        if (result != MessageBoxResult.Yes) return;
        try
        {
            if (item.IsDirectory)
                Directory.Delete(item.FullPath, true);
            else
                File.Delete(item.FullPath);
            _viewModel.RefreshFileTree(_viewModel.FileTree.ProjectPath);
        }
        catch (Exception ex)
        {
            MessageBox.Show($"删除失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
        }
    }

    /// <summary>全部折叠文件树</summary>
    private void CollapseAllTreeNodes(ItemsControl parent)
    {
        foreach (var item in parent.Items)
        {
            if (parent.ItemContainerGenerator.ContainerFromItem(item) is TreeViewItem tvi)
            {
                tvi.IsExpanded = false;
                CollapseAllTreeNodes(tvi);
            }
        }
    }

    /// <summary>在文件树中定位并展开到指定文件（Auto Reveal）</summary>
    public void RevealFileInTree(string filePath)
    {
        if (string.IsNullOrEmpty(filePath)) return;
        Dispatcher.BeginInvoke(new Action(() =>
        {
            FindAndSelectTreeItem(FileTreeView, filePath);
        }), System.Windows.Threading.DispatcherPriority.Background);
    }

    private static bool FindAndSelectTreeItem(ItemsControl parent, string filePath)
    {
        foreach (var item in parent.Items)
        {
            if (item is FileItem fi && string.Equals(fi.FullPath, filePath, StringComparison.OrdinalIgnoreCase))
            {
                if (parent.ItemContainerGenerator.ContainerFromItem(item) is TreeViewItem tvi)
                {
                    tvi.IsSelected = true;
                    tvi.BringIntoView();
                    ExpandAncestors(tvi);
                    return true;
                }
            }
            if (parent.ItemContainerGenerator.ContainerFromItem(item) is TreeViewItem childTvi)
            {
                if (FindAndSelectTreeItem(childTvi, filePath))
                    return true;
            }
        }
        return false;
    }

    private static void ExpandAncestors(TreeViewItem tvi)
    {
        var parent = VisualTreeHelper.GetParent(tvi);
        while (parent != null)
        {
            if (parent is TreeViewItem parentTvi)
            {
                parentTvi.IsExpanded = true;
                parent = VisualTreeHelper.GetParent(parentTvi);
            }
            else
            {
                parent = VisualTreeHelper.GetParent(parent);
            }
        }
    }

    // ===== 打开编辑器列表事件 =====
    private void OpenEditorItem_Click(object sender, MouseButtonEventArgs e)
    {
        if (sender is FrameworkElement fe && fe.DataContext is EditorTab tab)
        {
            _viewModel.OpenFile(tab.FilePath);
        }
    }

    private void OpenEditorClose_Click(object sender, MouseButtonEventArgs e)
    {
        if (sender is FrameworkElement fe && fe.DataContext is EditorTab tab)
        {
            _viewModel.Editor.Tabs.Remove(tab);
            e.Handled = true;
        }
    }

    // ===== 输入框 Watermark 提示显隐控制 =====

    private void ChatInputBox_GotFocus(object sender, RoutedEventArgs e)
        => UpdateWatermarkVisibility();

    private void ChatInputBox_LostFocus(object sender, RoutedEventArgs e)
        => UpdateWatermarkVisibility();

    private void ChatInputBox_TextChanged(object sender, TextChangedEventArgs e)
        => UpdateWatermarkVisibility();

    /// <summary>根据焦点和内容状态控制 Watermark 可见性</summary>
    private void UpdateWatermarkVisibility()
    {
        if (ChatWatermark == null || ChatInputBox == null) return;
        var hasText = !string.IsNullOrEmpty(ChatInputBox.Text);
        var isFocused = ChatInputBox.IsFocused;
        ChatWatermark.Visibility = (!hasText && !isFocused) ? Visibility.Visible : Visibility.Collapsed;
    }
}
