    private void PendingMessageEdit_Click(object sender, RoutedEventArgs e)
    {
        if (sender is FrameworkElement fe && fe.Tag is PendingMessageItem item)
        {
            if (item.IsEditing)
            {
                // 确认编辑：关闭编辑模式，内容已通过绑定更新
                item.IsEditing = false;
            }
            else
            {
                // 进入编辑模式
                item.IsEditing = true;
            }
        }
    }

    /// <summary>等待队列编辑框按键处理（Enter 确认编辑，Escape 取消）</summary>
    private void PendingMessageEditBox_KeyDown(object sender, System.Windows.Input.KeyEventArgs e)
    {
        if (e.Key == System.Windows.Input.Key.Enter && Keyboard.Modifiers == ModifierKeys.None)
        {
            // Enter 确认编辑
            if (sender is FrameworkElement fe && fe.Tag is PendingMessageItem item)
            {
                item.IsEditing = false;
            }
            e.Handled = true;
        }
        else if (e.Key == System.Windows.Input.Key.Escape)
        {
            // Escape 取消编辑
            if (sender is FrameworkElement fe && fe.Tag is PendingMessageItem item)
            {
                item.IsEditing = false;
            }
            e.Handled = true;
        }
    }

