    private void ToggleDiff_Click(object sender, RoutedEventArgs e)
    {
        if (sender is FrameworkElement fe && fe.Tag is PendingFileChange change)
        {
            change.IsDiffExpanded = !change.IsDiffExpanded;
            if (change.IsDiffExpanded && change.DiffLines.Count == 0)
            {
                var original = change.OriginalContent;
                var current = "";
                try { if (File.Exists(change.FilePath)) current = File.ReadAllText(change.FilePath); } catch { }
                var diff = Services.DiffService.ComputeDiff(original, current);
                foreach (var hunk in diff.Hunks)
                    foreach (var line in hunk.Lines)
                        change.DiffLines.Add(new ViewModels.DiffLineDisplay
                        {
                            Text = line.Text,
                            Prefix = line.Type switch { Services.DiffLineType.Added => "+", Services.DiffLineType.Removed => "-", _ => " " },
                            BackgroundColor = line.Type switch { Services.DiffLineType.Added => "#1a3a1a", Services.DiffLineType.Removed => "#3a1a1a", _ => "Transparent" }
                        });
            }
        }
    }

