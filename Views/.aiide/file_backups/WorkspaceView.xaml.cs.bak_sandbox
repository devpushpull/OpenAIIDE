    // ===== 根据语言类型切换高亮 =====

    private void ApplySyntaxHighlighting(string fileType)
    {
        var hlName = fileType switch
        {
            "C#" or "CSharp" => "C#",
            "Python" => "Python",
            "Java" => "Java",
            "JavaScript" or "TypeScript" => "JavaScript",
            "HTML" => "HTML",
            "CSS" => "CSS",
            "XML" or "XAML" => "XML",
            "C" or "C++" => "C++",
            "Rust" => "Rust",
            "Go" => "Go",
            "SQL" => "SQL",
            "JSON" => "JSON",
            "Markdown" => "Markdown",
            "YAML" => "YAML",
            "PowerShell" => "PowerShell",
            "批处理" => "Batch",
            _ => null
        };

        if (hlName != null)
        {
            var hl = ICSharpCode.AvalonEdit.Highlighting.HighlightingManager.Instance.GetDefinition(hlName);
            if (hl != null)
                CodeEditor.SyntaxHighlighting = hl;
        }
        else
        {
            CodeEditor.SyntaxHighlighting = null;
        }
    }

