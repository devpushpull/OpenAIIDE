using System.IO;
using System.Linq;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using System.Windows.Media;
using AIIDEWPF.ViewModels;
using AIIDEWPF.Models;
using AIIDEWPF.Services;
using Microsoft.VisualBasic;

namespace AIIDEWPF.Views;

public partial class WorkspaceView : UserControl
{
    private readonly MainViewModel _viewModel;
    private ModelManager ModelMgr => _viewModel.ModelManager;
    private InlineCompletionLayer? _completionLayer;
    private DiagnosticsMargin? _diagnosticsMargin;
    private LSPService? _lspService;
    private readonly VoiceInputService _voiceInput;
    private GridLength _savedSidebarWidth = new(260);
    private GridLength _savedAIPanelWidth = new(480);

    public WorkspaceView(MainViewModel viewModel)
    {
        InitializeComponent();
        _viewModel = viewModel;
        DataContext = _viewModel;

        // 设置 CodeEditor 引用，供调试器和LSP使用
        _viewModel.CodeEditor = CodeEditor;

        // ===== 余额提醒状态栏 =====
        SetupBalanceBar();

        // ===== LSP 实时诊断 =====
        InitializeLSP();

        // 初始化提供商下拉（预设 + 可自定义输入）
        foreach (var p in ModelMgr.GetProviders())
            SettingsProviderBox.Items.Add(p);
        SettingsProviderBox.IsEditable = true;

        // 聊天栏提供商下拉
        foreach (var p in ModelMgr.GetProviders())
            ChatProviderBox.Items.Add(p);
        ChatProviderBox.SelectedItem = ModelMgr.ActiveProvider;
        RefreshChatModelBox();

        // ===== 语音输入初始化 =====
        _voiceInput = new VoiceInputService();
        _voiceInput.OnSpeechRecognized += text =>
        {
            // 将识别文本插入到光标位置
            var caretIndex = ChatInputBox.CaretIndex;
            var currentText = _viewModel.Chat.InputText ?? "";
            var insertText = currentText.Length > 0 && caretIndex > 0 && !currentText.EndsWith(' ')
                ? " " + text
                : text;
            _viewModel.Chat.InputText = currentText.Insert(caretIndex, insertText);
            ChatInputBox.CaretIndex = caretIndex + insertText.Length;
            ChatInputBox.Focus();
        };
        _voiceInput.OnListeningChanged += isListening =>
        {
            VoiceBtn.Background = isListening
                ? new SolidColorBrush(Color.FromRgb(30, 150, 60))  // 录音中: 绿色
                : new SolidColorBrush(Color.FromRgb(0x3a, 0x3a, 0x3a)); // 空闲: 灰色
            VoiceBtn.Foreground = isListening
                ? new SolidColorBrush(Color.FromRgb(255, 255, 255))
                : new SolidColorBrush(Color.FromRgb(0xaa, 0xaa, 0xaa));
            VoiceBtn.ToolTip = isListening ? "正在录音... (点击停止)" : "语音输入 (点击开始/停止)";
        };
        _voiceInput.OnError += msg =>
        {
            System.Windows.MessageBox.Show(msg, "语音输入", MessageBoxButton.OK, MessageBoxImage.Warning);
        };

        // ===== 事件绑定 =====

        // 全部折叠命令：由 ViewModel 触发，View 执行
        _viewModel.CollapseAllRequested += () => CollapseAllTreeNodes(FileTreeView);
        // 自动定位文件：打开文件时在树中定位
        _viewModel.FileOpenedInTree += filePath => RevealFileInTree(filePath);

        // 弹窗打开/关闭
        _viewModel.PropertyChanged += (s, e) =>
        {
            if (e.PropertyName == nameof(MainViewModel.IsSettingsOpen))
            {
                if (_viewModel.IsSettingsOpen)
                {
                    SettingsOverlay.Visibility = Visibility.Visible;
                    RefreshModelList();
                    ClearModelForm();
                }
                else
                {
                    SettingsOverlay.Visibility = Visibility.Collapsed;
                }
            }
            // 面板切换时自动刷新数据
            else if (e.PropertyName == nameof(MainViewModel.ActiveSidebar))
            {
                switch (_viewModel.ActiveSidebar)
                {
                    case "git":
                        _viewModel.GitRefreshCommand.Execute(null);
                        break;
                    case "extensions":
                        _viewModel.RefreshPluginsCommand.Execute(null);
                        break;
                    case "wiki":
                        _viewModel.WikiSearchCommand.Execute(null);
                        break;
                    case "remote":
                        _viewModel.RefreshRemoteCommand.Execute(null);
                        break;
                    case "containers":
                        _viewModel.RefreshContainersCommand.Execute(null);
                        break;
                }
            }
            // 侧边栏显隐 → 动态调整 Grid 列宽 + Min/Max + 分隔条显隐
            else if (e.PropertyName == nameof(MainViewModel.IsLeftSidebarVisible))
            {
                var colSidebar = MainLayoutGrid.ColumnDefinitions[1];
                var colSplit = MainLayoutGrid.ColumnDefinitions[2];
                if (_viewModel.IsLeftSidebarVisible)
                {
                    colSidebar.Width = _savedSidebarWidth;
                    colSidebar.MinWidth = 180;
                    colSidebar.MaxWidth = 500;
                    colSplit.Width = GridLength.Auto;
                    LeftSplitter.Visibility = Visibility.Visible;
                }
                else
                {
                    _savedSidebarWidth = colSidebar.Width;
                    colSidebar.Width = new GridLength(0);
                    colSidebar.MinWidth = 0;
                    colSidebar.MaxWidth = double.PositiveInfinity;
                    colSplit.Width = new GridLength(0);
                    LeftSplitter.Visibility = Visibility.Collapsed;
                }
            }
            // AI面板显隐 → 动态调整 Grid 列宽 + Min/Max + 分隔条显隐
            else if (e.PropertyName == nameof(MainViewModel.IsAIPanelVisible))
            {
                var colAIPanel = MainLayoutGrid.ColumnDefinitions[5];
                var colSplit = MainLayoutGrid.ColumnDefinitions[4];
                if (_viewModel.IsAIPanelVisible)
                {
                    colAIPanel.Width = _savedAIPanelWidth;
                    colAIPanel.MinWidth = 280;
                    colAIPanel.MaxWidth = 800;
                    colSplit.Width = GridLength.Auto;
                    RightSplitter.Visibility = Visibility.Visible;
                }
                else
                {
                    _savedAIPanelWidth = colAIPanel.Width;
                    colAIPanel.Width = new GridLength(0);
                    colAIPanel.MinWidth = 0;
                    colAIPanel.MaxWidth = double.PositiveInfinity;
                    colSplit.Width = new GridLength(0);
                    RightSplitter.Visibility = Visibility.Collapsed;
                }
            }
        };

        // 初始化分隔条可见性（与 ViewModel 当前状态同步）
        LeftSplitter.Visibility = _viewModel.IsLeftSidebarVisible ? Visibility.Visible : Visibility.Collapsed;
        RightSplitter.Visibility = _viewModel.IsAIPanelVisible ? Visibility.Visible : Visibility.Collapsed;

        // AvalonEdit syntax highlighting
        CodeEditor.SyntaxHighlighting = ICSharpCode.AvalonEdit.Highlighting.HighlightingManager.Instance
            .GetDefinition("C#");

        // ===== C# 语法增强着色（async/await/var/Task等关键词）=====
        CodeEditor.TextArea.TextView.LineTransformers.Add(new CSharpEnhanceColorizer());

        // ===== 颜色预览渲染器（检测 #hex, rgb(), hsl() 颜色值并显示内联颜色方块）=====
        CodeEditor.TextArea.TextView.BackgroundRenderers.Add(new ColorPreviewRenderer(CodeEditor.TextArea));

        // ===== 停止/发送按钮联动 =====
        _viewModel.Chat.PropertyChanged += (s, e) =>
        {
            if (e.PropertyName == nameof(ChatViewModel.IsStreaming))
            {
                Dispatcher.Invoke(() =>
                {
                    StopBtn.Visibility = _viewModel.Chat.IsStreaming ? Visibility.Visible : Visibility.Collapsed;
                    SendBtn.Visibility = _viewModel.Chat.IsStreaming ? Visibility.Collapsed : Visibility.Visible;
                });
            }
        };

        // 编辑器语言高亮切换 + 行号导航
        _viewModel.Editor.PropertyChanged += (s, e) =>
        {
            if (e.PropertyName == nameof(EditorViewModel.FileType))
                ApplySyntaxHighlighting(_viewModel.Editor.FileType);
            if (e.PropertyName == nameof(EditorViewModel.NavigateToLine) && _viewModel.Editor.NavigateToLine >= 1)
            {
                var line = _viewModel.Editor.NavigateToLine;
                Dispatcher.BeginInvoke(() =>
                {
                    CodeEditor.ScrollToLine(line);
                    // 将光标移到目标行
                    var docLine = CodeEditor.Document.GetLineByNumber(line);
                    CodeEditor.TextArea.Caret.Offset = docLine.Offset;
                    CodeEditor.Focus();
                }, System.Windows.Threading.DispatcherPriority.Background);
            }
        };

        // Editor <-> ViewModel 双向同步（AvalonEdit Text 不是 DependencyProperty，只能代码绑定）
        _viewModel.Editor.PropertyChanged += (s, e) =>
        {
            if (e.PropertyName == nameof(EditorViewModel.CurrentContent))
            {
                if (CodeEditor.Text != _viewModel.Editor.CurrentContent)
                    CodeEditor.Text = _viewModel.Editor.CurrentContent;
            }
        };
        CodeEditor.TextChanged += (s, e) =>
        {
            if (_viewModel.Editor.CurrentContent != CodeEditor.Text)
                _viewModel.Editor.CurrentContent = CodeEditor.Text;
            // LSP: 通知文档变更
            NotifyLSPDidChange();
        };

        // File drag & drop
        AllowDrop = true;
        DragEnter += (s, e) =>
        {
            if (e.Data.GetDataPresent(DataFormats.FileDrop))
                e.Effects = DragDropEffects.Copy;
            else
                e.Effects = DragDropEffects.None;
        };
        Drop += (s, e) =>
        {
            if (e.Data.GetData(DataFormats.FileDrop) is string[] files && files.Length > 0)
                _viewModel.OpenFile(files[0]);
        };

        // ===== AI 代码补全层 =====
        var ccService = new CodeCompletionService();
        ccService.Initialize(_viewModel.Config, ModelMgr);
        _completionLayer = new InlineCompletionLayer(CodeEditor, ccService);

        // ===== LSP 诊断波浪线渲染器 =====
        _diagnosticsMargin = new DiagnosticsMargin(CodeEditor);
        CodeEditor.TextArea.TextView.BackgroundRenderers.Add(_diagnosticsMargin);

        // ===== 断点装订线 =====
        var bpMargin = new BreakpointMargin(CodeEditor, _viewModel.DebugSvc);
        CodeEditor.TextArea.TextView.BackgroundRenderers.Add(bpMargin);

        // 断点变更时刷新装订线
        _viewModel.DebugSvc.OnBreakpointsChanged += () =>
            Dispatcher.Invoke(() => CodeEditor.TextArea.TextView.InvalidateLayer(ICSharpCode.AvalonEdit.Rendering.KnownLayer.Background));

        // 快捷键：Alt+P 手动触发补全
        KeyDown += (s, e) =>
        {
            if (e.Key == Key.P && Keyboard.Modifiers == ModifierKeys.Alt)
            {
                e.Handled = true;
                _completionLayer?.RequestCompletion();
            }
        };

        // ===== Ctrl+Click 跳转到定义 =====
        CodeEditor.MouseLeftButtonDown += (s, e) =>
        {
            if (Keyboard.Modifiers == ModifierKeys.Control)
            {
                e.Handled = true;
                var pos = CodeEditor.GetPositionFromPoint(e.GetPosition(CodeEditor));
                if (pos.HasValue)
                {
                    var offset = CodeEditor.Document.GetOffset(pos.Value.Location);
                    var word = GetWordAtOffset(CodeEditor.Document, offset);
                    if (!string.IsNullOrEmpty(word))
                        _viewModel.GoToDefinitionCommand.Execute(null);
                }
            }
        };

        // 粘贴检测——检测粘贴的代码是否在项目中
        DataObject.AddPastingHandler(ChatInputBox, (s, e) =>
        {
            if (e.DataObject.GetDataPresent(DataFormats.Text))
            {
                var text = e.DataObject.GetData(DataFormats.Text) as string;
                if (!string.IsNullOrEmpty(text))
                {
                    Dispatcher.BeginInvoke(() => _viewModel.DetectPastedCode(text),
                        System.Windows.Threading.DispatcherPriority.Background);
                }
            }
        });

        // ═══ 输入框 Watermark 提示：有内容或聚焦时隐藏 ═══
        UpdateWatermarkVisibility();

        // Keyboard shortcuts
        KeyDown += (s, e) =>
        {
            if (Keyboard.Modifiers == ModifierKeys.Control)
            {
                switch (e.Key)
                {
                    case Key.S: _viewModel.SaveFile(false); e.Handled = true; break;
                    case Key.O: _viewModel.OpenFile(); e.Handled = true; break;
                    case Key.N: _viewModel.NewFile(); e.Handled = true; break;
                    case Key.W: _viewModel.CloseFile(); e.Handled = true; break;
                    case Key.Oem3: _viewModel.ToggleTerminal(); e.Handled = true; break;
                    case Key.K: HandleInlineEdit(); e.Handled = true; break;
                    case Key.B: _viewModel.ToggleSidebarCommand.Execute(null); e.Handled = true; break;
                    case Key.L: _viewModel.ToggleAIPanelCommand.Execute(null); e.Handled = true; break;
                    case Key.F: OpenSearchInEditor(); e.Handled = true; break;
                    case Key.H: OpenReplaceInEditor(); e.Handled = true; break;
                    case Key.P: _viewModel.SwitchSidebarCommand.Execute("search"); e.Handled = true; break;
                }
            }
            else if (Keyboard.Modifiers == (ModifierKeys.Control | ModifierKeys.Shift))
            {
                switch (e.Key)
                {
                    case Key.F: _viewModel.SwitchSidebarCommand.Execute("search"); e.Handled = true; break;
                    case Key.P: _viewModel.OpenPreviewCommand.Execute(null); e.Handled = true; break;
                }
            }
            // F1 快捷键帮助
            else if (e.Key == Key.F1 && Keyboard.Modifiers == ModifierKeys.None)
            {
                ShowKeyboardShortcuts();
                e.Handled = true;
            }
            // 调试快捷键（无修饰键或 Shift）
            else if (e.Key == Key.F9)
            {
                _viewModel.ToggleBreakpointCommand.Execute(null);
                e.Handled = true;
            }
            else if (e.Key == Key.F12 && Keyboard.Modifiers == ModifierKeys.None)
            {
                _viewModel.GoToDefinitionCommand.Execute(null);
                e.Handled = true;
            }
            else if (e.Key == Key.F12 && Keyboard.Modifiers == ModifierKeys.Shift)
            {
                _viewModel.FindReferencesCommand.Execute(null);
                e.Handled = true;
            }
            else if (e.Key == Key.F5 && Keyboard.Modifiers == ModifierKeys.None)
            {
                _viewModel.IsDebugging = !_viewModel.IsDebugging;
                if (_viewModel.IsDebugging) _viewModel.StartDebugCommand.Execute(null);
                else _viewModel.StopDebugCommand.Execute(null);
                e.Handled = true;
            }
            else if (e.Key == Key.F5 && Keyboard.Modifiers == ModifierKeys.Shift)
            {
                _viewModel.StopDebugCommand.Execute(null);
                e.Handled = true;
            }
            else if (e.Key == Key.F10 && Keyboard.Modifiers == ModifierKeys.None)
            {
                _viewModel.StepOverCommand.Execute(null);
                e.Handled = true;
            }
            else if (e.Key == Key.F11 && Keyboard.Modifiers == ModifierKeys.None)
            {
                _viewModel.StepIntoCommand.Execute(null);
                e.Handled = true;
            }
            else if (e.Key == Key.F11 && Keyboard.Modifiers == ModifierKeys.Shift)
            {
                _viewModel.StepOutCommand.Execute(null);
                e.Handled = true;
            }
        };

        // Auto-scroll chat: 仅当新消息到达时自动滚到底部
        _viewModel.Chat.Messages.CollectionChanged += (s, e) =>
        {
            if (e.Action == System.Collections.Specialized.NotifyCollectionChangedAction.Add)
            {
                Dispatcher.BeginInvoke(new Action(() =>
                {
                    // 强制更新布局，确保 ScrollableHeight / VerticalOffset 为当前值
                    ChatScrollViewer.UpdateLayout();
                    double scrollableHeight = ChatScrollViewer.ScrollableHeight;
                    double verticalOffset = ChatScrollViewer.VerticalOffset;
                    bool isNearBottom = verticalOffset >= scrollableHeight - 50;
                    if (isNearBottom || scrollableHeight <= 0)
                        ChatScrollViewer.ScrollToEnd();
                }), System.Windows.Threading.DispatcherPriority.Background);
            }
        };
    }

    // ===== 弹窗：模型管理 =====

    private void RefreshModelList()
    {
        ModelListBox.Items.Clear();
        foreach (var provider in ModelMgr.GetProviders())
        {
            foreach (var model in provider.Models)
            {
                ModelListBox.Items.Add($"{provider.Name} / {model.Name}");
            }
        }
    }

    private void ClearModelForm()
    {
        SettingsProviderBox.SelectedIndex = -1;
        SettingsProviderBox.Text = "";
        SettingsBaseUrlBox.Text = "";
        SettingsModelIdBox.Text = "";
        SettingsModelNameBox.Text = "";
        SettingsApiKeyBox.Password = "";
        SettingsAgentCheck.IsChecked = true;
        SettingsQACheck.IsChecked = true;
        SettingsMaxTokensBox.Text = "";
        SettingsMaxTokensLabel.Text = "最大令牌数（留空使用模型默认值）";
    }

    private void ModelList_SelectionChanged(object sender, SelectionChangedEventArgs e)
    {
        if (ModelListBox.SelectedIndex < 0) return;

        var providers = ModelMgr.GetProviders().ToList();
        int idx = 0;
        ProviderDef? foundProv = null;
        ModelDef? foundModel = null;
        foreach (var p in providers)
        {
            for (int mi = 0; mi < p.Models.Count; mi++)
            {
                if (idx == ModelListBox.SelectedIndex)
                {
                    foundProv = p;
                    foundModel = p.Models[mi];
                    break;
                }
                idx++;
            }
            if (foundProv != null) break;
        }

        if (foundProv == null || foundModel == null) return;

        SettingsProviderBox.SelectedItem = foundProv;
        SettingsBaseUrlBox.Text = foundProv.BaseUrl;
        SettingsModelIdBox.Text = foundModel.Id;
        SettingsModelNameBox.Text = foundModel.Name;
        SettingsApiKeyBox.Password = foundProv.ApiKey;
        SettingsAgentCheck.IsChecked = foundModel.AgentMode;
        SettingsQACheck.IsChecked = foundModel.QAMode;

        var cfg = _viewModel.GetConfig().AI;
        SettingsMaxTokensBox.Text = cfg.MaxTokens > 0 ? cfg.MaxTokens.ToString() : ModelMgr.GetDefaultMaxTokens(foundModel.Id);
    }

    private void AddModel_Click(object sender, RoutedEventArgs e)
    {
        var provName = SettingsProviderBox.Text.Trim();
        var provId = (SettingsProviderBox.SelectedItem as ProviderDef)?.Id ?? provName.ToLowerInvariant();
        var baseUrl = SettingsBaseUrlBox.Text.Trim();
        var modelId = SettingsModelIdBox.Text.Trim();
        var modelName = SettingsModelNameBox.Text.Trim();
        var apiKey = SettingsApiKeyBox.Password;
        var agent = SettingsAgentCheck.IsChecked == true;
        var qa = SettingsQACheck.IsChecked == true;
        int.TryParse(SettingsMaxTokensBox.Text.Trim(), out var maxTokens);

        if (string.IsNullOrEmpty(modelId))
        {
            MessageBox.Show("模型 ID 不能为空", "提示", MessageBoxButton.OK, MessageBoxImage.Warning);
            return;
        }

        var provider = ModelMgr.RegisterOrUpdate(provId, provName, baseUrl, apiKey, modelId, modelName, agent, qa);

        if (maxTokens > 0)
            _viewModel.GetConfig().AI.MaxTokens = maxTokens;
        _viewModel.SaveSettings();

        ModelMgr.SetActive(provId, modelId);
        RefreshModelList();
        RefreshChatProviderBox();
        RefreshChatModelBox();
        _viewModel.RefreshAvailableModes();

        ChatModelBox.SelectedItem = ModelMgr.ActiveModel;
        _viewModel.Chat.SelectedModel = modelId;
        _viewModel.Chat.AIStatus = string.IsNullOrEmpty(apiKey) ? "AI: 未配置" : "AI: 就绪";
    }

    private void DeleteModel_Click(object sender, RoutedEventArgs e)
    {
        if (ModelListBox.SelectedIndex < 0) return;

        var providers = ModelMgr.GetProviders().ToList();
        int idx = 0;
        ProviderDef? foundProv = null;
        ModelDef? foundModel = null;
        foreach (var p in providers)
        {
            for (int mi = 0; mi < p.Models.Count; mi++)
            {
                if (idx == ModelListBox.SelectedIndex)
                {
                    foundProv = p;
                    foundModel = p.Models[mi];
                    break;
                }
                idx++;
            }
            if (foundProv != null) break;
        }

        if (foundProv == null || foundModel == null) return;

        var result = MessageBox.Show($"确定删除模型 \"{foundProv.Name} / {foundModel.Name}\"？",
            "确认删除", MessageBoxButton.YesNo, MessageBoxImage.Question);
        if (result != MessageBoxResult.Yes) return;

        ModelMgr.RemoveModel(foundProv.Id, foundModel.Id);
        RefreshModelList();
        ClearModelForm();

        if (ModelMgr.ActiveModel == null || ModelMgr.ActiveModel.Id == foundModel.Id)
        {
            var firstProv = ModelMgr.GetProviders().FirstOrDefault();
            if (firstProv != null && firstProv.Models.Count > 0)
            {
                ModelMgr.SetActive(firstProv.Id, firstProv.Models[0].Id);
            }
        }
        RefreshChatProviderBox();
        RefreshChatModelBox();
        _viewModel.RefreshAvailableModes();
        _viewModel.SaveSettings();
    }

    // ===== 聊天栏模型选择 =====

    private void ChatProviderBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
    {
        if (ChatProviderBox.SelectedItem is ProviderDef prov)
        {
            ModelMgr.SetActive(prov.Id, ModelMgr.ActiveModel?.Id ?? prov.Models[0].Id);
            RefreshChatModelBox();
            _viewModel.RefreshAvailableModes();
            CheckAndWarnModelConfig();
        }
    }

    private void ChatModelBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
    {
        if (ChatModelBox.SelectedItem is ModelDef model)
        {
            ModelMgr.SetActive(
                ModelMgr.ActiveProvider?.Id ?? "deepseek", model.Id);
            _viewModel.Chat.SelectedModel = model.Id;
            _viewModel.RefreshAvailableModes();
            CheckAndWarnModelConfig();
        }
    }

    /// <summary>模式切换（智能体/问答）时的 API Key 配置检查</summary>
    private void ChatModeBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
    {
        if (ChatModeBox.SelectedValue is string modeId)
        {
            _viewModel.Chat.ChatMode = modeId;
            _viewModel.RefreshAvailableModes();
            CheckAndWarnModelConfig();
        }
    }

    /// <summary>检查当前模型是否已配置 API Key，未配置则提示用户</summary>
    private void CheckAndWarnModelConfig()
    {
        var providerId = ModelMgr.ActiveProvider?.Id ?? "";
        var apiKey = ModelMgr.GetEffectiveApiKey(providerId);
        if (string.IsNullOrEmpty(apiKey))
        {
            var modelName = ModelMgr.ActiveModel?.Name ?? ModelMgr.ActiveModel?.Id ?? "当前模型";
            var providerName = ModelMgr.ActiveProvider?.Name ?? "当前提供商";

            // 检查是否最近已显示过同类 API Key 警告，避免重复刷屏
            var lastSysMsg = _viewModel.Chat.Messages.LastOrDefault(m => m.Role == "system");
            bool alreadyWarned = lastSysMsg != null && lastSysMsg.Content.Contains("尚未配置");

            // 两层检查：先判断是否完全未配置任何 API Key
            if (!ModelMgr.HasAnyApiKeyConfigured())
            {
                _viewModel.Chat.AIStatus = "⚠️ 未配置 API Key";
                if (!alreadyWarned)
                    _viewModel.Chat.AddMessage("system",
                        "⚠️ **尚未配置任何大模型 API Key**，无法使用。\n\n" +
                        "💡 请前往 **设置 → 管理模型** 配置 API Key 后再使用该模型。");
            }
            else
            {
                _viewModel.Chat.AIStatus = $"⚠️ {providerName}/{modelName}: 未配置 API Key";
                if (!alreadyWarned)
                    _viewModel.Chat.AddMessage("system",
                        $"⚠️ **{providerName} / {modelName}** 尚未配置 API Key，无法使用。\n\n" +
                        "💡 请前往 **设置 → 管理模型** 配置 API Key 后再使用该模型。");
            }
        }
        else
        {
            _viewModel.Chat.AIStatus = "AI: 就绪";
        }
    }

    private void RefreshChatModelBox()
    {
        ChatModelBox.Items.Clear();
        var prov = ModelMgr.ActiveProvider;
        if (prov == null) return;
        foreach (var m in prov.Models)
        {
            ChatModelBox.Items.Add(m);
        }
        ChatModelBox.SelectedItem = ModelMgr.ActiveModel;
    }

    private void RefreshChatProviderBox()
    {
        ChatProviderBox.Items.Clear();
        foreach (var p in ModelMgr.GetProviders())
            ChatProviderBox.Items.Add(p);
        ChatProviderBox.SelectedItem = ModelMgr.ActiveProvider;
    }

    // ===== 终端 / 日志 =====

    private void TerminalInput_KeyDown(object sender, KeyEventArgs e)
    {
        if (e.Key == Key.Enter)
        {
            _viewModel.TerminalInput_KeyDown(TerminalInputBox.Text);
            TerminalInputBox.Text = string.Empty;
            e.Handled = true;
        }
    }

    private void ClearLog_Click(object sender, RoutedEventArgs e)
    {
        _viewModel.Log.Clear();
    }

    private void SettingsOverlay_MouseDown(object sender, MouseButtonEventArgs e)
    {
        if (e.OriginalSource == SettingsOverlay)
            _viewModel.IsSettingsOpen = false;
    }

    private void SettingsOverlay_BlockMouseDown(object sender, MouseButtonEventArgs e)
    {
        e.Handled = true;
