    /// <summary>在外部浏览器中打开预览URL</summary>
    private void OpenPreviewInBrowser_Click(object sender, RoutedEventArgs e)
    {
        var url = _viewModel.PreviewUrl?.Trim();
        if (string.IsNullOrEmpty(url)) return;
        if (!url.StartsWith("http://") && !url.StartsWith("https://"))
            url = "http://" + url;
        try
        {
            System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
            {
                FileName = url,
                UseShellExecute = true
            });
        }
        catch (Exception ex)
        {
            System.Windows.MessageBox.Show($"无法打开浏览器: {ex.Message}", "预览",
                MessageBoxButton.OK, MessageBoxImage.Warning);
        }
    }

    /// <summary>获取光标位置的单词（用于 Ctrl+Click 跳转）</summary>
    private static string? GetWordAtOffset(ICSharpCode.AvalonEdit.Document.TextDocument doc, int offset)
    {
        if (offset < 0 || offset >= doc.TextLength) return null;
        var text = doc.Text;
        int start = offset, end = offset;
        while (start > 0 && (char.IsLetterOrDigit(text[start - 1]) || text[start - 1] == '_'))
            start--;
        while (end < text.Length && (char.IsLetterOrDigit(text[end]) || text[end] == '_'))
            end++;
        var word = text[start..end];
        return word.Length > 0 && word.Length < 80 ? word : null;
    }

