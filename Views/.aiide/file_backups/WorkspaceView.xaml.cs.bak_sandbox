    // ===== LSP 实时诊断 =====

    private async void InitializeLSP()
    {
        _lspService = new LSPService();
        _lspService.OnDiagnosticsChanged += (filePath, diags) =>
        {
            Dispatcher.Invoke(() =>
            {
                _diagnosticsMargin?.SetDiagnostics(
                    new Dictionary<string, List<Services.DiagnosticItem>>(
                        _lspService.AllDiagnostics));
                // 只刷新当前文件的诊断显示
                if (filePath == _viewModel.Editor.CurrentFile)
                    CodeEditor.TextArea.TextView.InvalidateLayer(
                        ICSharpCode.AvalonEdit.Rendering.KnownLayer.Selection);
            });
        };

        _lspService.OnGoToLocation += (filePath, line, column) =>
        {
            Dispatcher.Invoke(() =>
            {
                _viewModel.OpenFile(filePath);
                _viewModel.Editor.NavigateToLine = line;
            });
        };

        // 延迟启动LSP，等待项目路径设置
        _viewModel.FileTree.PropertyChanged += async (s, e) =>
        {
            if (e.PropertyName == nameof(FileTreeViewModel.ProjectPath) &&
                !string.IsNullOrEmpty(_viewModel.FileTree.ProjectPath))
            {
                await _lspService.StartAsync(_viewModel.FileTree.ProjectPath);
                // 如果已有打开文件，通知 LSP
                if (!string.IsNullOrEmpty(_viewModel.Editor.CurrentFile))
                    NotifyLSPDidOpen();
            }
        };
    }

    private void NotifyLSPDidOpen()
    {
        if (_lspService == null || !_lspService.IsRunning) return;
        var filePath = _viewModel.Editor.CurrentFile;
        if (string.IsNullOrEmpty(filePath)) return;
        var lang = _viewModel.Editor.FileType ?? "plaintext";
        _lspService.DidOpen(filePath, CodeEditor.Text, lang);
    }

    private void NotifyLSPDidChange()
    {
        if (_lspService == null || !_lspService.IsRunning) return;
        var filePath = _viewModel.Editor.CurrentFile;
        if (string.IsNullOrEmpty(filePath)) return;
        _lspService.DidChange(filePath, CodeEditor.Text);
    }

    // ===== 内联编辑 Ctrl+K =====

    private async void HandleInlineEdit()
    {
        var selectedText = CodeEditor.SelectedText;
        if (string.IsNullOrWhiteSpace(selectedText))
        {
            // 如果没有选中，选中当前行
            var line = CodeEditor.TextArea.Caret.Line;
            var doc = CodeEditor.Document;
            var seg = doc.GetLineByNumber(line);
            CodeEditor.Select(seg.Offset, seg.Length);
            selectedText = doc.GetText(seg);
        }

        if (string.IsNullOrWhiteSpace(selectedText)) return;

        var filePath = _viewModel.Editor.CurrentFile ?? "untitled";
        var language = GuessLanguage(filePath);
        var apiKey = ModelMgr.GetEffectiveApiKey(ModelMgr.ActiveProvider?.Id ?? "");
        if (string.IsNullOrEmpty(apiKey)) return;

        var provider = ModelMgr.ActiveProvider;
        var baseUrl = provider?.BaseUrl ?? "https://api.deepseek.com/v1";
        var model = ModelMgr.ActiveModel?.Id ?? "deepseek-v4-pro";

        var popup = new InlineEditPopup(selectedText, filePath, language, apiKey, baseUrl, model)
        {
            Owner = Window.GetWindow(this)
        };

        if (popup.ShowDialog() == true && !string.IsNullOrEmpty(popup.ResultCode))
        {
            // 替换选中文本
            var start = CodeEditor.SelectionStart;
            var length = CodeEditor.SelectionLength;
            CodeEditor.Document.Replace(start, length, popup.ResultCode);
            CodeEditor.Select(start, popup.ResultCode.Length);
        }
    }

    private static string GuessLanguage(string filePath)
    {
        var ext = System.IO.Path.GetExtension(filePath).ToLowerInvariant();
        return ext switch
        {
            ".cs" => "C#",
            ".js" => "JavaScript",
            ".ts" or ".tsx" => "TypeScript",
            ".py" => "Python",
            ".java" => "Java",
            ".go" => "Go",
            ".rs" => "Rust",
            ".cpp" or ".cc" or ".cxx" or ".h" or ".hpp" => "C++",
            ".c" => "C",
            ".html" or ".htm" => "HTML",
            ".css" => "CSS",
            ".json" => "JSON",
            ".xml" => "XML",
            ".yaml" or ".yml" => "YAML",
            ".sql" => "SQL",
            _ => "plaintext"
        };
    }

