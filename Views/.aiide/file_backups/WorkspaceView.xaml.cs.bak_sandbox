    // ===== 文件树双击打开文件 =====

    private void FileTree_MouseDoubleClick(object sender, MouseButtonEventArgs e)
    {
        // 从事件源查找 TreeViewItem
        var source = e.OriginalSource as DependencyObject;
        while (source != null && source is not TreeViewItem)
            source = System.Windows.Media.VisualTreeHelper.GetParent(source);

        if (source is TreeViewItem { DataContext: FileItem item } && !item.IsDirectory)
        {
            _viewModel.OpenFile(item.FullPath);
            e.Handled = true;
        }
    }

    // ===== 文件树单击展开文件夹 / 打开文件 =====
    private void FileTree_PreviewMouseLeftButtonDown(object sender, MouseButtonEventArgs e)
    {
        // 只处理对 TreeViewItem 的单击（非展开箭头区域）
        var source = e.OriginalSource as DependencyObject;
        TreeViewItem? clickedTvi = null;
        while (source != null)
        {
            if (source is TreeViewItem tvi)
            {
                clickedTvi = tvi;
                break;
            }
            source = VisualTreeHelper.GetParent(source);
        }

        if (clickedTvi?.DataContext is not FileItem item) return;

        if (item.IsDirectory)
        {
            // 单击文件夹：切换展开/折叠
            clickedTvi.IsExpanded = !clickedTvi.IsExpanded;
            e.Handled = true;
        }
        else
        {
            // 单击文件：在编辑器中打开（新标签页）
            _viewModel.OpenFile(item.FullPath);
            e.Handled = true;
        }
    }

    // ===== 文件标签页点击切换 =====

    private void EditorTab_Click(object sender, MouseButtonEventArgs e)
    {
        // 如果点击的是关闭按钮，不切换标签页
        if (e.OriginalSource is Button)
            return;
        if (sender is FrameworkElement fe && fe.DataContext is EditorTab tab)
        {
            // 更新 IsActive 标记
            foreach (var t in _viewModel.Editor.Tabs)
                t.IsActive = false;
            tab.IsActive = true;
            _viewModel.OpenFile(tab.FilePath);
        }
    }

    private void EditorTabClose_Click(object sender, RoutedEventArgs e)
    {
        // 使用 Button.Click，直接获取 DataContext
        if (sender is Button btn && btn.DataContext is EditorTab tab)
        {
            var tabs = _viewModel.Editor.Tabs;
            var idx = tabs.IndexOf(tab);
            tabs.Remove(tab);

            // 如果关闭的是当前激活标签，自动切换到相邻标签
            if (_viewModel.Editor.CurrentFile == tab.FilePath)
            {
                if (tabs.Count > 0)
                {
                    var nextIdx = Math.Min(idx, tabs.Count - 1);
                    var nextTab = tabs[nextIdx];
                    nextTab.IsActive = true;
                    _viewModel.OpenFile(nextTab.FilePath);
                }
                else
                {
                    // 所有标签已关闭，清除编辑器状态
                    _viewModel.CloseFile();
                }
            }
            e.Handled = true;
        }
    }

    private void TabScrollLeft_Click(object sender, RoutedEventArgs e)
    {
        var offset = TabScrollViewer.HorizontalOffset;
        TabScrollViewer.ScrollToHorizontalOffset(Math.Max(0, offset - 200));
    }

    private void TabScrollRight_Click(object sender, RoutedEventArgs e)
    {
        var offset = TabScrollViewer.HorizontalOffset;
        var maxOffset = TabScrollViewer.ScrollableWidth;
        TabScrollViewer.ScrollToHorizontalOffset(Math.Min(maxOffset, offset + 200));
    }

