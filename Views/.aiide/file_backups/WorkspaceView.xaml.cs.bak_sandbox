    /// <summary>点击变更文件旁的"恢复"按钮，恢复到 checkpoint 快照</summary>
    private void FileChangeRestore_Click(object sender, RoutedEventArgs e)
    {
        if (sender is FrameworkElement fe && fe.Tag is FileChangeItem item && !string.IsNullOrEmpty(item.CheckpointId))
        {
            var result = MessageBox.Show(
                $"确认将「{item.FileName}」恢复到修改前状态？\n\n此操作不可撤销，当前修改将被丢弃。",
                "恢复文件确认",
                MessageBoxButton.YesNo,
                MessageBoxImage.Warning);

            if (result == MessageBoxResult.Yes)
            {
                try
                {
                    if (_viewModel.TryRestoreFromCheckpoint(item.CheckpointId))
                    {
                        _viewModel.Chat.FileChanges.Remove(item);
                        _viewModel.Chat.AddMessage("system", $"↩ 已恢复「{item.FileName}」到 checkpoint 快照状态。");
                    }
                    else
                    {
                        _viewModel.Chat.AddMessage("system", $"⚠️ 恢复「{item.FileName}」失败，请手动检查文件状态。");
                    }
                }
                catch (Exception ex)
                {
                    _viewModel.Chat.AddMessage("system", $"❌ 恢复「{item.FileName}」时出错: {ex.Message}");
                }
            }
        }
    }

