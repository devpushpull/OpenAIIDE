<Window x:Class="AIIDEWPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AIIDEWPF.ViewModels"
        xmlns:conv="clr-namespace:AIIDEWPF.Converters"
        Title="设置" Height="550" Width="800"
        MinHeight="450" MinWidth="700"
        Background="#1e1e1e" Foreground="#d4d4d4"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow" ResizeMode="CanResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:IsNotNullConverter x:Key="IsNotNull"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航栏 -->
            <Border Grid.Column="0" Background="#252525" BorderBrush="#3a3a3a" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="设置" FontSize="16" FontWeight="Bold"
                               Foreground="#e0e0e0" Margin="16,16,16,12"/>

                    <ListBox Grid.Row="1" x:Name="NavListBox" ItemsSource="{Binding NavItems}"
                             Background="Transparent" BorderThickness="0"
                             SelectedIndex="0" Margin="4,0,4,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" FontSize="13"
                                           Foreground="#aaa" Padding="12,8"
                                           Margin="0,1"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#007acc"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#3a3a3a"/>
                                                    <Setter TargetName="Border" Property="Cursor" Value="Hand"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧内容区 -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0">
                <Grid Margin="28,20">

                    <!-- ====== 通用 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageGeneral">
                        <StackPanel>
                            <TextBlock Text="通用" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,20"/>
                            <TextBlock Text="AI 响应语言" Foreground="#aaa" FontSize="12" Margin="0,8,0,4"/>
                            <ComboBox Text="{Binding ResponseLanguage, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True" Background="#333" Foreground="#d4d4d4"
                                      BorderThickness="1" BorderBrush="#555" FontSize="13"
                                      Height="30" VerticalContentAlignment="Center" Width="200"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem>中文</ComboBoxItem>
                                <ComboBoxItem>English</ComboBoxItem>
                            </ComboBox>
                            <CheckBox Content="自动检查更新" IsChecked="{Binding AutoCheckUpdates}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,16,0,0"/>
                            <!-- 自动联网搜索开关 -->
                            <CheckBox IsChecked="{Binding AutoWebSearch}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,12,0,0">
                                <TextBlock>
                                    <Run Text="自动联网搜索" FontWeight="SemiBold"/>
                                    <Run Text="（" Foreground="#888"/>
                                    <Run Text="开启后 AI 可直接发起联网搜索；关闭时每次搜索需手动确认" Foreground="#888"/>
                                    <Run Text="）" Foreground="#888"/>
                                </TextBlock>
                            </CheckBox>
                            <TextBlock Text="本地数据存储路径" Foreground="#aaa" FontSize="12" Margin="0,16,0,4"/>
                            <TextBlock Text="%LOCALAPPDATA%\AIIDE\" Foreground="#888" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== AI / 模型 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageAI">
                        <StackPanel>
                            <TextBlock Text="AI / 模型" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,20"/>

                            <TextBlock Text="默认 API 密钥" Foreground="#aaa" FontSize="12" Margin="0,8,0,4"/>
                            <PasswordBox x:Name="DefaultApiKeyBox"
                                         Background="#333" Foreground="#d4d4d4" FontSize="13"
                                         BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                         Height="30" Width="340" HorizontalAlignment="Left"
                                         PasswordChanged="DefaultApiKeyBox_PasswordChanged"/>

                            <TextBlock Text="默认模型 ID" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding DefaultModel, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="340" HorizontalAlignment="Left"/>

                            <TextBlock Text="最大令牌数（0=使用模型默认值）" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="100" HorizontalAlignment="Left"/>

                            <CheckBox Content="流式输出 (Stream)" IsChecked="{Binding StreamMode}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,16,0,16"/>

                            <!-- 模型配额 + 自定义模型管理 -->
                            <Border Background="#2a2a2a" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,4,0,0">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="模型管理" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0"/>
                                            <TextBlock Text="{Binding ModelQuotaDisplay}" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding QuotaWarning}" FontSize="11" Foreground="#e8a800" Margin="0,2,0,0"
                                                       Visibility="{Binding CanAddMoreModels, Converter={StaticResource InverseBoolToVisibility}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                                    Visibility="{Binding IsNotEditingModel, Converter={StaticResource BoolToVisibility}}">
                                            <Button Content="+ 自定义模型" Width="110" Background="#007acc" Foreground="White"
                                                    BorderThickness="0" Padding="6,4" FontSize="12"
                                                    Command="{Binding AddCustomModelCommand}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 模型列表 -->
                                    <ListBox ItemsSource="{Binding Models}"
                                             SelectedItem="{Binding SelectedProvider}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="12"
                                             BorderThickness="1" BorderBrush="#555"
                                             Height="140" Margin="0,8,0,0"
                                             Visibility="{Binding IsNotEditingModel, Converter={StaticResource BoolToVisibility}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontSize="10" Width="18" TextAlignment="Center"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0">
                                                            <Run Text="{Binding IsCustom, Mode=OneWay}" Foreground="#569cd6"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                                                        <TextBlock Text=" (内置)" FontSize="10" Foreground="#666" Margin="4,0,0,0"
                                                                   Visibility="{Binding IsCustom, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                        <TextBlock Text=" (自定义)" FontSize="10" Foreground="#d4a843" Margin="4,0,0,0"
                                                                   Visibility="{Binding IsCustom, Converter={StaticResource BoolToVisibility}}"/>
                                                    </StackPanel>
                                                    <TextBlock FontSize="11" Foreground="#888" Margin="24,1,0,0">
                                                        <Run Text="ID: "/><Run Text="{Binding Id}"/>
                                                        <Run Text=" | "/><Run Text="模型数: "/><Run Text="{Binding Models.Count, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- 自定义模型编辑表单 -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280"
                                                  Visibility="{Binding IsEditingModel, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="提供商信息" FontSize="13" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,8"/>

                                            <TextBlock Text="提供商 ID（唯一标识，如 my-company）" Foreground="#aaa" FontSize="11" Margin="0,4,0,2"/>
                                            <TextBox Text="{Binding EditProviderId, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,4" Height="28"/>

                                            <TextBlock Text="提供商名称（显示名，如 我的公司）" Foreground="#aaa" FontSize="11" Margin="0,6,0,2"/>
                                            <TextBox Text="{Binding EditProviderName, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,4" Height="28"/>

                                            <TextBlock Text="API 基础 URL（OpenAI 兼容格式）" Foreground="#aaa" FontSize="11" Margin="0,6,0,2"/>
                                            <TextBox Text="{Binding EditBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,4" Height="28"
                                                     ToolTip="例如: https://api.example.com/v1"/>

                                            <TextBlock Text="API 密钥（留空使用默认密钥）" Foreground="#aaa" FontSize="11" Margin="0,6,0,2"/>
                                            <PasswordBox x:Name="EditProviderApiKeyBox"
                                                         Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                         BorderThickness="0" Padding="8,4" Height="28"
                                                         PasswordChanged="EditProviderApiKeyBox_PasswordChanged"/>

                                            <TextBlock Text="模型信息" FontSize="13" FontWeight="Bold" Foreground="#569cd6" Margin="0,12,0,8"/>

                                            <TextBlock Text="模型 ID（API 调用使用的标识）" Foreground="#aaa" FontSize="11" Margin="0,4,0,2"/>
                                            <TextBox Text="{Binding EditModelId, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,4" Height="28"/>

                                            <TextBlock Text="模型名称（显示名）" Foreground="#aaa" FontSize="11" Margin="0,6,0,2"/>
                                            <TextBox Text="{Binding EditModelName, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,4" Height="28"/>

                                            <TextBlock Text="最大令牌数（0=使用模型默认值）" Foreground="#aaa" FontSize="11" Margin="0,6,0,2"/>
                                            <TextBox Text="{Binding EditModelMaxTokens, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,4" Height="28" Width="120" HorizontalAlignment="Left"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <CheckBox Content="智能体模式" IsChecked="{Binding EditAgentMode}"
                                                          Foreground="#d4d4d4" FontSize="12" Margin="0,0,16,0"/>
                                                <CheckBox Content="问答模式" IsChecked="{Binding EditQAMode}"
                                                          Foreground="#d4d4d4" FontSize="12"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                <Button Content="💾 保存" Width="70" Background="#007acc" Foreground="White"
                                                        BorderThickness="0" Padding="6,4" FontSize="12"
                                                        Command="{Binding SaveCustomModelCommand}"/>
                                                <Button Content="取消" Width="70" Background="#555" Foreground="#d4d4d4"
                                                        BorderThickness="0" Padding="6,4" FontSize="12" Margin="8,0,0,0"
                                                        Command="{Binding CancelCustomModelCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- 底部操作栏（编辑/删除） -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0"
                                                Visibility="{Binding IsNotEditingModel, Converter={StaticResource BoolToVisibility}}">
                                        <Button Content="✏️ 编辑" Width="64" Background="#555" Foreground="#d4d4d4"
                                                BorderThickness="0" Padding="4,4" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding EditCustomModelCommand}"
                                                IsEnabled="{Binding SelectedProvider.IsCustom, Mode=OneWay}"/>
                                        <Button Content="🗑️ 删除" Width="64" Background="#8b0000" Foreground="#f0a0a0"
                                                BorderThickness="0" Padding="4,4" FontSize="11"
                                                Command="{Binding DeleteCustomModelCommand}"
                                                IsEnabled="{Binding SelectedProvider.IsCustom, Mode=OneWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 编辑器 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageEditor">
                        <StackPanel>
                            <TextBlock Text="编辑器" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,20"/>

                            <TextBlock Text="字体大小" Foreground="#aaa" FontSize="12" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="80" HorizontalAlignment="Left"/>

                            <TextBlock Text="制表符大小" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding TabSize, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="80" HorizontalAlignment="Left"/>

                            <CheckBox Content="自动换行" IsChecked="{Binding WordWrap}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,16,0,0"/>
                            <CheckBox Content="显示迷你地图" IsChecked="{Binding ShowMinimap}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,8,0,0"/>

                            <!-- AI 代码补全 -->
                            <TextBlock Text="AI 代码补全" FontSize="15" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,20,0,12"/>
                            <CheckBox Content="启用 AI 行间补全（输入停止后自动提示，Tab 采纳 / Esc 取消）"
                                      IsChecked="{Binding CompletionEnabled}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,0,0,8"/>
                            <TextBlock Text="补全延迟 (ms)" Foreground="#aaa" FontSize="12" Margin="0,6,0,4"/>
                            <TextBox Text="{Binding CompletionDebounce, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="80" HorizontalAlignment="Left"/>
                            <TextBlock Text="最大行数（1~10）" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding CompletionMaxLines, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 外观 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageAppearance">
                        <StackPanel>
                            <TextBlock Text="外观" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,20"/>
                            <TextBlock Text="主题" Foreground="#aaa" FontSize="12" Margin="0,8,0,4"/>
                            <ComboBox ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding Theme}"
                                      Background="#333" Foreground="#d4d4d4" FontSize="13"
                                      BorderThickness="1" BorderBrush="#555"
                                      Height="30" Width="160" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 终端 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageTerminal">
                        <StackPanel>
                            <TextBlock Text="终端" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,20"/>

                            <TextBlock Text="字体" Foreground="#aaa" FontSize="12" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding TerminalFontFamily, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13" FontFamily="Consolas"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="200" HorizontalAlignment="Left"/>

                            <TextBlock Text="字体大小" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding TerminalFontSize, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="80" HorizontalAlignment="Left"/>

                            <TextBlock Text="光标样式" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <ComboBox ItemsSource="{Binding CursorStyleOptions}"
                                      SelectedItem="{Binding TerminalCursorStyle}"
                                      Background="#333" Foreground="#d4d4d4" FontSize="13"
                                      BorderThickness="1" BorderBrush="#555"
                                      Height="30" Width="140" HorizontalAlignment="Left"/>

                            <TextBlock Text="Shell 路径" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="340"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding TerminalShellPath, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#333" Foreground="#d4d4d4" FontSize="13" FontFamily="Consolas"
                                         BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                         Height="30"/>
                            </Grid>

                            <TextBlock Text="回滚行数" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding TerminalScrollbackLines, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="13"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="30" Width="100" HorizontalAlignment="Left"/>

                            <CheckBox Content="启用 ANSI 颜色" IsChecked="{Binding TerminalEnableColors}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,16,0,0"/>
                            <CheckBox Content="启用语法高亮（Shell 输出）" IsChecked="{Binding TerminalSyntaxHighlight}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,8,0,0"/>

                            <TextBlock Text="💡 Shell 路径支持: powershell.exe / cmd.exe / wsl.exe / bash" FontSize="11"
                                       Foreground="#666" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 文件排除 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageFileExclude">
                        <StackPanel>
                            <TextBlock Text="文件排除" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,8"/>
                            <TextBlock Text="控制文件树和搜索中排除的文件/目录模式（每行一个 glob 模式）" FontSize="12" Foreground="#888" Margin="0,0,0,16"/>

                            <TextBlock Text="文件树排除模式" Foreground="#aaa" FontSize="12" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding FileExcludePatterns, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="12" FontFamily="Consolas"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="120" Width="380" HorizontalAlignment="Left"
                                     TextWrapping="NoWrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>

                            <TextBlock Text="搜索排除模式" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding SearchExcludePatterns, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#333" Foreground="#d4d4d4" FontSize="12" FontFamily="Consolas"
                                     BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                     Height="100" Width="380" HorizontalAlignment="Left"
                                     TextWrapping="NoWrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>

                            <CheckBox Content="遵循 .gitignore 规则" IsChecked="{Binding UseGitIgnore}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,16,0,0"/>
                            <CheckBox Content="隐藏以 . 开头的文件" IsChecked="{Binding HideDotFiles}"
                                      Foreground="#d4d4d4" FontSize="13" Margin="0,8,0,0"/>

                            <TextBlock Text="💡 glob 模式示例: **/node_modules, **/*.min.js, **/obj, *.log" FontSize="11"
                                       Foreground="#666" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 记忆库 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageMemory">
                        <Grid x:Name="MemoryContent" DataContext="{Binding MemoryVM}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="记忆库" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0"
                                           VerticalAlignment="Center"/>
                                <Button Content="+ 新建" Width="70" Background="#007acc" Foreground="White"
                                        BorderThickness="0" Padding="6,4" FontSize="12" Margin="16,0,0,0"
                                        Command="{Binding AddCommand}"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- 搜索栏 + 作用域筛选 -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="#333" Foreground="#d4d4d4" FontSize="12"
                                         BorderThickness="1" BorderBrush="#555" Padding="8,4"
                                         Width="200" VerticalContentAlignment="Center"/>
                                <Button Content="搜索" Background="#555" Foreground="#d4d4d4"
                                        BorderThickness="0" Padding="8,4" FontSize="12" Margin="4,0,0,0"
                                        Command="{Binding SearchCommand}"/>
                            </StackPanel>

                            <!-- 作用域筛选按钮组 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="作用域:" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button x:Name="ScopeFilterAllBtn" Content="全部" Width="50" FontSize="11" Padding="4,2" Margin="0,0,4,0"
                                        Background="#007acc" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        Click="ScopeFilterAll_Click"/>
                                <Button x:Name="ScopeFilterGlobalBtn" Content="全局" Width="50" FontSize="11" Padding="4,2" Margin="0,0,4,0"
                                        Background="#555" Foreground="#d4d4d4" BorderThickness="0" Cursor="Hand"
                                        Click="ScopeFilterGlobal_Click"/>
                                <Button x:Name="ScopeFilterProjectBtn" Content="项目" Width="50" FontSize="11" Padding="4,2" Margin="0,0,4,0"
                                        Background="#555" Foreground="#d4d4d4" BorderThickness="0" Cursor="Hand"
                                        Click="ScopeFilterProject_Click"/>
                            </StackPanel>

                            <!-- 记忆列表 -->
                            <ListBox Grid.Row="3" ItemsSource="{Binding Memories}"
                                     SelectedItem="{Binding SelectedMemory}" Background="#333"
                                     Foreground="#d4d4d4" FontSize="12" BorderThickness="1" BorderBrush="#555"
                                     Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Foreground="#569cd6">
                                                    <Run Text="["/><Run Text="{Binding Scope}"/><Run Text="]"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}" FontSize="11" Foreground="#aaa"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- 编辑表单 -->
                            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Margin="0,4,0,0">
                                    <TextBlock Text="标题" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                                    <TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,4"/>

                                    <TextBlock Text="内容" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,4"
                                             Height="100" TextWrapping="Wrap" AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>

                                    <TextBlock Text="类别" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <ComboBox ItemsSource="{x:Static vm:MemoryViewModel.Categories}"
                                              SelectedItem="{Binding EditCategory}"
                                              Background="#333" Foreground="#d4d4d4" FontSize="12"
                                              BorderThickness="1" BorderBrush="#555"/>

                                    <TextBlock Text="作用域" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <ComboBox ItemsSource="{x:Static vm:MemoryViewModel.Scopes}"
                                              SelectedItem="{Binding EditScope}"
                                              Background="#333" Foreground="#d4d4d4" FontSize="12"
                                              BorderThickness="1" BorderBrush="#555"/>

                                    <TextBlock Text="关键词（逗号分隔）" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <TextBox Text="{Binding EditKeywords, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,4"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="保存" Width="70" Background="#007acc" Foreground="White"
                                                BorderThickness="0" Padding="6,4" FontSize="12"
                                                Command="{Binding SaveCommand}"/>
                                        <Button Content="取消" Width="70" Background="#555" Foreground="#d4d4d4"
                                                BorderThickness="0" Padding="6,4" FontSize="12" Margin="8,0,0,0"
                                                Command="{Binding CancelEditCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- 底部操作栏 -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="编辑" Width="60" Background="#555" Foreground="#d4d4d4"
                                        BorderThickness="0" Padding="4,4" FontSize="11" Margin="0,0,4,0"
                                        Command="{Binding EditCommand}"/>
                                <Button Content="删除" Width="60" Background="#8b0000" Foreground="#f0a0a0"
                                        BorderThickness="0" Padding="4,4" FontSize="11"
                                        Command="{Binding DeleteCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- ====== 规则 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageRules">
                        <Grid x:Name="RulesContent" DataContext="{Binding RulesVM}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="规则" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0"
                                           VerticalAlignment="Center"/>
                                <Button Content="+ 新建" Width="70" Background="#007acc" Foreground="White"
                                        BorderThickness="0" Padding="6,4" FontSize="12" Margin="16,0,0,0"
                                        Command="{Binding AddCommand}"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- 规则列表 -->
                            <ListBox Grid.Row="1" ItemsSource="{Binding Rules}"
                                     SelectedItem="{Binding SelectedRule}" Background="#333"
                                     Foreground="#d4d4d4" FontSize="12" BorderThickness="1" BorderBrush="#555"
                                     Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                                                <TextBlock Text="{Binding RuleType}" FontSize="10" Foreground="#569cd6"
                                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}" FontSize="11" Foreground="#aaa"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- 规则编辑表单 -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Margin="0,4,0,0">
                                    <TextBlock Text="规则名称" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,4"/>

                                    <TextBlock Text="规则内容" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,4"
                                             Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                                    <TextBlock Text="生效方式" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <ComboBox ItemsSource="{x:Static vm:RulesViewModel.RuleTypes}"
                                              SelectedItem="{Binding EditRuleType}"
                                              Background="#333" Foreground="#d4d4d4" FontSize="12"
                                              BorderThickness="1" BorderBrush="#555"/>

                                    <TextBlock Text="文件匹配模式（glob 类型时使用）" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <TextBox Text="{Binding EditGlob, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,4"/>

                                    <TextBlock Text="场景描述（model_decision 类型时使用）" Foreground="#aaa" FontSize="12" Margin="0,8,0,2"/>
                                    <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,4"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="保存" Width="70" Background="#007acc" Foreground="White"
                                                BorderThickness="0" Padding="6,4" FontSize="12"
                                                Command="{Binding SaveCommand}"/>
                                        <Button Content="取消" Width="70" Background="#555" Foreground="#d4d4d4"
                                                BorderThickness="0" Padding="6,4" FontSize="12" Margin="8,0,0,0"
                                                Command="{Binding CancelEditCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- 底部操作栏 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="删除" Width="60" Background="#8b0000" Foreground="#f0a0a0"
                                        BorderThickness="0" Padding="4,4" FontSize="11"
                                        Command="{Binding DeleteCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- ====== 命令 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageCommands">
                        <Grid x:Name="CommandsContent" DataContext="{Binding CommandsVM}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="命令" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0"
                                           VerticalAlignment="Center"/>
                                <Button Content="+ 新建" Width="70" Background="#007acc" Foreground="White"
                                        BorderThickness="0" Padding="6,4" FontSize="12" Margin="16,0,0,0"
                                        Command="{Binding AddCommand}"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <!-- 工具栏：恢复默认 -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="🔄 恢复默认" Background="#5a3a3a" Foreground="#d0a0a0"
                                        BorderThickness="0" Padding="8,4" FontSize="11"
                                        Command="{Binding ResetCommand}"/>
                                <TextBlock Text="配置保存在 .codeartsdoer/slash_commands.json"
                                           Foreground="#666" FontSize="10" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 命令列表 -->
                            <ListView Grid.Row="2" ItemsSource="{Binding Commands}"
                                      SelectedItem="{Binding SelectedCommand}"
                                      Background="#333" Foreground="#d4d4d4" FontSize="12"
                                      BorderThickness="1" BorderBrush="#555"
                                      Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="" Width="30">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Icon}" FontSize="14" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="命令" Width="120" DisplayMemberBinding="{Binding Command}"/>
                                        <GridViewColumn Header="标签" Width="80" DisplayMemberBinding="{Binding Label}"/>
                                        <GridViewColumn Header="描述" Width="160" DisplayMemberBinding="{Binding Description}"/>
                                        <GridViewColumn Header="分类" Width="60" DisplayMemberBinding="{Binding Category}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <!-- 编辑表单 -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Margin="0,4,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="命令" Foreground="#aaa" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding EditCommand, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="6,4" Height="28"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,0">
                                            <TextBlock Text="标签" Foreground="#aaa" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding EditLabel, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="6,4" Height="28"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,6,8,0">
                                            <TextBlock Text="图标" Foreground="#aaa" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding EditIcon, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="6,4" Height="28"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,6,0,0">
                                            <TextBlock Text="分类" Foreground="#aaa" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding EditCategory, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="6,4" Height="28"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                            <TextBlock Text="描述" Foreground="#aaa" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="12"
                                                     BorderThickness="0" Padding="6,4" Height="48"
                                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="💾 保存" Width="70" Background="#007acc" Foreground="White"
                                                BorderThickness="0" Padding="6,4" FontSize="12"
                                                Command="{Binding SaveCommand}"/>
                                        <Button Content="取消" Width="70" Background="#555" Foreground="#d4d4d4"
                                                BorderThickness="0" Padding="6,4" FontSize="12" Margin="8,0,0,0"
                                                Command="{Binding CancelEditCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- 底部操作栏 -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                                        Margin="0,8,0,0"
                                        Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="✏️ 编辑" Width="60" Background="#555" Foreground="#d4d4d4"
                                        BorderThickness="0" Padding="4,4" FontSize="11" Margin="0,0,4,0"
                                        Command="{Binding EditCmdCommand}"/>
                                <Button Content="🗑️ 删除" Width="60" Background="#8b0000" Foreground="#f0a0a0"
                                        BorderThickness="0" Padding="4,4" FontSize="11"
                                        Command="{Binding DeleteCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- ====== 快捷键 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageKeymap">
                        <StackPanel>
                            <TextBlock Text="快捷键" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,16"/>
                            <ItemsControl ItemsSource="{x:Static vm:SettingsViewModel.KeymapEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Shortcut}" FontSize="13"
                                                       Foreground="#569cd6" FontFamily="Consolas"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Action}"
                                                       FontSize="13" Foreground="#aaa"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 隐私 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PagePrivacy">
                        <StackPanel>
                            <TextBlock Text="隐私" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,8"/>
                            <TextBlock Text="管理数据收集和隐私相关设置" FontSize="12" Foreground="#888" Margin="0,0,0,20"/>

                            <Border Background="#2a2a2a" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="数据收集" FontSize="14" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,10"/>
                                    <CheckBox IsChecked="{Binding EnableTelemetry}" Foreground="#d4d4d4" FontSize="13" Margin="0,4,0,0">
                                        <TextBlock>
                                            <Run Text="启用遥测数据收集" FontWeight="SemiBold"/>
                                            <Run Text="（" Foreground="#888"/><Run Text="匿名错误报告和性能数据" Foreground="#888"/><Run Text="）" Foreground="#888"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <CheckBox IsChecked="{Binding EnableCrashReports}" Foreground="#d4d4d4" FontSize="13" Margin="0,8,0,0">
                                        <TextBlock>
                                            <Run Text="启用崩溃报告" FontWeight="SemiBold"/>
                                            <Run Text="（" Foreground="#888"/><Run Text="自动发送崩溃日志帮助改进稳定性" Foreground="#888"/><Run Text="）" Foreground="#888"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <CheckBox IsChecked="{Binding EnableUsageAnalytics}" Foreground="#d4d4d4" FontSize="13" Margin="0,8,0,0">
                                        <TextBlock>
                                            <Run Text="启用使用情况分析" FontWeight="SemiBold"/>
                                            <Run Text="（" Foreground="#888"/><Run Text="匿名功能使用统计数据" Foreground="#888"/><Run Text="）" Foreground="#888"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <CheckBox IsChecked="{Binding ShareCodeSnippets}" Foreground="#d4d4d4" FontSize="13" Margin="0,8,0,0">
                                        <TextBlock>
                                            <Run Text="分享代码片段用于模型改进" FontWeight="SemiBold"/>
                                            <Run Text="（" Foreground="#888"/><Run Text="代码将被匿名化处理" Foreground="#888"/><Run Text="）" Foreground="#888"/>
                                        </TextBlock>
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <Border Background="#2a2a2a" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="数据保留" FontSize="14" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,10"/>
                                    <CheckBox IsChecked="{Binding AutoClearHistoryOnExit}" Foreground="#d4d4d4" FontSize="13" Margin="0,4,0,0">
                                        <TextBlock>
                                            <Run Text="退出时自动清除对话历史" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <TextBlock Text="对话历史保留天数" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
                                    <TextBox Text="{Binding HistoryRetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#333" Foreground="#d4d4d4" FontSize="13"
                                             BorderThickness="1" BorderBrush="#555" Padding="8,6"
                                             Height="30" Width="80" HorizontalAlignment="Left"
                                             IsEnabled="{Binding AutoClearHistoryOnExit, Converter={StaticResource InverseBool}}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="⚠️ 本应用不向远程服务器发送代码数据，所有 AI 请求仅发送至您配置的 API 端点。" 
                                       FontSize="11" Foreground="#666" Margin="0,14,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 网络代理 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageProxy">
                        <StackPanel>
                            <TextBlock Text="网络代理" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,8"/>
                            <TextBlock Text="配置 HTTP/HTTPS 代理以连接外部 API 服务" FontSize="12" Foreground="#888" Margin="0,0,0,20"/>

                            <CheckBox IsChecked="{Binding EnableProxy}" Foreground="#d4d4d4" FontSize="13" Margin="0,0,0,16">
                                <TextBlock>
                                    <Run Text="启用代理" FontWeight="SemiBold"/>
                                    <Run Text="（" Foreground="#888"/><Run Text="通过代理服务器连接外部 API" Foreground="#888"/><Run Text="）" Foreground="#888"/>
                                </TextBlock>
                            </CheckBox>

                            <Border Background="#2a2a2a" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,16"
                                    IsEnabled="{Binding IsProxyEnabled}">
                                <StackPanel>
                                    <TextBlock Text="代理服务器" FontSize="14" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,10"/>

                                    <TextBlock Text="代理类型" Foreground="#aaa" FontSize="12" Margin="0,6,0,4"/>
                                    <ComboBox ItemsSource="{Binding ProxyTypeOptions}"
                                              SelectedItem="{Binding ProxyType}"
                                              Background="#333" Foreground="#d4d4d4" FontSize="13"
                                              BorderThickness="1" BorderBrush="#555"
                                              Height="30" Width="140" HorizontalAlignment="Left"/>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="主机地址" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13" FontFamily="Consolas"
                                                     BorderThickness="0" Padding="8,6" Height="30"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="端口" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,6" Height="30" Width="100" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#2a2a2a" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="14"
                                    IsEnabled="{Binding IsProxyEnabled}">
                                <StackPanel>
                                    <TextBlock Text="认证（可选）" FontSize="14" FontWeight="Bold" Foreground="#569cd6" Margin="0,0,0,10"/>

                                    <CheckBox IsChecked="{Binding ProxyUseAuth}" Foreground="#d4d4d4" FontSize="13" Margin="0,0,0,10">
                                        <TextBlock>
                                            <Run Text="启用代理认证" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </CheckBox>

                                    <Grid IsEnabled="{Binding IsProxyAuthEnabled}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="用户名" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding ProxyUsername, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                     BorderThickness="0" Padding="8,6" Height="30"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="密码" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
                                            <PasswordBox x:Name="ProxyPasswordBox"
                                                         Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                                         BorderThickness="0" Padding="8,6" Height="30"
                                                         PasswordChanged="ProxyPasswordBox_PasswordChanged"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="💡 代理设置将影响 AI API 请求和联网搜索的网络连接" FontSize="11"
                                       Foreground="#666" Margin="0,14,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 网络诊断 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageNetwork">
                        <StackPanel>
                            <TextBlock Text="网络诊断" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,6"/>
                            <TextBlock Text="测试 AI IDE 所需网络服务的连通性" FontSize="12" Foreground="#888" Margin="0,0,0,16"/>

                            <!-- 诊断按钮 + 摘要 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="{Binding DiagButtonText}" Width="100" Height="30"
                                        Background="#007acc" Foreground="White" BorderThickness="0" FontSize="13"
                                        Command="{Binding RunNetworkDiagCommand}"
                                        IsEnabled="{Binding IsDiagRunning, Converter={StaticResource InverseBool}}"/>
                                <TextBlock Text="{Binding DiagSummary}" FontSize="13" Foreground="#d4d4d4"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>

                            <!-- 诊断结果列表 -->
                            <ItemsControl ItemsSource="{Binding DiagResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#2a2a2a" CornerRadius="4" Padding="10,6" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="200"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StatusIcon}" FontSize="14"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                           Foreground="#d4d4d4" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding LatencyDisplay}" FontSize="12"
                                                           Foreground="#888" VerticalAlignment="Center" Margin="0,0,10,0"
                                                           FontFamily="Consolas,monospace" Width="55" TextAlignment="Right"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Detail}" FontSize="11"
                                                           Foreground="#666" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 提示 -->
                            <TextBlock Text="💡 若 AI 服务端点不通，请检查网络代理/防火墙设置" FontSize="11"
                                       Foreground="#666" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== MCP 服务 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageMCP">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 标题栏 -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔗 MCP 服务管理" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0"
                                           VerticalAlignment="Center"/>
                                <Button Content="+ 手动添加" Width="90" Height="28" Background="#007acc" Foreground="White"
                                        BorderThickness="0" FontSize="11" Margin="16,0,0,0"
                                        Command="{Binding AddMCPServerCommand}"/>
                            </StackPanel>
                            <TextBlock Text="MCP (Model Context Protocol) 让 AI 连接外部工具和数据源。从市场安装或手动配置。"
                                       FontSize="11" Foreground="#888" Margin="0,6,0,0"/>
                        </StackPanel>

                        <TabControl Grid.Row="1" Background="#252526" BorderBrush="#454545" BorderThickness="1">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Background" Value="#2d2d2d"/>
                                    <Setter Property="Foreground" Value="#aaa"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="16,8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                                        Cursor="Hand">
                                                    <ContentPresenter Content="{TemplateBinding Header}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#3a3a3a"/>
                                                        <Setter Property="Foreground" Value="#4ec9b0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>

                            <!-- Tab 1: 我的服务器 -->
                            <TabItem Header="🖥 我的服务器">
                                <Grid Margin="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Content="🔄 刷新" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                                BorderThickness="0" FontSize="11" Command="{Binding RefreshMCPServersCommand}"/>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding MCPServers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,3" Padding="10,8" Background="#252526" CornerRadius="4">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#4ec9b0"
                                                                           VerticalAlignment="Center" Text="{Binding Name}"/>
                                                                <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                                        Visibility="{Binding Enabled, Converter={StaticResource BoolToVisibility}}">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#1a3a1a"/>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="启用" FontSize="10" Foreground="#90ee90"/>
                                                                </Border>
                                                                <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                                        Visibility="{Binding Enabled, Converter={StaticResource InverseBoolToVisibility}}">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#3a1a1a"/>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="禁用" FontSize="10" Foreground="#f0a0a0"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Grid.Row="1" FontSize="11" Foreground="#569cd6" Margin="0,4,0,0"
                                                                       FontFamily="Consolas,monospace">
                                                                <Run Text="{Binding Command, Mode=OneWay}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding ArgsDisplay, Mode=OneWay}" Foreground="#888"/>
                                                            </TextBlock>
                                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"
                                                                           VerticalAlignment="Center" MaxWidth="280" TextTrimming="CharacterEllipsis"/>
                                                                <Button Content="编辑" Width="48" Height="22" FontSize="10"
                                                                        Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                                                                        Margin="12,0,4,0" Command="{Binding DataContext.EditMCPServerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding .}"/>
                                                                <Button Content="卸载" Width="48" Height="22" FontSize="10"
                                                                        Background="#5a1a1a" Foreground="#f0a0a0" BorderThickness="0"
                                                                        Command="{Binding DataContext.UninstallMCPCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding .}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>

                            <!-- Tab 2: 工具市场 -->
                            <TabItem Header="🛒 工具市场">
                                <Grid Margin="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="发现 MCP 工具" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding MCPMarketStatus}" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                        <Button Content="🔄 刷新" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                                BorderThickness="0" FontSize="11" Margin="16,0,0,0" Command="{Binding RefreshMCPMarketCommand}"/>
                                    </StackPanel>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding MCPMarketItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,3" Padding="10,8" Background="#252526" CornerRadius="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock FontSize="12" FontWeight="Bold" Foreground="#569cd6"
                                                                               VerticalAlignment="Center" Text="{Binding Name}"/>
                                                                    <Border Background="#3a3a3a" CornerRadius="3" Padding="6,1" Margin="8,0,0,0">
                                                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#aaa"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"
                                                                           TextWrapping="Wrap" Margin="0,4,0,0" MaxWidth="360"/>
                                                                <TextBlock FontSize="10" Foreground="#4ec9b0" Margin="0,3,0,0"
                                                                           FontFamily="Consolas,monospace" TextTrimming="CharacterEllipsis">
                                                                    <Run Text="{Binding Command, Mode=OneWay}"/>
                                                                    <Run Text=" "/>
                                                                    <Run Text="{Binding Args, Mode=OneWay}" Foreground="#888"/>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding InstallNote}" FontSize="10" Foreground="#f0c040" Margin="0,2,0,0"
                                                                           Visibility="{Binding InstallNote, Converter={StaticResource IsNotNull}}"/>
                                                                <TextBlock Text="{Binding EnvNote}" FontSize="10" Foreground="#60c0ff" Margin="0,2,0,0"
                                                                           Visibility="{Binding EnvNote, Converter={StaticResource IsNotNull}}"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Width="72" Height="28"
                                                                    Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0"
                                                                    FontSize="11" VerticalAlignment="Center"
                                                                    Content="{Binding InstallStatus}"
                                                                    Command="{Binding DataContext.InstallMCPCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding .}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>

                    <!-- ====== 学习统计 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageLearning">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="🧠 学习统计" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0"
                                           VerticalAlignment="Center"/>
                                <Button Content="🔄 刷新" Width="72" Height="28" Background="#3a3a3a" Foreground="#d4d4d4"
                                        BorderThickness="0" FontSize="11" Margin="16,0,0,0"
                                        Click="LearningRefresh_Click"/>
                            </StackPanel>

                            <TextBlock Text="AI 自我学习系统从每次对话中自动提取编程经验，统计如下："
                                       FontSize="11" Foreground="#888" Margin="0,0,0,20"/>

                            <!-- 统计卡片 -->
                            <WrapPanel Margin="0,0,0,20">
                                <!-- 总经验数 -->
                                <Border Background="#252526" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="6"
                                        Padding="20,16" Width="170" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="总经验数" FontSize="11" Foreground="#888"/>
                                        <TextBlock Text="{Binding LearningTotalCount}" FontSize="28" FontWeight="Bold"
                                                   Foreground="#4ec9b0" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 已验证 -->
                                <Border Background="#252526" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="6"
                                        Padding="20,16" Width="170" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="已验证" FontSize="11" Foreground="#888"/>
                                        <TextBlock Text="{Binding LearningVerifiedCount}" FontSize="28" FontWeight="Bold"
                                                   Foreground="#569cd6" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 平均置信度 -->
                                <Border Background="#252526" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="6"
                                        Padding="20,16" Width="170" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="平均置信度" FontSize="11" Foreground="#888"/>
                                        <TextBlock Text="{Binding LearningAvgConfidence}" FontSize="28" FontWeight="Bold"
                                                   Foreground="#dcdcaa" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <!-- 分类分布 -->
                            <Border Background="#252526" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="6" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="📊 分类分布" FontSize="13" FontWeight="SemiBold" Foreground="#e0e0e0" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding LearningCategoryBreakdown}"
                                               FontSize="12" Foreground="#aaa" TextWrapping="Wrap"
                                               LineHeight="22"/>
                                </StackPanel>
                            </Border>

                            <!-- 说明 -->
                            <TextBlock Text="💡 学习经验从 AI 代码审查、Bug修复、性能优化、重构建议等对话中自动提取。&#10;置信度 ≥ 0.4 的经验才会入库，重复经验会自动合并提升置信度。"
                                       FontSize="11" Foreground="#666" Margin="0,16,0,0" TextWrapping="Wrap" LineHeight="18"/>
                        </StackPanel>
                    </Grid>

                    <!-- ====== 关于 ====== -->
                    <Grid Visibility="Collapsed" x:Name="PageAbout">
                        <StackPanel>
                            <TextBlock Text="关于" FontSize="18" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,12"/>
                            <TextBlock Text="AI IDE - 智能代码编辑器" FontSize="14" Foreground="#d4d4d4"/>
                            <TextBlock Text="版本 1.0.0" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Text="基于 .NET 10 + WPF + MVVM 架构" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Text="AI 引擎: DeepSeek API" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                            <TextBlock Text="数据库: SQLite (本地)" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>

                            <!-- 环境状态（来自统一启动诊断） -->
                            <Separator Background="#3a3a3a" Margin="0,16,0,12"/>
                            <TextBlock Text="{Binding EnvSummary}" FontSize="13" Foreground="#d4d4d4" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="{Binding EnvNetworkStatus}" FontSize="12" Foreground="#aaa" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding EnvDotNetStatus}" FontSize="12" Foreground="#aaa" Margin="0,2,0,0"/>
                                <TextBlock Text="{Binding EnvGitStatus}" FontSize="12" Foreground="#aaa" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- 底部按钮栏 -->
        <Border Grid.Row="1" Background="#252525" BorderBrush="#3a3a3a" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10">
                <Button Content="取消" Width="80" Background="#3a3a3a" Foreground="#d4d4d4"
                        BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,10,0"
                        Command="{Binding CloseCommand}"/>
                <Button Content="保存设置" Width="90" Background="#007acc" Foreground="White"
                        BorderThickness="0" Padding="8,6" FontSize="13" FontWeight="SemiBold"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
