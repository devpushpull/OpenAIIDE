<UserControl x:Class="AIIDEWPF.Views.WorkspaceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AIIDEWPF"
        xmlns:vm="clr-namespace:AIIDEWPF.ViewModels"
        xmlns:conv="clr-namespace:AIIDEWPF.Converters"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Background="#1e1e1e" Foreground="#d4d4d4">
    <UserControl.InputBindings>
        <!-- 调试快捷键 -->
        <KeyBinding Key="F5" Command="{Binding ContinueDebugCommand}"/>
        <KeyBinding Key="F10" Command="{Binding StepOverCommand}"/>
        <KeyBinding Key="F11" Command="{Binding StepIntoCommand}"/>
        <KeyBinding Key="F11" Modifiers="Shift" Command="{Binding StepOutCommand}"/>
        <KeyBinding Key="F5" Modifiers="Shift" Command="{Binding StopDebugCommand}"/>
        <KeyBinding Key="F10" Modifiers="Ctrl" Command="{Binding RunToCursorCommand}"/>
        <KeyBinding Key="F9" Command="{Binding ToggleBreakpointCommand}"/>
        <!-- 编辑器快捷键 -->
        <KeyBinding Key="F12" Command="{Binding GoToDefinitionCommand}"/>
        <KeyBinding Key="F12" Modifiers="Shift" Command="{Binding FindReferencesCommand}"/>
    </UserControl.InputBindings>
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:SandboxModeToBgConverter x:Key="SandboxModeToBg"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:BoolToEditIconConverter x:Key="BoolToEditIcon"/>
        <conv:IsNotNullConverter x:Key="IsNotNull"/>
        <conv:ActiveBarFgConverter x:Key="ActiveBarFg"/>
        <conv:DirIconConverter x:Key="DirIcon"/>
        <conv:FileIconConverter x:Key="FileIcon"/>
        <conv:StringHasContentToVisibilityConverter x:Key="HasContentToVis"/>
        <conv:MarkdownToFlowDocumentConverter x:Key="MarkdownConverter"/>

        <!-- 可选中复制的只读文本框样式 -->
        <Style x:Key="SelectableTextStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Cursor" Value="Arrow"/>
        </Style>

        <!-- Chat message templates -->
        <DataTemplate x:Key="SystemMessageTemplate" DataType="{x:Type vm:ChatMessageDisplay}">
            <Grid Margin="8,4">
                <Border Background="#2a2a2a" CornerRadius="6" Padding="8,4" HorizontalAlignment="Center" MaxWidth="360">
                    <TextBox Text="{Binding Content, Mode=OneWay}" Foreground="#888" FontSize="12"
                             TextAlignment="Center" Style="{StaticResource SelectableTextStyle}"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ReasoningMessageTemplate" DataType="{x:Type vm:ChatMessageDisplay}">
            <Grid Margin="8,4">
                <!-- Qoder风格推理对话框 -->
                <Border Background="#1a1d26" CornerRadius="10" Padding="10,8" HorizontalAlignment="Left" MaxWidth="430"
                        BorderBrush="#2d3540" BorderThickness="1">
                    <StackPanel>
                        <!-- 头部：思考状态 + 模型名 + 展开/折叠 -->
                        <Grid Cursor="Hand" MouseLeftButtonDown="ReasoningMessage_Click" ToolTip="点击展开/折叠推理过程">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- 思考动画图标 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                    <Setter Property="Text" Value="⏳"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStreaming}" Value="False">
                                                    <Setter Property="Text" Value="✅"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#c8a84e" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                    <Setter Property="Text" Value="深度思考中..."/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStreaming}" Value="False">
                                                    <Setter Property="Text" Value="思考完成"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <!-- 模型标签 -->
                            <TextBlock Grid.Column="1" Text="{Binding ModelLabel}" FontSize="9" Foreground="#5a6a7a"
                                       VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding HasModelLabel, Converter={StaticResource BoolToVis}}"/>
                            <!-- 折叠/展开指示 -->
                            <TextBlock Grid.Column="2" FontSize="12" Foreground="#666" VerticalAlignment="Center" Margin="6,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReasoningCollapsed}" Value="True">
                                                <Setter Property="Text" Value="▶"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsReasoningCollapsed}" Value="False">
                                                <Setter Property="Text" Value="▼"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- 展开状态：完整推理内容 -->
                        <Border Background="#151820" CornerRadius="6" Padding="10,8" Margin="0,6,0,0"
                                Visibility="{Binding IsReasoningCollapsed, Converter={StaticResource InverseBoolToVis}}"
                                BorderBrush="#2a3040" BorderThickness="1">
                            <TextBox Text="{Binding Content, Mode=OneWay}"
                                     Foreground="#8b949e" FontSize="12" FontStyle="Italic"
                                     Background="Transparent" BorderThickness="0"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     Style="{StaticResource SelectableTextStyle}"
                                     VerticalScrollBarVisibility="Auto" MaxHeight="300"/>
                        </Border>

                        <!-- 折叠状态：摘要提示 -->
                        <Border Background="#1d2128" CornerRadius="6" Padding="10,6" Margin="0,6,0,0"
                                Cursor="Hand" MouseLeftButtonDown="ReasoningMessage_Click"
                                Visibility="{Binding IsReasoningCollapsed, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="11" Foreground="#5a6a7a" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                <Setter Property="Text" Value="点击查看实时推理过程..."/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsStreaming}" Value="False">
                                                <Setter Property="Text" Value="点击查看完整推理过程"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type vm:ChatMessageDisplay}">
            <Grid Margin="8,4">
                <Border Background="#0e639c" CornerRadius="8" Padding="10,6" HorizontalAlignment="Right" MaxWidth="360">
                    <TextBox Text="{Binding Content, Mode=OneWay}" Foreground="White" FontSize="13"
                             Style="{StaticResource SelectableTextStyle}"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" DataType="{x:Type vm:ChatMessageDisplay}">
            <Grid Margin="8,4">
                <StackPanel>
                    <TextBlock Text="{Binding ModelLabel}" FontSize="10" Foreground="#4ec9b0" Margin="4,0,0,2"
                               Visibility="{Binding HasModelLabel, Converter={StaticResource BoolToVis}}"/>
                    <Border Background="#2d2d2d" CornerRadius="8" Padding="10,6" HorizontalAlignment="Left" MaxWidth="420">
                        <FlowDocumentScrollViewer Document="{Binding Content, Converter={StaticResource MarkdownConverter}}"
                                                 Foreground="#d4d4d4" FontSize="13"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 MaxHeight="400"
                                                 Background="Transparent" BorderThickness="0"
                                                 IsToolBarVisible="False"/>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ToolCallTemplate" DataType="{x:Type vm:ChatMessageDisplay}">
            <Grid Margin="8,4">
                <Border Background="#3a3a1a" CornerRadius="6" Padding="8,4" HorizontalAlignment="Left" MaxWidth="380">
                    <StackPanel>
                        <TextBox Foreground="#f0c040" FontSize="12" Style="{StaticResource SelectableTextStyle}">
                            <TextBox.Text>
                                <MultiBinding StringFormat="{}{0} {1}">
                                    <Binding Path="ToolStatus" StringFormat="[{0}]"/>
                                    <Binding Path="Content"/>
                                </MultiBinding>
                            </TextBox.Text>
                        </TextBox>
                        <TextBox Text="{Binding ToolResult, Mode=OneWay}" Foreground="#888" FontSize="11"
                                 Style="{StaticResource SelectableTextStyle}"
                                 Visibility="{Binding IsToolDone, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <Style x:Key="ChatMessageStyle" TargetType="ContentPresenter">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource UserMessageTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource AssistantMessageTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource SystemMessageTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsReasoning}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource ReasoningMessageTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsTool}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource ToolCallTemplate}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Activity Bar button style (Qoder/VS Code style with hover) -->
        <Style x:Key="ActivityBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#858585"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a3a3a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ====== Row 0: Tab Bar (VS Code-style with navigation arrows) ====== -->
        <Border Grid.Row="0" Background="#252526" Height="36"
                Visibility="{Binding Editor.HasTabs, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ◀ 左翻页（多标签时显示） -->
                <Button Grid.Column="0" Content="◀" Width="28" Height="36"
                        Background="Transparent" Foreground="#888" BorderThickness="0"
                        FontSize="10" Cursor="Hand"
                        Visibility="{Binding Editor.HasMultipleTabs, Converter={StaticResource BoolToVis}}"
                        Click="TabScrollLeft_Click"/>

                <!-- 标签滚动区 -->
                <ScrollViewer Grid.Column="1" x:Name="TabScrollViewer"
                              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Editor.Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0" Margin="0" Cursor="Hand"
                                        Background="{Binding ActiveBackground}"
                                        BorderBrush="#454545" BorderThickness="0,0,1,0"
                                        MouseLeftButtonDown="EditorTab_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- 文件名 -->
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12"
                                                   Foreground="{Binding ActiveForeground}"
                                                   VerticalAlignment="Center" Padding="12,0,0,0" Margin="0,9,0,7"/>
                                        <!-- 关闭按钮（Button 替代 TextBlock，确保可靠点击） -->
                                        <Button Content="×" Width="22" Height="22" FontSize="15"
                                                Background="Transparent"
                                                Foreground="{Binding ActiveForeground}"
                                                BorderThickness="0" Cursor="Hand"
                                                Margin="2,0,6,0" Padding="0"
                                                ToolTip="关闭" Click="EditorTabClose_Click"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ▶ 右翻页（多标签时显示） -->
                <Button Grid.Column="2" Content="▶" Width="28" Height="36"
                        Background="Transparent" Foreground="#888" BorderThickness="0"
                        FontSize="10" Cursor="Hand"
                        Visibility="{Binding Editor.HasMultipleTabs, Converter={StaticResource BoolToVis}}"
                        Click="TabScrollRight_Click"/>
            </Grid>
        </Border>

        <!-- ====== Row 1: 五栏主体布局 (活动栏 | 侧边栏 | 编辑器 | 分隔条 | AI面板) ====== -->
        <Grid Grid.Row="1" x:Name="MainLayoutGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>      <!-- Activity Bar -->
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="500"/>    <!-- Left Sidebar -->
                <ColumnDefinition Width="Auto"/>    <!-- Left Splitter -->
                <ColumnDefinition Width="*"/>       <!-- Editor -->
                <ColumnDefinition Width="Auto"/>    <!-- Right Splitter -->
                <ColumnDefinition Width="480" MinWidth="280" MaxWidth="800"/>    <!-- AI Panel -->
            </Grid.ColumnDefinitions>

            <!-- ===== Col 0: Activity Bar (Qoder-style narrow icon strip) ===== -->
            <Border Grid.Column="0" Background="#333333">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部组：导航图标 -->
                    <StackPanel Grid.Row="0" VerticalAlignment="Top" Margin="0,8,0,0">
                        <!-- 文件树 -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="文件资源管理器"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="files">
                            <TextBlock Text="📁" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsFilesSidebar, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- 搜索 -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="搜索 (Ctrl+Shift+F)"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="search">
                            <TextBlock Text="🔍" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsSearchSidebar, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- 代码管理(Git) -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="源代码管理 (Git)"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="git">
                            <TextBlock Text="🔀" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsGitSidebar, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- 运行和调试 -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="运行和调试 (F5)"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="debug">
                            <TextBlock Text="🐞" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsDebugSidebar, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- 扩展 -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}"
                                ToolTip="{Binding PluginEntryTooltip}"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="extensions">
                            <Grid>
                                <TextBlock Text="📦" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{Binding IsExtensionsSidebar, Converter={StaticResource ActiveBarFg}}"/>
                                <!-- 更新计数角标 -->
                                <Border x:Name="PluginUpdateBadge" CornerRadius="8"
                                        Background="#e05050" MinWidth="16" Height="16"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,1,3,0" Padding="3,0"
                                        Visibility="{Binding HasPluginUpdate, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding PluginUpdateBadge}"
                                               FontSize="9" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>
                        <!-- Repo Wiki -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="Repo Wiki"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="wiki">
                            <TextBlock Text="📖" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsWikiSidebar, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- 远程资源管理器 -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="远程资源管理器"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="remote">
                            <TextBlock Text="🌐" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsRemoteSidebar, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- Containers -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="Containers"
                                Command="{Binding SwitchSidebarCommand}" CommandParameter="containers">
                            <TextBlock Text="📦" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsContainersSidebar, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                    </StackPanel>

                    <!-- 底部组：AI / 终端 / 日志 -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,8">
                        <!-- AI Chat -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="AI 对话面板"
                                Command="{Binding ToggleAIPanelCommand}">
                            <TextBlock Text="💬" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsAIPanelVisible, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- Terminal -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="终端"
                                Command="{Binding SwitchBottomTabCommand}" CommandParameter="terminal">
                            <TextBlock Text="🖥" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsTerminalTab, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                        <!-- Log -->
                        <Button Style="{StaticResource ActivityBarButtonStyle}" ToolTip="日志输出"
                                Command="{Binding SwitchBottomTabCommand}" CommandParameter="log">
                            <TextBlock Text="📋" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding IsLogTab, Converter={StaticResource ActiveBarFg}}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Col 1: Left Sidebar (switchable panels) ===== -->
            <Border Grid.Column="1" Background="#252526"
                    Visibility="{Binding IsLeftSidebarVisible, Converter={StaticResource BoolToVis}}">
                <Grid>

                <!-- Files Panel -->
                <Grid Visibility="{Binding IsFilesSidebar, Converter={StaticResource BoolToVis}}">
                    <!-- === 项目已打开：显示文件树 === -->
                    <Grid Visibility="{Binding FileTree.IsProjectOpen, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- 项目信息头 -->
                    <Border Grid.Row="0" Padding="12,8" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding FileTree.ProjectName}" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0"/>
                            <TextBlock Text="{Binding FileTree.ProjectPath}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                            <TextBlock FontSize="11" Foreground="#666">
                                <Run Text="{Binding FileTree.FileCount}"/><Run Text=" 个文件"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <!-- 打开的编辑器 (Open Editors) -->
                    <Border Grid.Row="1" BorderBrush="#454545" BorderThickness="0,0,0,1">
                    <Expander IsExpanded="True"
                              Background="#252526" Foreground="#d4d4d4" BorderThickness="0">
                        <Expander.Header>
                            <Border Padding="0,6,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📑" FontSize="11" Margin="8,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="打开的编辑器" FontSize="11" FontWeight="Bold"
                                               Foreground="#888" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="10" Foreground="#555" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <Run Text="("/><Run Text="{Binding Editor.Tabs.Count, Mode=OneWay}"/><Run Text=")"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Expander.Header>
                        <Border Background="#252526" Padding="0,2">
                            <ItemsControl ItemsSource="{Binding Editor.Tabs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,3" Cursor="Hand" Background="Transparent"
                                                MouseLeftButtonDown="OpenEditorItem_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                                            <Setter Property="Background" Value="#2d2d2d"/>
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2a2d2e"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="📄" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#d4d4d4"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding IsDirty, Converter={StaticResource BoolToVis}, ConverterParameter=●}"
                                                               FontSize="10" Foreground="#e2c08d" VerticalAlignment="Center" Margin="4,0,0,0"
                                                               Visibility="Collapsed"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="×" FontSize="14" Foreground="#888"
                                                           VerticalAlignment="Center" Margin="4,0,0,0" Cursor="Hand"
                                                           MouseLeftButtonDown="OpenEditorClose_Click"
                                                           ToolTip="关闭编辑器"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Expander>
                    </Border>
                    <!-- 工具栏 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="4,2" VerticalAlignment="Top">
                        <Button Content="🔄" Width="28" Height="26" Padding="0" Background="Transparent"
                                Foreground="#c0c0c0" BorderThickness="0" Cursor="Hand"
                                Command="{Binding RefreshTreeCommand}" ToolTip="刷新文件树"/>
                        <Button Content="📄" Width="28" Height="26" Padding="0" Background="Transparent"
                                Foreground="#c0c0c0" BorderThickness="0" Cursor="Hand"
                                Command="{Binding NewFileCommand}" Margin="2,0,0,0" ToolTip="新建文件"/>
                        <Button Content="📁" Width="28" Height="26" Padding="0" Background="Transparent"
                                Foreground="#c0c0c0" BorderThickness="0" Cursor="Hand"
                                Command="{Binding NewFolderCommand}" Margin="2,0,0,0" ToolTip="新建文件夹"/>
                        <Button Content="⊟" Width="28" Height="26" Padding="0" Background="Transparent"
                                Foreground="#c0c0c0" BorderThickness="0" Cursor="Hand"
                                Command="{Binding CollapseAllCommand}" Margin="2,0,0,0" ToolTip="全部折叠"/>
                    </StackPanel>
                    <!-- 文件树 -->
                    <TreeView x:Name="FileTreeView" Grid.Row="3" ItemsSource="{Binding FileTree.RootItems}"
                              Background="#252526" BorderThickness="0" Padding="4"
                              PreviewMouseLeftButtonDown="FileTree_PreviewMouseLeftButtonDown"
                              MouseDoubleClick="FileTree_MouseDoubleClick"
                              SelectedItemChanged="FileTree_SelectedItemChanged">
                        <TreeView.ContextMenu>
                            <ContextMenu Background="#2d2d30" Foreground="#d4d4d4" BorderBrush="#454545">
                                <ContextMenu.Resources>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#d4d4d4"/>
                                        <Setter Property="Padding" Value="12,4"/>
                                    </Style>
                                    <Style TargetType="Separator">
                                        <Setter Property="Background" Value="#454545"/>
                                        <Setter Property="Height" Value="1"/>
                                    </Style>
                                </ContextMenu.Resources>
                                <MenuItem Header="新建文件" Click="ContextNewFile_Click" InputGestureText="Ctrl+N, F"/>
                                <MenuItem Header="新建文件夹" Click="ContextNewFolder_Click"/>
                                <Separator/>
                                <MenuItem Header="在资源管理器中打开" Click="ContextRevealInExplorer_Click" InputGestureText="Shift+Alt+R"/>
                                <MenuItem Header="打开到侧边" Click="ContextOpenToSide_Click" InputGestureText="Ctrl+Enter"/>
                                <Separator/>
                                <MenuItem Header="复制路径" Click="ContextCopyPath_Click" InputGestureText="Shift+Alt+C"/>
                                <MenuItem Header="复制相对路径" Click="ContextCopyRelativePath_Click"/>
                                <Separator/>
                                <MenuItem Header="重命名" Click="ContextRename_Click" InputGestureText="F2"/>
                                <MenuItem Header="删除" Click="ContextDelete_Click" InputGestureText="Del">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                            <Setter Property="Foreground" Value="#f14c4c"/>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="#d4d4d4"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Converter={StaticResource FileIcon}}" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding GitStatusMark}" 
                                               Foreground="{Binding GitStatusColor}" 
                                               FontSize="11" Margin="0,0,3,0"
                                               Visibility="{Binding GitStatusMark, Converter={StaticResource HasContentToVis}}"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <!-- 大纲 (Outline) - VS Code 风格折叠面板 -->
                    <Expander Grid.Row="4" IsExpanded="False"
                              Background="#252526" Foreground="#d4d4d4" BorderThickness="0"
                              BorderBrush="#454545" Margin="0,0,0,0">
                        <Expander.Header>
                            <Border BorderBrush="#454545" BorderThickness="0,1,0,0" Padding="0,6,0,2" Margin="0,0,0,0">
                                <TextBlock Text="📑 大纲 (OUTLINE)" FontSize="11" FontWeight="Bold"
                                           Foreground="#888" Margin="8,0,0,0"/>
                            </Border>
                        </Expander.Header>
                        <Border Background="#252526" Padding="8,4" MaxHeight="160">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="当前文件符号结构" FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                                    <!-- 占位大纲项 -->
                                    <Border Padding="6,3" Margin="0,1" CornerRadius="2" Cursor="Hand"
                                            Background="#2a2a2a" ToolTip="打开文件后显示符号列表">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔤" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="命名空间 / 类 / 方法 / 属性" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="💡 打开代码文件后自动解析" FontSize="10" Foreground="#555"
                                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Expander>

                    <!-- 时间线 (Timeline) - VS Code 风格折叠面板 -->
                    <Expander Grid.Row="5" IsExpanded="False"
                              Background="#252526" Foreground="#d4d4d4" BorderThickness="0">
                        <Expander.Header>
                            <Border BorderBrush="#454545" BorderThickness="0,1,0,0" Padding="0,6,0,2">
                                <TextBlock Text="🕐 时间线 (TIMELINE)" FontSize="11" FontWeight="Bold"
                                           Foreground="#888" Margin="8,0,0,0"/>
                            </Border>
                        </Expander.Header>
                        <Border Background="#252526" Padding="8,4" MaxHeight="160">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="文件 Git 历史记录" FontSize="10" Foreground="#666" Margin="0,0,0,8"/>
                                    <!-- 占位时间线条目 -->
                                    <Border Padding="6,3" Margin="0,1" CornerRadius="2"
                                            Background="#2a2a2a">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📝" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="打开文件后可查看" FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Git 提交历史 · 本地历史记录" FontSize="9" Foreground="#555" Margin="18,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="💡 选择文件后显示变更时间线" FontSize="10" Foreground="#555"
                                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Expander>
                    </Grid>
                    <!-- === 无项目：空状态提示 === -->
                    <Border Visibility="{Binding FileTree.IsProjectOpen, Converter={StaticResource InverseBoolToVis}}"
                            Background="#252526">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-40,0,0">
                            <TextBlock Text="📂" FontSize="56" HorizontalAlignment="Center" Foreground="#444" Margin="0,0,0,8"/>
                            <TextBlock Text="尚未打开文件夹" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#999" HorizontalAlignment="Center"/>
                            <TextBlock Text="打开一个文件夹以开始使用" FontSize="11"
                                       Foreground="#666" HorizontalAlignment="Center" Margin="0,4,0,20"/>
                            <Button Content="📂  打开文件夹" Width="160" Height="34"
                                    Background="#0e639c" Foreground="White" BorderThickness="0"
                                    FontSize="12" Cursor="Hand" HorizontalAlignment="Center"
                                    Command="{Binding OpenProjectCommand}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Search Panel -->
                <Grid Visibility="{Binding IsSearchSidebar, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="8" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchInput, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                                     Padding="8,5" FontSize="12" VerticalContentAlignment="Center"
                                     ToolTip="输入搜索关键词，回车搜索">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="搜索" Width="50" Background="#007acc" Foreground="White"
                                    BorderThickness="0" FontSize="11" Margin="4,0,0,0"
                                    Command="{Binding SearchCommand}"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SearchResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2,1" Padding="6,3" Background="#2d2d2d" CornerRadius="3"
                                            Cursor="Hand" MouseLeftButtonDown="SearchResult_Click"
                                            ToolTip="点击打开文件">
                                        <StackPanel>
                                            <TextBlock FontSize="11" Foreground="#569cd6" FontFamily="Consolas,monospace">
                                                <Run Text="{Binding File}"/><Run Text=":"/><Run Text="{Binding Line}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Preview}" FontSize="10" Foreground="#888"
                                                       Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Git Panel -->
                <Grid Visibility="{Binding IsGitSidebar, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="12,8" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="🔀 源代码管理" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                            <Border Background="#2a2a2a" CornerRadius="3" Padding="6,3" Margin="0,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding GitBranchDisplay}" FontSize="11" Foreground="#f0c040"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Visibility="{Binding GitBranchDisplay, Converter={StaticResource HasContentToVis}}"/>
                                    <TextBlock Text="{Binding GitChangeDisplay}" FontSize="11" Foreground="#888" VerticalAlignment="Center"
                                               Visibility="{Binding GitChangeDisplay, Converter={StaticResource HasContentToVis}}"/>
                                    <TextBlock Text="非 Git 仓库" FontSize="10" Foreground="#666"
                                               Visibility="{Binding IsNotGitRepo, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- Changed Files -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                        <StackPanel>
                            <!-- 变更文件列表 -->
                            <TextBlock Text="📝 变更" FontSize="11" FontWeight="Bold" Foreground="#888" Margin="12,4,0,4"
                                       Visibility="{Binding HasGitChanges, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding GitChanges}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4,1" Padding="8,4" Background="#2a2a2a" CornerRadius="3" Cursor="Hand"
                                                MouseLeftButtonDown="GitChangeItem_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StatusMark}" FontSize="11" FontWeight="Bold"
                                                           Foreground="{Binding StatusColor}" VerticalAlignment="Center" Width="20"/>
                                                <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#d4d4d4"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- 暂存区文件 -->
                            <TextBlock Text="📦 暂存的更改" FontSize="11" FontWeight="Bold" Foreground="#888" Margin="12,12,0,4"
                                       Visibility="{Binding HasStagedChanges, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding GitStagedChanges}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4,1" Padding="8,4" Background="#1a2a1a" CornerRadius="3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓" FontSize="11" FontWeight="Bold"
                                                           Foreground="#90ee90" VerticalAlignment="Center" Width="20"/>
                                                <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#a0d0a0"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- 未跟踪文件 -->
                            <TextBlock Text="❓ 未跟踪的文件" FontSize="11" FontWeight="Bold" Foreground="#888" Margin="12,12,0,4"
                                       Visibility="{Binding HasUntrackedChanges, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding GitUntrackedChanges}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4,1" Padding="8,4" Background="#2a2a1a" CornerRadius="3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="U" FontSize="11" FontWeight="Bold"
                                                           Foreground="#f0c040" VerticalAlignment="Center" Width="20"/>
                                                <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#d4d4d4"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- 无变更提示 -->
                            <TextBlock Text="✅ 工作区干净，没有待提交的更改" FontSize="11" Foreground="#666"
                                       Margin="12,8,0,0"
                                       Visibility="{Binding IsGitClean, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Margin="8,6">
                        <TextBox Text="{Binding GitCommitMessage, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                                 Padding="8,6" FontSize="12" Height="32" VerticalContentAlignment="Center"
                                 ToolTip="输入提交信息">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="✅ 提交并推送" Height="30"
                                    Background="#1a5a2a" Foreground="#90ee90" BorderThickness="0" FontSize="12"
                                    Command="{Binding GitCommitPushCommand}"
                                    Visibility="{Binding HasGitChanges, Converter={StaticResource BoolToVis}}"/>
                            <Button Grid.Column="0" Content="🔄 刷新" Height="30"
                                    Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0" FontSize="12"
                                    Command="{Binding GitRefreshCommand}"
                                    Visibility="{Binding HasGitChanges, Converter={StaticResource InverseBoolToVis}}"/>
                            <Button Grid.Column="1" Content="⚙️ 配置" Width="60" Height="30"
                                    Background="#3a5a7a" Foreground="#a0c0e0" BorderThickness="0" FontSize="11"
                                    Command="{Binding GitSettingsCommand}" Margin="6,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Extensions Panel -->
                <Grid Visibility="{Binding IsExtensionsSidebar, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="12,8" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 扩展" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                                <TextBlock Text=" (已安装)" FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="{Binding InstalledPluginSummary}" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Installed Plugins List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                        <ItemsControl ItemsSource="{Binding InstalledPlugins}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="8,6" Background="#2a2a2a" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Foreground="#569cd6" VerticalAlignment="Center"/>
                                                <TextBlock FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="6,0,0,0">
                                                    <Run Text="v"/><Run Text="{Binding Version}"/>
                                                </TextBlock>
                                                <Border Background="#1a3a1a" CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                                        Visibility="{Binding Enabled, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="已启用" FontSize="9" Foreground="#90ee90"/>
                                                </Border>
                                                <Border Background="#3a1a1a" CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                                        Visibility="{Binding Enabled, Converter={StaticResource InverseBoolToVis}}">
                                                    <TextBlock Text="已禁用" FontSize="9" Foreground="#f0a0a0"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="10" Foreground="#888"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <TextBlock Text="📭 暂无已安装插件&#10;点击下方「管理扩展」浏览和安装插件" FontSize="11" Foreground="#666"
                                   HorizontalAlignment="Center" Margin="0,24,0,0" TextAlignment="Center"
                                   Visibility="{Binding HasInstalledPlugins, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Margin="8,6">
                        <Button Content="🔌 管理扩展" Height="30"
                                Background="#3a5a7a" Foreground="#a0c0e0" BorderThickness="0" FontSize="12"
                                Command="{Binding PluginManagerCommand}"/>
                        <Button Content="🔄 刷新列表" Height="28"
                                Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0" FontSize="11"
                                Command="{Binding RefreshPluginsCommand}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Repo Wiki Panel -->
                <Grid Visibility="{Binding IsWikiSidebar, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="12,8" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="📖 Repo Wiki" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                            <TextBlock Text="项目知识库 · 编程偏好 · 开发经验" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Search -->
                    <Border Grid.Row="1" Padding="8,4" Margin="4,4" Background="#2a2a2a" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding WikiSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="#d4d4d4" BorderThickness="0"
                                     Padding="6,4" FontSize="11" VerticalContentAlignment="Center"
                                     ToolTip="搜索知识库记忆">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding WikiSearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Content="🔍" Width="32" Height="26"
                                    Background="Transparent" Foreground="#888" BorderThickness="0" FontSize="12"
                                    Command="{Binding WikiSearchCommand}"/>
                        </Grid>
                    </Border>
                    <!-- Memory Items List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                        <ItemsControl ItemsSource="{Binding WikiMemories}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4,2" Padding="8,6" Background="#2a2a2a" CornerRadius="4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ScopeIcon}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="#d4d4d4" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ContentPreview}" FontSize="10" Foreground="#888"
                                                       TextTrimming="CharacterEllipsis" Margin="16,2,0,0" MaxWidth="210"/>
                                            <StackPanel Orientation="Horizontal" Margin="16,2,0,0">
                                                <Border Background="#333" CornerRadius="2" Padding="4,1">
                                                    <TextBlock Text="{Binding Category}" FontSize="9" Foreground="#888"/>
                                                </Border>
                                                <TextBlock Text="{Binding UpdatedAtStr}" FontSize="9" Foreground="#555" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <TextBlock Text="📭 暂无知识库条目&#10;AI 会在对话中自动学习你的偏好" FontSize="11" Foreground="#666"
                                   HorizontalAlignment="Center" Margin="0,24,0,0" TextAlignment="Center"
                                   Visibility="{Binding HasWikiMemories, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Actions -->
                    <StackPanel Grid.Row="3" Margin="8,6">
                        <Button Content="➕ 添加记忆" Height="28"
                                Background="#3a5a3a" Foreground="#a0d0a0" BorderThickness="0" FontSize="11"
                                Command="{Binding WikiAddMemoryCommand}"/>
                        <Button Content="🗑 清除会话记忆" Height="28"
                                Background="#4a3a3a" Foreground="#d0a0a0" BorderThickness="0" FontSize="11"
                                Command="{Binding WikiClearSessionCommand}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Remote Explorer Panel -->
                <Grid Visibility="{Binding IsRemoteSidebar, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="12,8" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐 远程资源管理器" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                                <TextBlock Text=" (REMOTE EXPLORER)" FontSize="9" Foreground="#555" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="SSH Targets · WSL Targets · Dev Containers" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Connection List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,4,0,0">
                            <!-- SSH Targets -->
                            <Expander IsExpanded="True" Background="#252526" Foreground="#d4d4d4" BorderThickness="0" Margin="4,2">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🖥" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="SSH Targets" FontSize="12" FontWeight="SemiBold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                                        <TextBlock Text=" (已配置)" FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel>
                                <ItemsControl ItemsSource="{Binding SshConnections}" Margin="0,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="8,2" Padding="8,6" Background="#2a2a2a" CornerRadius="4" Cursor="Hand"
                                                    MouseLeftButtonDown="RemoteConnection_Click">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🟢" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                   Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock Text="⚪" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                   Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#569cd6" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock FontSize="10" Foreground="#666" Margin="22,2,0,0">
                                                        <Run Text="{Binding Host}"/><Run Text=":"/><Run Text="{Binding Port}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="  暂无 SSH 连接" FontSize="10" Foreground="#555" Margin="8,4,0,4"
                                           Visibility="{Binding HasSshConnections, Converter={StaticResource InverseBoolToVis}}"/>
                                </StackPanel>
                            </Expander>
                            <!-- WSL Targets -->
                            <Expander IsExpanded="True" Background="#252526" Foreground="#d4d4d4" BorderThickness="0" Margin="4,2">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🐧" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="WSL Targets" FontSize="12" FontWeight="SemiBold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel>
                                <ItemsControl ItemsSource="{Binding WslConnections}" Margin="0,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="8,2" Padding="8,6" Background="#2a2a2a" CornerRadius="4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🐧" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#d4d4d4" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Distribution}" FontSize="10" Foreground="#666" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="  未检测到 WSL 发行版&#10;  请确保已安装 WSL 并运行 wsl --install" FontSize="10" Foreground="#555" Margin="8,4,0,4"
                                           Visibility="{Binding HasWslConnections, Converter={StaticResource InverseBoolToVis}}"/>
                                </StackPanel>
                            </Expander>
                            <!-- Dev Containers -->
                            <Expander IsExpanded="True" Background="#252526" Foreground="#d4d4d4" BorderThickness="0" Margin="4,2">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📦" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Dev Containers" FontSize="12" FontWeight="SemiBold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel>
                                <ItemsControl ItemsSource="{Binding DevContainerConnections}" Margin="0,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="8,2" Padding="8,6" Background="#2a2a2a" CornerRadius="4">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📦" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="#569cd6" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ConfigPath}" FontSize="10" Foreground="#666" Margin="22,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="  暂无 Dev Container 配置" FontSize="10" Foreground="#555" Margin="8,4,0,4"
                                           Visibility="{Binding HasDevContainerConnections, Converter={StaticResource InverseBoolToVis}}"/>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Margin="8,6">
                        <Button Content="➕ 新建远程连接" Height="30"
                                Background="#3a5a7a" Foreground="#a0c0e0" BorderThickness="0" FontSize="12"
                                Command="{Binding AddRemoteConnectionCommand}"/>
                        <Button Content="🔄 刷新" Height="28"
                                Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0" FontSize="11"
                                Command="{Binding RefreshRemoteCommand}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Containers Panel -->
                <Grid Visibility="{Binding IsContainersSidebar, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="12,8" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="📦 Containers" FontSize="13" FontWeight="Bold" Foreground="#e0e0e0"/>
                            <TextBlock Text="Docker 容器开发环境管理" FontSize="10" Foreground="#666" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Container List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,4,0,0">
                            <!-- Running containers -->
                            <TextBlock Text="▶ 运行中" FontSize="11" FontWeight="Bold" Foreground="#888" Margin="12,4,0,2"
                                       Visibility="{Binding HasRunningContainers, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding RunningContainers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4,2" Padding="8,6" Background="#1a2a1a" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🟢" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding ContainerName}" FontSize="12" FontWeight="SemiBold" Foreground="#d4d4d4" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Image}" FontSize="10" Foreground="#666" Margin="22,2,0,0"/>
                                                    <TextBlock Text="{Binding Ports}" FontSize="10" Foreground="#569cd6" Margin="22,1,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                                    <Button Content="⏹" Width="28" Height="24" FontSize="11"
                                                            Background="#4a3030" Foreground="#f0a0a0" BorderThickness="0"
                                                            ToolTip="停止容器" Click="ContainerStop_Click" Tag="{Binding ContainerId}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Stopped containers -->
                            <TextBlock Text="⏸ 已停止" FontSize="11" FontWeight="Bold" Foreground="#888" Margin="12,12,0,2"
                                       Visibility="{Binding HasStoppedContainers, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding StoppedContainers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4,2" Padding="8,6" Background="#2a2a2a" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🔴" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding ContainerName}" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Image}" FontSize="10" Foreground="#555" Margin="22,2,0,0"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                                    <Button Content="▶" Width="28" Height="24" FontSize="11"
                                                            Background="#2a4a2a" Foreground="#90ee90" BorderThickness="0"
                                                            ToolTip="启动容器" Click="ContainerStart_Click" Tag="{Binding ContainerId}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Empty state -->
                            <TextBlock Text="📭 未检测到 Docker 容器\n请确保 Docker Desktop 已运行\n使用 docker run 或 docker-compose 启动开发容器"
                                       FontSize="11" Foreground="#666" HorizontalAlignment="Center" Margin="0,24,0,0" TextAlignment="Center"
                                       Visibility="{Binding HasAnyContainers, Converter={StaticResource InverseBoolToVis}}"/>
                        </StackPanel>
                    </ScrollViewer>
                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Margin="8,6">
                        <Button Content="🔄 刷新容器列表" Height="30"
                                Background="#3a5a7a" Foreground="#a0c0e0" BorderThickness="0" FontSize="12"
                                Command="{Binding RefreshContainersCommand}"/>
                    </StackPanel>
                </Grid>

                <!-- Debug Panel (Placeholder) -->
                <Grid Visibility="{Binding IsDebugSidebar, Converter={StaticResource BoolToVis}}">
                    <Border VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                        <StackPanel>
                            <TextBlock Text="🐞" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="运行和调试" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="断点、变量、调用堆栈" FontSize="11" Foreground="#888" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Button Content="▶ 启动调试 (F5)" Width="140" Height="28"
                                    Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" FontSize="11"
                                    Command="{Binding StartDebugCommand}" Margin="0,8,0,0"/>
                            <Button Content="⏹ 停止调试 (Shift+F5)" Width="140" Height="28"
                                    Background="#5a3030" Foreground="#f0a0a0" BorderThickness="0" FontSize="11"
                                    Command="{Binding StopDebugCommand}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
            </Border>

            <!-- Col 2: Left Splitter -->
            <GridSplitter x:Name="LeftSplitter" Grid.Column="2" Width="3" Background="#454545" HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" Visibility="Collapsed"/>

            <!-- ===== Col 3: Editor + Welcome ===== -->
            <Grid Grid.Column="3">
                <avalon:TextEditor x:Name="CodeEditor"
                                   Background="#1E1E1E" Foreground="#d4d4d4"
                                   FontFamily="Consolas, Courier New, monospace"
                                   FontSize="14" WordWrap="True"
                                   ShowLineNumbers="True" LineNumbersForeground="#858585">
                    <avalon:TextEditor.ContextMenu>
                        <ContextMenu Foreground="#d4d4d4">
                            <MenuItem Header="剪切" Command="ApplicationCommands.Cut"/>
                            <MenuItem Header="复制" Command="ApplicationCommands.Copy"/>
                            <MenuItem Header="粘贴" Command="ApplicationCommands.Paste"/>
                        </ContextMenu>
                    </avalon:TextEditor.ContextMenu>
                </avalon:TextEditor>

                <!-- ===== 欢迎页（无文件打开时显示） ===== -->
                <Border x:Name="WelcomePanel" Background="#1e1e1e"
                        Visibility="{Binding Editor.HasOpenFile, Converter={StaticResource InverseBoolToVis}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    MaxWidth="700" Margin="40,60,40,40">

                            <!-- Logo & 标题 -->
                            <TextBlock Text="🤖" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="AI IDE" FontSize="28" FontWeight="Bold"
                                       Foreground="#e0e0e0" HorizontalAlignment="Center"/>
                            <TextBlock Text="AI 驱动的智能集成开发环境" FontSize="14"
                                       Foreground="#888" HorizontalAlignment="Center" Margin="0,4,0,30"/>

                            <!-- 快捷操作 -->
                            <Border Background="#252526" CornerRadius="8" Padding="24,20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="🚀 快速开始" FontSize="16" FontWeight="Bold"
                                               Foreground="#e0e0e0" Margin="0,0,0,14"/>

                                    <Button Content="📂 打开项目文件夹" Height="36" HorizontalAlignment="Stretch"
                                            Background="#0e639c" Foreground="White" BorderThickness="0"
                                            FontSize="13" Cursor="Hand" Margin="0,0,0,8"
                                            Command="{Binding OpenProjectCommand}">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button Content="📄 打开文件 (Ctrl+O)" Height="36" HorizontalAlignment="Stretch"
                                            Background="#333" Foreground="#d4d4d4" BorderThickness="0"
                                            FontSize="13" Cursor="Hand" Margin="0,0,0,8"
                                            Command="{Binding OpenFileCommand}">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button Content="📝 新建文件 (Ctrl+N)" Height="36" HorizontalAlignment="Stretch"
                                            Background="#333" Foreground="#d4d4d4" BorderThickness="0"
                                            FontSize="13" Cursor="Hand"
                                            Command="{Binding NewFileCommand}">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 快捷键参考 -->
                            <Border Background="#252526" CornerRadius="8" Padding="24,20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="⌨ 常用快捷键" FontSize="16" FontWeight="Bold"
                                               Foreground="#e0e0e0" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="Ctrl+S" Foreground="#569cd6"/>
                                                <Run Text="  保存文件"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="Ctrl+O" Foreground="#569cd6"/>
                                                <Run Text="  打开文件"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="Ctrl+N" Foreground="#569cd6"/>
                                                <Run Text="  新建文件"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="Ctrl+Z" Foreground="#569cd6"/>
                                                <Run Text="  撤销"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="Ctrl+F" Foreground="#569cd6"/>
                                                <Run Text="  搜索"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="Ctrl+B" Foreground="#569cd6"/>
                                                <Run Text="  切换侧栏"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="Ctrl+L" Foreground="#569cd6"/>
                                                <Run Text="  AI 对话"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="#999" Margin="0,0,0,6">
                                                <Run Text="F5" Foreground="#569cd6"/>
                                                <Run Text="  启动调试"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 底部提示 -->
                            <TextBlock FontSize="11" Foreground="#555" HorizontalAlignment="Center"
                                       Text="💡 打开项目后 AI 可以分析代码库并进行智能对话"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Col 4: Right Splitter -->
            <GridSplitter x:Name="RightSplitter" Grid.Column="4" Width="3" Background="#454545" HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" Visibility="Collapsed"/>

            <!-- ===== Col 5: Right AI Panel (collapsible) ===== -->
            <Border Grid.Column="5" Background="#252526"
                    Visibility="{Binding IsAIPanelVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- AI Panel Header -->
                    <Border Grid.Row="0" Background="#2d2d2d" Padding="10,6" BorderBrush="#454545" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💬 AI 对话" FontSize="12" FontWeight="Bold" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Chat.AIStatus}" FontSize="11" Foreground="#888"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                                <Button Content="≫" Width="24" Height="20" FontSize="14"
                                        Background="Transparent" Foreground="#888" BorderThickness="0"
                                        HorizontalAlignment="Right" Padding="0"
                                        Command="{Binding ToggleAIPanelCommand}" ToolTip="折叠 AI 面板"/>
                            </Grid>
                            <!-- 会话标签栏 -->
                            <ItemsControl ItemsSource="{Binding Sessions}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,4,2" Padding="6,3" CornerRadius="4" Cursor="Hand"
                                                Background="{Binding TabBackground}"
                                                BorderBrush="{Binding TabBorder}" BorderThickness="1"
                                                MouseLeftButtonDown="SessionTab_Click" Tag="{Binding Id}">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- 状态图标 -->
                                                <TextBlock Text="{Binding StatusIcon}" FontSize="10"
                                                           Foreground="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#d4d4d4" VerticalAlignment="Center"/>
                                                <Button Content="×" Width="16" Height="16" FontSize="10"
                                                        Background="Transparent" Foreground="#888" BorderThickness="0" Padding="0"
                                                        Margin="6,0,0,0" Cursor="Hand"
                                                        Click="SessionClose_Click" Tag="{Binding Id}"
                                                        ToolTip="关闭会话"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="+ 新对话" FontSize="10" Foreground="#569cd6" Background="Transparent"
                                    BorderThickness="0" Padding="2,2" HorizontalAlignment="Left" Cursor="Hand"
                                    Command="{Binding NewSessionCommand}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Chat Messages -->
                    <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ChatMessages" ItemsSource="{Binding Chat.Messages}"
                                      ItemContainerStyle="{StaticResource ChatMessageStyle}"/>
                    </ScrollViewer>

                    <!-- 当前文件引用 -->
                    <Border Grid.Row="2" Background="#252530" Padding="6,4" BorderBrush="#454545" BorderThickness="0,1,0,0"
                            Visibility="{Binding Chat.HasCurrentFiles, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="📎 当前引用文件" FontSize="10" Foreground="#888" Margin="0,0,0,3"/>
                            <ItemsControl ItemsSource="{Binding Chat.CurrentFiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#3a3a3a" CornerRadius="3" Padding="6,2" Margin="0,0,4,2" Cursor="Hand"
                                                MouseLeftButtonDown="FileRef_Click" Tag="{Binding .}" ToolTip="点击在编辑器中打开">
                                            <TextBlock FontSize="11" Foreground="#569cd6" FontFamily="Consolas,monospace">
                                                <Run Text="📄 "/><Run Text="{Binding ., Converter={x:Static conv:FileNameConverter.Instance}}"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- 待确认文件变更 -->
                    <Border x:Name="PendingChangesPanel" Grid.Row="2" Background="#2d2010" Padding="6,4" BorderBrush="#554020" BorderThickness="0,1,0,0"
                            Visibility="{Binding Chat.HasPendingChanges, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Chat.PendingChanges}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="6,4" Background="#3a3020" CornerRadius="4">
                                        <StackPanel>
                                            <!-- 第一行：文件名 + 操作按钮 -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="11" Foreground="#f0c040" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Run Text="{Binding ChangeLabel, Mode=OneWay}"/>
                                                </TextBlock>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock FontSize="11" Foreground="#d4d4d4" VerticalAlignment="Center"
                                                               FontFamily="Consolas,monospace" TextTrimming="CharacterEllipsis"
                                                               Text="{Binding FileName}"/>
                                                    <TextBlock Text="{Binding DiffSummary}" FontSize="10" Foreground="#aaa"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <Button Content="🔍 Diff" Width="50" Height="20" FontSize="9"
                                                            Background="#444" Foreground="#aaa" BorderThickness="0" Margin="8,0,0,0" Padding="0"
                                                            Click="ToggleDiff_Click" Tag="{Binding .}"
                                                            Visibility="{Binding HasDiffContent, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding CountdownText}" FontSize="10" Foreground="#888"
                                                               VerticalAlignment="Center" Margin="0,0,6,0"
                                                               Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"/>
                                                    <Button Content="采纳" Width="42" Height="22" FontSize="10"
                                                            Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" Padding="0"
                                                            Click="AcceptChange_Click" Tag="{Binding .}"/>
                                                    <Button Content="拒绝" Width="42" Height="22" FontSize="10"
                                                            Background="#5a1a1a" Foreground="#f0a0a0" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                                                            Click="RejectChange_Click" Tag="{Binding .}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Diff 预览区域（可折叠） -->
                                            <Border Margin="0,6,0,0" Background="#1e1e1e" BorderBrush="#444" BorderThickness="1"
                                                    CornerRadius="3" Padding="4"
                                                    Visibility="{Binding IsDiffExpanded, Converter={StaticResource BoolToVis}}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="代码差异预览" FontSize="10" Foreground="#888" Margin="0,0,0,4"/>
                                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding DiffLines}" FontFamily="Consolas,monospace" FontSize="11">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{Binding BackgroundColor}" Padding="4,1" CornerRadius="1">
                                                                    <TextBlock FontSize="11" FontFamily="Consolas,monospace">
                                                                        <Run Text="{Binding Prefix}" Foreground="#888"/>
                                                                        <Run Text="{Binding Text}" Foreground="#d4d4d4"/>
                                                                    </TextBlock>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- 终端命令沙箱确认（三段式内联UI：左侧偏好 | 中间摘要 | 右侧执行模式）-->
                    <Border x:Name="TerminalConsentsPanel" Grid.Row="4" Background="#1a2a30" Padding="6,4" BorderBrush="#305060" BorderThickness="0,1,0,0"
                            Visibility="{Binding Chat.HasTerminalConsents, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Chat.TerminalConsents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="6,4" Background="#253540" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 状态文本（非待处理时显示）-->
                                            <TextBlock Grid.Column="0" FontSize="11" Foreground="#6890a0" VerticalAlignment="Center" Margin="0,0,8,0"
                                                       Text="{Binding StatusDisplay}"
                                                       Visibility="{Binding IsNotPending, Converter={StaticResource BoolToVis}}"/>

                                            <!-- 左侧：审批偏好切换 -->
                                            <Button Grid.Column="0" FontSize="11" Foreground="#90c8e0" Background="#1e3a4a"
                                                    BorderThickness="1" BorderBrush="#306880" Padding="5,2"
                                                    Content="{Binding RememberDisplay}" ToolTip="点击切换：不再询问 / 每次询问"
                                                    Click="ToggleTerminalRemember_Click" Tag="{Binding .}"
                                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="#1e3a4a" BorderBrush="#306880" BorderThickness="1" CornerRadius="2" Padding="6,2">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{TemplateBinding Content}" Foreground="#90c8e0" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" ▼" Foreground="#5080a0" FontSize="8" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- 中间：命令摘要 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                                <TextBlock FontSize="12" Foreground="#d4d4d4" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" Text="{Binding Summary}"/>
                                            </StackPanel>

                                            <!-- 右侧：执行模式切换 -->
                                            <Button Grid.Column="2" FontSize="11" Foreground="#c0e0c0"
                                                    Background="{Binding ExecutionMode, Converter={StaticResource SandboxModeToBg}}"
                                                    BorderThickness="1" BorderBrush="#408060" Padding="5,2"
                                                    Content="{Binding ExecutionDisplay}" ToolTip="点击切换：沙箱运行 / 终端"
                                                    Click="ToggleTerminalExecMode_Click" Tag="{Binding .}"
                                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="#408060" BorderThickness="1" CornerRadius="2" Padding="6,2">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{TemplateBinding Content}" Foreground="#c0e0c0" FontSize="11" VerticalAlignment="Center"/>
                                                                <TextBlock Text=" ▼" Foreground="#60a080" FontSize="8" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- 拒绝按钮 -->
                                            <Button Grid.Column="3" Content="拒绝" Width="42" Height="22" FontSize="10"
                                                    Background="#5a1a1a" Foreground="#f0a0a0" BorderThickness="0" Padding="0" Margin="6,0,0,0"
                                                    Click="RejectTerminalConsent_Click" Tag="{Binding .}"
                                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"/>
                                            <!-- 执行按钮 -->
                                            <Button Grid.Column="4" Content="▶ 执行" Width="52" Height="22" FontSize="10"
                                                    Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                                                    Click="AcceptTerminalConsent_Click" Tag="{Binding .}"
                                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- 允许修改项目外文件确认 -->
                    <Border x:Name="ExternalEditConsentsPanel" Grid.Row="3" Background="#2d1020" Padding="6,4" BorderBrush="#552040" BorderThickness="0,1,0,0"
                            Visibility="{Binding Chat.HasExternalEditConsents, Converter={StaticResource BoolToVis}}">
                        <ItemsControl ItemsSource="{Binding Chat.ExternalEditConsents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2" Padding="6,4" Background="#3a2030" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="12" Foreground="#f0a0d0" VerticalAlignment="Center" Margin="0,0,8,0"
                                                       Text="{Binding Title}"/>
                                            <TextBlock Grid.Column="1" FontSize="11" Foreground="#d4d4d4" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" Text="{Binding Detail}"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <TextBlock Text="{Binding StatusDisplay}" FontSize="10" Foreground="#888"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Visibility="{Binding IsNotPending, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="允许" Width="42" Height="22" FontSize="10"
                                                        Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" Padding="0"
                                                        Click="AcceptExternalEdit_Click" Tag="{Binding .}"
                                                        Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"/>
                                                <Button Content="拒绝" Width="42" Height="22" FontSize="10"
                                                        Background="#5a1a1a" Foreground="#f0a0a0" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                                                        Click="RejectExternalEdit_Click" Tag="{Binding .}"
                                                        Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- 等待发送队列 -->
                    <Border Grid.Row="3" Background="#2a2530" Padding="8,6" BorderBrush="#554070" BorderThickness="0,1,0,0"
                            Visibility="{Binding Chat.HasPendingMessages, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⏳" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="12" Foreground="#d0b0f0" FontWeight="Bold">
                                    <Run Text="等待发送 · "/><Run Text="{Binding Chat.PendingMessageCount, Mode=OneWay}"/><Run Text=" 条消息"/>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding Chat.PendingMessages}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#353040" CornerRadius="3" Padding="6,3" Margin="0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 查看模式 -->
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                                                Visibility="{Binding IsViewMode, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding PreviewText}" FontSize="11"
                                                                   Foreground="#ccc" TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center" MaxWidth="200"/>
                                                        <TextBlock Text="{Binding TimeText}" FontSize="10"
                                                                   Foreground="#777" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <!-- 编辑模式 -->
                                                    <TextBox Grid.Column="0" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                                             Background="#2a2030" Foreground="#d0b0f0" BorderThickness="0"
                                                             FontSize="11" Padding="4,2" VerticalAlignment="Center"
                                                             TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="60"
                                                             KeyDown="PendingMessageEditBox_KeyDown"
                                                             Tag="{Binding}"/>
                                                    <!-- 操作按钮 -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <!-- 编辑/确认按钮 -->
                                                        <Button Width="24" Height="22" Background="#3a3050" Foreground="#c0a0f0"
                                                                BorderThickness="0" Padding="0" FontSize="11" Cursor="Hand"
                                                                ToolTip="编辑" Click="PendingMessageEdit_Click"
                                                                Tag="{Binding}">
                                                            <TextBlock Text="{Binding IsEditing, Converter={StaticResource BoolToEditIcon}}"
                                                                       FontSize="11"/>
                                                        </Button>
                                                        <!-- 删除按钮 -->
                                                        <Button Width="24" Height="22" Background="#4a3040" Foreground="#f0a0a0"
                                                                BorderThickness="0" Padding="0" FontSize="11" Cursor="Hand" Margin="2,0,0,0"
                                                                ToolTip="移除此消息" Click="PendingMessageDelete_Click"
                                                                Tag="{Binding Id}">
                                                            <TextBlock Text="✕" FontSize="11"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <Button Grid.Column="2" Content="✕ 清空" Background="#4a3040" Foreground="#f0a0a0"
                                    BorderThickness="0" Padding="6,4" FontSize="10" Margin="8,0,0,0" Cursor="Hand"
                                    Click="ClearPendingQueue_Click"/>
                        </Grid>
                    </Border>

                    <!-- 待办列表 -->
                    <Expander Grid.Row="4" IsExpanded="{Binding Chat.IsTodoExpanded}"
                              Background="#2a2a2a" Foreground="#d4d4d4" BorderThickness="0">
                        <Expander.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="📋 待办列表" FontSize="12" FontWeight="Bold" Foreground="#e0c040" VerticalAlignment="Center"/>
                                        <TextBlock FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Run Text="("/><Run Text="{Binding Chat.PlanCompletedCount, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding Chat.PlanTotalCount, Mode=OneWay}"/><Run Text=" 项)"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- 采纳/拒绝 快捷按钮 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="✅ 采纳" Width="52" Height="22" FontSize="10"
                                                Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" Padding="0"
                                                Command="{Binding ConfirmPlanCommand}" ToolTip="采纳AI建议并执行" Margin="0,0,4,0"/>
                                        <Button Content="❌ 拒绝" Width="52" Height="22" FontSize="10"
                                                Background="#5a3030" Foreground="#f0a0a0" BorderThickness="0" Padding="0"
                                                Command="{Binding CancelPlanCommand}" ToolTip="拒绝AI建议"/>
                                    </StackPanel>
                                </Grid>
                                <!-- 进度条 -->
                                <Border Grid.Row="1" Background="#3a3a3a" CornerRadius="2" Height="4" Margin="0,4,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="{Binding Chat.TodoProgressBarWidth, Converter={StaticResource PercentageToWidth}}"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#28a745" CornerRadius="2" MinWidth="4"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Expander.Header>
                        <Border Background="#2d2d2d" MinHeight="40" MaxHeight="200" Padding="8,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- 筛选按钮行 -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="全部" Width="40" Height="20" FontSize="9" Padding="0" Margin="0,0,2,0"
                                            Background="#3a6a3a" Foreground="#a0d0a0" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding SetTodoFilterCommand}"
                                            CommandParameter="{x:Static vm:TodoFilter.All}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Chat.TodoFilterMode}" Value="All">
                                                        <Setter Property="Background" Value="#28a745"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="待办" Width="40" Height="20" FontSize="9" Padding="0" Margin="0,0,2,0"
                                            Background="#3a3a3a" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding SetTodoFilterCommand}"
                                            CommandParameter="{x:Static vm:TodoFilter.Pending}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Chat.TodoFilterMode}" Value="Pending">
                                                        <Setter Property="Background" Value="#fd7e14"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="进行中" Width="52" Height="20" FontSize="9" Padding="0" Margin="0,0,2,0"
                                            Background="#3a3a3a" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding SetTodoFilterCommand}"
                                            CommandParameter="{x:Static vm:TodoFilter.InProgress}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Chat.TodoFilterMode}" Value="InProgress">
                                                        <Setter Property="Background" Value="#60c0ff"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="已完成" Width="52" Height="20" FontSize="9" Padding="0" Margin="0,0,2,0"
                                            Background="#3a3a3a" Foreground="#888" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding SetTodoFilterCommand}"
                                            CommandParameter="{x:Static vm:TodoFilter.Completed}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Chat.TodoFilterMode}" Value="Completed">
                                                        <Setter Property="Background" Value="#6c757d"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Width="4"/>
                                    <Button Content="🗑 清除已完成" Height="20" FontSize="9" Padding="4,0"
                                            Background="#5a3030" Foreground="#f0a0a0" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding ClearCompletedTodosCommand}"
                                            ToolTip="移除所有已完成和已取消的待办"/>
                                </StackPanel>
                                <!-- 手动添加待办行 -->
                                <Grid Grid.Row="1" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NewTodoInput" Grid.Column="0"
                                             Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                                             Padding="6,3" FontSize="11" Height="24"
                                             VerticalContentAlignment="Center"
                                             ToolTip="输入新待办项内容"
                                             PreviewKeyDown="NewTodoInput_KeyDown"/>
                                    <Button Grid.Column="1" Content="＋ 添加" Height="24" FontSize="10" Padding="6,0"
                                            Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" Cursor="Hand"
                                            Click="AddTodo_Click" Margin="4,0,0,0"
                                            ToolTip="手动添加一条待办项"/>
                                </Grid>
                                <!-- 待办列表 -->
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                                    <ItemsControl ItemsSource="{Binding Chat.FilteredTodos}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1" Cursor="Hand"
                                                      ToolTip="点击切换状态: 待办 → 进行中 → 完成 → 取消">
                                                    <Grid.InputBindings>
                                                        <MouseBinding Gesture="LeftClick"
                                                                      Command="{Binding DataContext.ToggleTodoCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Grid.InputBindings>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 状态指示点 -->
                                                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4"
                                                            Background="{Binding StatusColor}" Margin="0,0,6,0"
                                                            VerticalAlignment="Center"/>
                                                    <!-- 内容 -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <!-- 分类标签 -->
                                                        <Border Background="{Binding CategoryColor}" CornerRadius="2"
                                                                Padding="3,1" HorizontalAlignment="Left" Margin="0,0,0,2"
                                                                Visibility="{Binding HasCategory, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding CategoryDisplay}" FontSize="7"
                                                                       Foreground="White"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Content}" FontSize="11"
                                                                   Foreground="#d4d4d4" TextWrapping="Wrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                            <Setter Property="Foreground" Value="#666"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="cancelled">
                                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                            <Setter Property="Foreground" Value="#886666"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Expander>

                    <!-- 开发计划 -->
                    <Expander Grid.Row="5" IsExpanded="{Binding Chat.IsPlanExpanded}"
                              Background="#2a2a2a" Foreground="#d4d4d4" BorderThickness="0"
                              Visibility="{Binding Chat.HasPlan, Converter={StaticResource BoolToVis}}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📐 开发计划" FontSize="12" FontWeight="Bold" Foreground="#60c0ff" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Chat.PlanTitle}" FontSize="11" Foreground="#aaa"
                                           VerticalAlignment="Center" Margin="8,0,0,0" MaxWidth="160" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Expander.Header>
                        <Border Background="#252530" Padding="8">
                            <StackPanel>
                                <!-- 计划详情面板 -->
                                <Border Margin="0,0,0,6" Padding="10,8" Background="#1e1e2e" CornerRadius="4"
                                        Visibility="{Binding Chat.PlanDetailExpanded, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="📋 计划详情" FontSize="12" FontWeight="Bold" Foreground="#60c0ff" VerticalAlignment="Center"/>
                                            <Button Content="✕ 收起" Background="Transparent" Foreground="#888"
                                                    BorderThickness="0" Padding="6,2" FontSize="10" Cursor="Hand"
                                                    Command="{Binding HidePlanDetailCommand}" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="180">
                                            <TextBlock Text="{Binding Chat.PlanDetail}" FontSize="11" Foreground="#ccc"
                                                       TextWrapping="Wrap" FontFamily="Consolas, monospace"/>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#3a3a3a" CornerRadius="4" Height="18" Margin="0,0,8,0">
                                        <Border Background="#007acc" CornerRadius="4" HorizontalAlignment="Left"
                                                Width="{Binding Chat.PlanProgress, Mode=OneWay}" Height="18">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Chat.PlanProgress}" Value="100">
                                                            <Setter Property="Background" Value="#4ec9b0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Chat.PlanProgressText, Mode=OneWay}"
                                               FontSize="12" Foreground="#60c0ff" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="140">
                                    <ItemsControl ItemsSource="{Binding Chat.Todos}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0" Width="70"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Content}"
                                                               FontSize="11" Foreground="#ccc" TextWrapping="Wrap" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                        <Setter Property="Foreground" Value="#666"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0"
                                            Visibility="{Binding Chat.IsPlanPending, Converter={StaticResource BoolToVis}}">
                                    <Button Content="✅ 确认并执行" Background="#007acc" Foreground="White"
                                            BorderThickness="0" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Command="{Binding ConfirmPlanCommand}"/>
                                    <Button Content="📋 查看详情" Background="#555" Foreground="#ddd"
                                            BorderThickness="0" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Command="{Binding ShowPlanDetailCommand}"/>
                                    <Button Content="🔄 重新规划" Background="#555" Foreground="#ddd"
                                            BorderThickness="0" Padding="8,4" Margin="0,0,4,0" FontSize="11"
                                            Command="{Binding ReplanCommand}"/>
                                    <Button Content="❌ 放弃" Background="#5a3030" Foreground="#f0a0a0"
                                            BorderThickness="0" Padding="8,4" FontSize="11"
                                            Command="{Binding CancelPlanCommand}"/>
                                </StackPanel>
                                <!-- 执行中状态 -->
                                <StackPanel Visibility="{Binding Chat.IsPlanExecuting, Converter={StaticResource BoolToVis}}" Margin="0,6,0,0">
                                    <Border Background="#1a2a3a" CornerRadius="4" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock FontSize="11" Foreground="#60c0ff" TextWrapping="Wrap">
                                                <Run Text="⏳ AI 正在按计划执行 — 进度 "/>
                                                <Run Text="{Binding Chat.PlanProgressText, Mode=OneWay}" FontWeight="Bold" Foreground="#4ec9b0"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Chat.CurrentExecutingStep}" FontSize="10" Foreground="#888"
                                                       TextWrapping="Wrap" Margin="0,3,0,0"
                                                       Visibility="{Binding Chat.HasCurrentStep, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- 算法库 -->
                    <Expander Grid.Row="8" IsExpanded="{Binding Chat.IsAlgorithmExpanded}"
                              Background="#2a2a2a" Foreground="#d4d4d4" BorderThickness="0">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧮 算法库" FontSize="12" FontWeight="Bold" Foreground="#569cd6" VerticalAlignment="Center"/>
                                <TextBlock FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Run Text="("/><Run Text="{Binding Chat.Algorithms.Count, Mode=OneWay}"/><Run Text=" 个)"/>
                                </TextBlock>
                            </StackPanel>
                        </Expander.Header>
                        <Border Background="#2d2d2d" MinHeight="40" MaxHeight="200" Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Chat.Algorithms}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1" Padding="6,3" Background="#333" CornerRadius="3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding DisplayText}" FontSize="12" Foreground="#569cd6" FontFamily="Consolas, monospace"/>
                                                        <TextBlock Text="{Binding SubText}" FontSize="10" Foreground="#888" Margin="0,1,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Description}" FontSize="10" Foreground="#666"
                                                               VerticalAlignment="Center" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Expander>

                    <!-- 终端命令执行输出 -->
                    <Expander Grid.Row="7" IsExpanded="{Binding Chat.IsTerminalExpanded}"
                              Background="#2a2a2a" Foreground="#d4d4d4" BorderThickness="0"
                              Visibility="{Binding Chat.HasTerminalOutputs, Converter={StaticResource BoolToVis}}">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="🖥 终端输出" FontSize="12" FontWeight="Bold" Foreground="#60c0ff" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Run Text="("/><Run Text="{Binding Chat.TerminalOutputs.Count, Mode=OneWay}"/><Run Text=" 条)"/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- 危险命令确认偏好下拉 -->
                                <ComboBox Grid.Column="2" Width="90" Height="22" FontSize="11"
                                          SelectedValue="{Binding Chat.TerminalConfirmPreference, Mode=TwoWay}"
                                          SelectedValuePath="Tag"
                                          Background="#3a3a3a" Foreground="#c0c0c0" BorderThickness="0"
                                          VerticalAlignment="Center" Margin="8,0,0,0">
                                    <ComboBoxItem Content="每次询问" Tag="AskEveryTime"/>
                                    <ComboBoxItem Content="不再询问" Tag="AlwaysAllow"/>
                                </ComboBox>
                            </Grid>
                        </Expander.Header>
                        <Border Background="#1e1e24" MinHeight="40" MaxHeight="200" Padding="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Chat.TerminalOutputs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1" Padding="6,4" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#252530"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                <Setter Property="Background" Value="#3a3020"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsRejected}" Value="True">
                                                                <Setter Property="Background" Value="#3a2020"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" FontSize="11" Foreground="#569cd6"
                                                                   FontFamily="Consolas,monospace" TextTrimming="CharacterEllipsis"
                                                                   Text="{Binding CommandDisplay}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#888"/>
                                                                    <Setter Property="Text" Value="{Binding ExitDisplay}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                            <Setter Property="Foreground" Value="#f0a060"/>
                                                                            <Setter Property="Text" Value="⏳ 等待确认..."/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsRejected}" Value="True">
                                                                            <Setter Property="Foreground" Value="#f06060"/>
                                                                            <Setter Property="Text" Value="🚫 已拒绝"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                    <!-- 非等待状态：显示输出 -->
                                                    <TextBox Text="{Binding Output, Mode=OneWay}" FontSize="10"
                                                             Foreground="#a0a0a0" FontFamily="Consolas,monospace"
                                                             IsReadOnly="True" BorderThickness="0"
                                                             Background="#1a1a24" Margin="0,4,0,0" Padding="6,4"
                                                             TextWrapping="Wrap" MaxHeight="120"
                                                             VerticalScrollBarVisibility="Auto"
                                                             Visibility="{Binding IsNotPending, Converter={StaticResource BoolToVis}}"/>
                                                    <!-- 等待确认：显示 Accept/Reject 按钮 -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                                Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="⚠️ 此命令存在风险，是否允许执行？" FontSize="11"
                                                                   Foreground="#f0a060" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                        <Button Content="✓ 允许" Width="56" Height="24" FontSize="11"
                                                                Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" Padding="0"
                                                                Click="AcceptTerminalCommand_Click" Tag="{Binding .}"/>
                                                        <Button Content="✕ 拒绝" Width="56" Height="24" FontSize="11"
                                                                Background="#5a1a1a" Foreground="#f0a0a0" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                                                                Click="RejectTerminalCommand_Click" Tag="{Binding .}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Expander>

                    <!-- 待更新文件 -->
                    <Expander Grid.Row="6" IsExpanded="{Binding Chat.IsFileChangesExpanded}"
                              Background="#2a2a2a" Foreground="#d4d4d4" BorderThickness="0">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁 文件变更" FontSize="12" FontWeight="Bold" Foreground="#4ec9b0" VerticalAlignment="Center"/>
                                <TextBlock FontSize="11" Foreground="#888" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Run Text="("/><Run Text="{Binding Chat.FileChanges.Count, Mode=OneWay}"/><Run Text=" 个)"/>
                                </TextBlock>
                            </StackPanel>
                        </Expander.Header>
                        <Border Background="#2d2d2d" MinHeight="40" MaxHeight="150" Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Chat.FileChanges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,1" Padding="4,2" Background="#333" CornerRadius="3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ChangeIcon}" FontSize="11" Foreground="#4ec9b0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#d4d4d4"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0" FontFamily="Consolas, monospace"/>
                                                    </StackPanel>
                                                    <!-- 恢复按钮（仅有关联 checkpoint 时显示） -->
                                                    <Button Grid.Column="1" Content="↩ 恢复"
                                                            Visibility="{Binding HasCheckpoint, Converter={StaticResource BoolToVis}}"
                                                            Background="#3a2a1a" Foreground="#e2c08d" BorderThickness="0"
                                                            Padding="6,2" FontSize="10" Cursor="Hand"
                                                            ToolTip="恢复到修改前的 checkpoint 快照"
                                                            Tag="{Binding}"
                                                            Click="FileChangeRestore_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Expander>

                    <!-- ===== 未登录提示区（未登录时显示） ===== -->
                    <Border Grid.Row="9" Grid.RowSpan="3" Background="#1e1e1e" Padding="24,20"
                            Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🔑" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="登录以使用 AI 功能" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#e0e0e0" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="登录后即可使用 AI 对话、代码生成、智能补全等功能"
                                       FontSize="12" Foreground="#888" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,0,0,16"/>
                            <Button Content="🔑  登  录" Width="140" Height="36"
                                    Background="#007acc" Foreground="White" BorderThickness="0"
                                    FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                                    Click="LoginPrompt_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <TextBlock Text="如果没有账号，请联系超级管理员（开发者）开通"
                                       FontSize="10" Foreground="#555" HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Chat Input -->
                    <Grid Grid.Row="9"
                          Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 余额状态栏 -->
                        <Border x:Name="ChatBalanceBar" Grid.Row="0" Padding="10,5"
                                Background="#2a2a2a" BorderBrush="#454545" BorderThickness="0,0,0,1"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Padding="5,2" CornerRadius="3" Background="#3a3a3a" Margin="0,0,8,0">
                                    <TextBlock x:Name="ChatBalanceModelName" Text="" FontSize="10" Foreground="#8cc8ff"/>
                                </Border>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="ChatBalanceSessionCost" Text="" FontSize="10" Foreground="#888" Margin="0,0,10,0"/>
                                    <Border Width="60" Height="5" CornerRadius="3" Background="#3a3a3a" Margin="0,0,6,0">
                                        <Border x:Name="ChatBalanceProgressBar" Width="0" CornerRadius="3" Background="#4ec9b0" HorizontalAlignment="Left"/>
                                    </Border>
                                    <TextBlock x:Name="ChatBalancePercentText" Text="" FontSize="9" Foreground="#888"/>
                                </StackPanel>
                                <TextBlock x:Name="ChatBalanceWarningText" Grid.Column="2" FontSize="9"
                                           Foreground="#fd7e14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                            </Grid>
                        </Border>

                        <!-- 代码引用标签（粘贴检测结果） -->
                        <Border Grid.Row="1" Background="#1e3a2a" Padding="6,3" BorderBrush="#2a5a3a" BorderThickness="0,1,0,0"
                                Visibility="{Binding HasCodeRefs, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔗" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ItemsControl ItemsSource="{Binding CodeRefChips}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2a4a3a" CornerRadius="3" Padding="5,2" Margin="0,0,6,0"
                                                    Cursor="Hand" ToolTip="点击定位到代码位置"
                                                    MouseLeftButtonDown="CodeRefChip_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📝" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock FontSize="10" Foreground="#4ec9b0" VerticalAlignment="Center">
                                                        <Run Text="{Binding FileName}"/>
                                                        <Run Text=":"/>
                                                        <Run Text="{Binding Line, StringFormat='L{0}'}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="  ✕" FontSize="10" Foreground="#f0a0a0"
                                                               VerticalAlignment="Center" Cursor="Hand"
                                                               MouseLeftButtonDown="CodeRefDismiss_Click" ToolTip="关闭"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- TextBox 输入区 + Watermark 提示 -->
                        <Border Grid.Row="2" BorderBrush="#454545" BorderThickness="0,1,0,0" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <!-- Watermark 占位提示：仅在无输入且未聚焦时显示 -->
                                    <TextBlock x:Name="ChatWatermark"
                                               Text="规划编程，@ 添加上下文，/ 使用命令"
                                               FontSize="13" Foreground="#666"
                                               Padding="8,6" IsHitTestVisible="False"
                                               VerticalAlignment="Top"/>
                                    <TextBox x:Name="ChatInputBox"
                                             Text="{Binding Chat.InputText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                                             Padding="8,6" FontSize="13" TextWrapping="Wrap"
                                             AcceptsReturn="True" MinHeight="60" MaxHeight="140"
                                             GotFocus="ChatInputBox_GotFocus"
                                             LostFocus="ChatInputBox_LostFocus"
                                             TextChanged="ChatInputBox_TextChanged"/>
                                </Grid>

                                <!-- 输入矫正提示 -->
                                <TextBlock Grid.Row="1" Text="{Binding InputCorrectionHint}"
                                           FontSize="11" Foreground="#e8c050" Margin="8,2,8,0"
                                           Visibility="{Binding InputCorrectionHint, Converter={StaticResource HasContentToVis}}"
                                           ToolTip="输入文本已被自动矫正，点击查看详情"/>

                                <!-- @ 提及弹窗 -->
                                <Popup x:Name="AtMentionPopup"
                                       IsOpen="{Binding IsAtMentionPopupOpen}"
                                       PlacementTarget="{Binding ElementName=ChatInputBox}"
                                       Placement="Top"
                                       StaysOpen="False"
                                       PopupAnimation="Fade"
                                       AllowsTransparency="True">
                                    <Border Background="#2a2a2a" BorderBrush="#4ec9b0" BorderThickness="1"
                                            CornerRadius="4" MaxHeight="240" MinWidth="260" MaxWidth="280">
                                        <DockPanel>
                                            <Border DockPanel.Dock="Top" Background="#1e1e1e" Padding="6,4"
                                                    BorderBrush="#333" BorderThickness="0,0,0,1">
                                                <TextBlock FontSize="11" Foreground="#888">
                                                    <Run Text="@"/>
                                                    <Run Text="{Binding AtMentionQuery}"/>
                                                    <Run Text=" — 搜索文件/文件夹"/>
                                                </TextBlock>
                                            </Border>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding AtMentionResults}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8,5" Background="Transparent" Cursor="Hand"
                                                                    MouseLeftButtonDown="AtMentionItem_Click">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Icon}" FontSize="12"
                                                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                                                   Foreground="#d4d4d4" FontFamily="Consolas,monospace"/>
                                                                        <TextBlock Text="{Binding RelativePath}" FontSize="10"
                                                                                   Foreground="#888" TextTrimming="CharacterEllipsis"
                                                                                   MaxWidth="220"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding TypeLabel}" FontSize="10"
                                                                               Foreground="#666" VerticalAlignment="Center"
                                                                               Margin="8,0,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Border>
                                </Popup>

                                <!-- / 斜杠命令弹窗 -->
                                <Popup x:Name="SlashCommandPopup"
                                       IsOpen="{Binding IsSlashCommandPopupOpen}"
                                       PlacementTarget="{Binding ElementName=ChatInputBox}"
                                       Placement="Top"
                                       StaysOpen="False"
                                       PopupAnimation="Fade"
                                       AllowsTransparency="True">
                                    <Border Background="#2a2a2a" BorderBrush="#c0a000" BorderThickness="1"
                                            CornerRadius="4" MaxHeight="300" MinWidth="320" MaxWidth="380">
                                        <DockPanel>
                                            <Border DockPanel.Dock="Top" Background="#1e1e1e" Padding="6,4"
                                                    BorderBrush="#333" BorderThickness="0,0,0,1">
                                                <TextBlock FontSize="11" Foreground="#888">
                                                    <Run Text="/"/>
                                                    <Run Text="{Binding SlashCommandQuery}"/>
                                                    <Run Text=" — 内置命令"/>
                                                </TextBlock>
                                            </Border>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding SlashCommandResults}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8,6" Background="Transparent" Cursor="Hand"
                                                                    MouseLeftButtonDown="SlashCommandItem_Click">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="14"
                                                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                    <StackPanel Grid.Column="1">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Command}" FontSize="13"
                                                                                       Foreground="#e8c050" FontFamily="Consolas,monospace"
                                                                                       FontWeight="Bold"/>
                                                                            <TextBlock Text="{Binding Label}" FontSize="12"
                                                                                       Foreground="#d4d4d4" Margin="10,0,0,0"/>
                                                                        </StackPanel>
                                                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                                                   Foreground="#888" Margin="0,1,0,0"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding Category}" FontSize="10"
                                                                               Foreground="#555" VerticalAlignment="Center"
                                                                               Margin="8,0,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- File Attachments -->
                    <Border Grid.Row="10" Background="#252530" Padding="8,4" BorderBrush="#454545" BorderThickness="0,1,0,0"
                            Visibility="{Binding Chat.HasAttachments, Converter={StaticResource BoolToVis}}"
                            x:Name="FileAttachmentsRow">
                        <ItemsControl ItemsSource="{Binding Chat.Attachments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2a2a3a" CornerRadius="4" Padding="6,3" Margin="0,0,5,3"
                                            BorderBrush="#454565" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#d4d4d4"
                                                           FontFamily="Consolas,monospace" MaxWidth="160" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SizeDisplay}" FontSize="9" Foreground="#888"/>
                                            </StackPanel>
                                            <Button Width="18" Height="18" FontSize="10" Padding="0"
                                                    Background="#4a3030" Foreground="#f0a0a0" BorderThickness="0"
                                                    Content="✕" ToolTip="移除附件" Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding .}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Send Bar (Qoder风格) -->
                    <Border Grid.Row="11" Padding="10,8" BorderBrush="#454545" BorderThickness="0,1,0,0" Background="#1e1e1e"
                            Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 计划建议卡片（内联替代 MessageBox） -->
                            <Border Grid.Row="0" Background="#1a2a3a" CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                    BorderBrush="#60c0ff" BorderThickness="1"
                                    Visibility="{Binding Chat.IsPlanSuggestionVisible, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontSize="12" Foreground="#e0e0e0" TextWrapping="Wrap" Margin="0,0,0,4">
                                            <Run Text="&#x1f4cb; "/><Run Text="{Binding Chat.PlanSuggestionText}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="#888" Text="点击「生成计划」让 AI 生成详细步骤供审阅，或「跳过」直接开始"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Button Content="{Binding Chat.PlanSuggestionAcceptText}" Background="#007acc" Foreground="White"
                                                BorderThickness="0" Padding="8,5" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding AcceptPlanSuggestionCommand}"/>
                                        <Button Content="{Binding Chat.PlanSuggestionSkipText}" Background="#555" Foreground="#ddd"
                                                BorderThickness="0" Padding="8,5" FontSize="11"
                                                Command="{Binding SkipPlanSuggestionCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 第一行：上下文操作 + 编译/部署按钮 -->
                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 左侧：模式/模型选择 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <!-- 模式选择 -->
                                    <Border Background="#2d2d2d" CornerRadius="4" Padding="0" Margin="0,0,4,0"
                                            BorderBrush="#454545" BorderThickness="1">
                                        <ComboBox x:Name="ChatModeBox" ItemsSource="{Binding AvailableModes}"
                                                  SelectedValue="{Binding Chat.ChatMode}"
                                                  SelectedValuePath="Id" DisplayMemberPath="Name"
                                                  Background="Transparent" Foreground="#d4d4d4" FontSize="12"
                                                  Width="72" Height="26" VerticalContentAlignment="Center"
                                                  BorderThickness="0"
                                                  SelectionChanged="ChatModeBox_SelectionChanged"/>
                                    </Border>
                                    <!-- 模型选择 -->
                                    <Border Background="#2d2d2d" CornerRadius="4" Padding="0" Margin="0,0,4,0"
                                            BorderBrush="#454545" BorderThickness="1">
                                        <ComboBox x:Name="ChatProviderBox"
                                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                                  Background="Transparent" Foreground="#d4d4d4" FontSize="12"
                                                  Width="80" Height="26" VerticalContentAlignment="Center"
                                                  BorderThickness="0"
                                                  SelectionChanged="ChatProviderBox_SelectionChanged"/>
                                    </Border>
                                    <Border Background="#2d2d2d" CornerRadius="4" Padding="0"
                                            BorderBrush="#454545" BorderThickness="1">
                                        <ComboBox x:Name="ChatModelBox"
                                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                                  Background="Transparent" Foreground="#d4d4d4" FontSize="12"
                                                  Width="140" Height="26" VerticalContentAlignment="Center"
                                                  BorderThickness="0"
                                                  SelectionChanged="ChatModelBox_SelectionChanged"/>
                                    </Border>
                                    <!-- 分隔 -->
                                    <Border Width="1" Background="#454545" Margin="8,2"/>
                                    <!-- 上下文按钮 -->
                                    <Button Width="26" Height="26" FontSize="13" Padding="0"
                                            Background="#2d2d2d" Foreground="#aaa" BorderThickness="1"
                                            BorderBrush="#454545" Content="📎" ToolTip="附加文件到对话" Cursor="Hand"
                                            Command="{Binding AttachFilesCommand}" Margin="0,0,4,0"/>
                                    <Button Width="26" Height="26" FontSize="13" Padding="0"
                                            Background="#2d2d2d" Foreground="#555" BorderThickness="1"
                                            BorderBrush="#454545" Content="🖼" ToolTip="附加图片（即将支持）" Cursor="Hand"
                                            IsEnabled="False" Margin="0,0,4,0"/>
                                </StackPanel>
                                <!-- 右侧：编译打包按钮 -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding BuildLanguageDisplay}" Foreground="#4ec9b0" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Content="🔨" Width="26" Height="26" FontSize="11" Padding="0"
                                            Background="#2d3d2d" Foreground="#a0d0a0" BorderThickness="0"
                                            Command="{Binding BuildCommand}" Margin="0,0,2,0"
                                            ToolTip="编译项目" Cursor="Hand"/>
                                    <Button Content="📦" Width="26" Height="26" FontSize="11" Padding="0"
                                            Background="#3d352d" Foreground="#d0c0a0" BorderThickness="0"
                                            Command="{Binding PackageCommand}" Margin="0,0,2,0"
                                            ToolTip="打包项目" Cursor="Hand"/>
                                    <Button Content="🚀" Width="26" Height="26" FontSize="11" Padding="0"
                                            Background="#2d3520" Foreground="#e0c060" BorderThickness="0"
                                            Command="{Binding GitPushCommand}" Margin="0,0,2,0"
                                            ToolTip="Git 推送" Cursor="Hand"/>
                                    <Button Content="⚙" Width="26" Height="26" FontSize="11" Padding="0"
                                            Background="#2d2d2d" Foreground="#888" BorderThickness="0"
                                            Command="{Binding GitSettingsCommand}" ToolTip="Git 配置" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>

                            <!-- 第二行：上下文用量 + 压缩/新对话 -->
                            <Border Grid.Row="2" Background="#252526" CornerRadius="4" Padding="6,4" Margin="0,2,0,2"
                                    BorderBrush="#3a3a3a" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 上下文用量进度条 -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="上下文:" Foreground="#888" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding Chat.ContextUsageText}" Foreground="#ccc" FontSize="10"
                                                   VerticalAlignment="Center" FontFamily="Consolas"/>
                                    </StackPanel>
                                    <!-- 进度条 -->
                                    <Grid Grid.Column="1" Margin="4,0">
                                        <Border Background="#3a3a3a" CornerRadius="3" Height="6" VerticalAlignment="Center">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding Chat.ContextUsagePercent, Converter={StaticResource PercentageToWidth}}"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{Binding Chat.ContextUsageColor}" CornerRadius="3"
                                                        MinWidth="4"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="🔄 压缩对话" Height="22" FontSize="10" Padding="6,0"
                                                Background="#2d4a2d" Foreground="#a0d0a0" BorderThickness="0"
                                                Command="{Binding CompressChatCommand}"
                                                IsEnabled="{Binding Chat.CanCompress}"
                                                ToolTip="使用 LLM 智能压缩对话历史，精简上下文" Cursor="Hand" Margin="0,0,4,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Chat.IsCompressing}" Value="True">
                                                            <Setter Property="Content" Value="⏳ 压缩中..."/>
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Background" Value="#4a4a2d"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="➕ 新对话" Height="22" FontSize="10" Padding="6,0"
                                                Background="#2d2d3a" Foreground="#a0a0d0" BorderThickness="0"
                                                Command="{Binding NewChatCommand}"
                                                ToolTip="创建新会话，刷新上下文" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 第三行：发送操作（与输入框关联提示） -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <Button x:Name="VoiceBtn" Content="🎤" Width="28" Height="28"
                                        Background="#2d2d2d" Foreground="#aaa" BorderThickness="0" FontSize="13"
                                        ToolTip="语音输入" Cursor="Hand"
                                        Click="VoiceBtn_Click" Margin="0,0,6,0"/>
                                <Button x:Name="StopBtn" Content="■ 停止生成" Width="68" Height="28"
                                        Background="#8b0000" Foreground="#f0a0a0" BorderThickness="0" FontSize="11"
                                        Command="{Binding StopCommand}" Visibility="Collapsed"/>
                                <Button x:Name="SendBtn" Content="发送" Width="62" Height="28"
                                        Background="#007acc" Foreground="White" BorderThickness="0" FontSize="12"
                                        FontWeight="SemiBold" Cursor="Hand"
                                        Command="{Binding SendMessageCommand}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ====== Row 2: Bottom Panel (标签化: 终端 | 日志) ====== -->
        <Grid Grid.Row="2" Visibility="{Binding IsBottomVisible, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="3"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>
            <GridSplitter Grid.Row="0" Height="3" Background="#454545" HorizontalAlignment="Stretch"/>

            <!-- Tab Headers -->
            <Border Grid.Row="1" Background="#252526" BorderBrush="#454545" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="8,0">
                        <Button Content="🖥 终端" Padding="10,6" Background="Transparent" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="12" Cursor="Hand"
                                Command="{Binding SwitchBottomTabCommand}" CommandParameter="terminal">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTerminalTab}" Value="True">
                                            <Setter Property="BorderBrush" Value="#007acc"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                            <Setter Property="Foreground" Value="#ffffff"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="📋 日志" Padding="10,6" Background="Transparent" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="12" Cursor="Hand"
                                Command="{Binding SwitchBottomTabCommand}" CommandParameter="log">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLogTab}" Value="True">
                                            <Setter Property="BorderBrush" Value="#007acc"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                            <Setter Property="Foreground" Value="#ffffff"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🌐 预览" Padding="10,6" Background="Transparent" Foreground="#d4d4d4"
                                BorderThickness="0" FontSize="12" Cursor="Hand"
                                Command="{Binding SwitchBottomTabCommand}" CommandParameter="preview">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPreviewTab}" Value="True">
                                            <Setter Property="BorderBrush" Value="#007acc"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                            <Setter Property="Foreground" Value="#ffffff"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <Button Content="✕" Width="28" Background="Transparent" Foreground="#888"
                            BorderThickness="0" FontSize="12" HorizontalAlignment="Right"
                            Command="{Binding SwitchBottomTabCommand}" CommandParameter="" ToolTip="关闭面板"/>
                </Grid>
            </Border>

            <!-- Terminal Tab -->
            <Border Grid.Row="2" Background="#1e1e1e"
                    Visibility="{Binding IsTerminalTab, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="TerminalOutput" Grid.Row="0"
                             Text="{Binding Terminal.TerminalOutput, Mode=OneWay}"
                             Background="#1e1e1e" Foreground="#d4d4d4"
                             FontFamily="Consolas, monospace" FontSize="13"
                             IsReadOnly="True" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                    <Grid Grid.Row="1" Background="#2d2d2d">
                        <TextBox x:Name="TerminalInputBox" Background="#2d2d2d" Foreground="#d4d4d4"
                                 FontFamily="Consolas, monospace" FontSize="13"
                                 BorderThickness="0" Padding="8,4"
                                 PreviewKeyDown="TerminalInput_KeyDown"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Log Tab -->
            <Border Grid.Row="2" Background="#1e1e1e"
                    Visibility="{Binding IsLogTab, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <ListBox x:Name="LogListBox" ItemsSource="{Binding Log.Entries}"
                             Background="#1e1e1e" Foreground="#aaa"
                             FontFamily="Consolas, monospace" FontSize="12"
                             BorderThickness="0" SelectionMode="Extended"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#aaa"/>
                                <Setter Property="Padding" Value="8,2"/>
                                <Setter Property="IsTabStop" Value="False"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    <Button Content="清空日志" Width="70" Background="#5a3030" Foreground="#f0a0a0"
                            BorderThickness="0" FontSize="11" Padding="4,2"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8"
                            Click="ClearLog_Click"/>
                </Grid>
            </Border>

            <!-- Preview Tab -->
            <Border Grid.Row="2" Background="#1e1e1e"
                    Visibility="{Binding IsPreviewTab, Converter={StaticResource BoolToVis}}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- URL栏 -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔗" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="1" x:Name="PreviewUrlBox"
                                 Text="{Binding PreviewUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#3a3a3a" Foreground="#d4d4d4"
                                 BorderThickness="0" Padding="8,5" FontSize="13"
                                 VerticalContentAlignment="Center"/>
                        <Button Grid.Column="2" Content="🌐 打开浏览器" Width="100"
                                Background="#007acc" Foreground="White" BorderThickness="0"
                                Padding="8,5" FontSize="12" Margin="8,0,0,0"
                                Click="OpenPreviewInBrowser_Click"/>
                    </Grid>

                    <!-- 提示信息 -->
                    <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="6" Padding="16"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="🌐 Web 预览面板" FontSize="16" Foreground="#e0e0e0"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock FontSize="12" Foreground="#888" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="400">
                                在上方输入 dev server 地址（如 http://localhost:5173），点击"打开浏览器"在外部浏览器中预览。
                                <LineBreak/>
                                <LineBreak/>
                                提示：AI 启动 dev server 后会自动检测并填入地址。
                                或在聊天中说"启动开发服务器"让 AI 帮你启动。
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ====== Row 3: Status Bar ====== -->
        <!-- 调试工具栏（调试时显示） -->
        <Border Grid.Row="3" Background="#5a3020" Height="28" Padding="6,0"
                Visibility="{Binding DebugToolbarVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶ 继续" Width="56" Height="22" FontSize="10"
                            Background="#1a5a1a" Foreground="#90ee90" BorderThickness="0" Padding="0"
                            Command="{Binding ContinueDebugCommand}" ToolTip="继续执行 (F5)"/>
                    <Button Content="⏭ 跳过" Width="56" Height="22" FontSize="10"
                            Background="#3a5a3a" Foreground="#d4d4d4" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                            Command="{Binding StepOverCommand}" ToolTip="单步跳过 (F10)"/>
                    <Button Content="⬇ 进入" Width="56" Height="22" FontSize="10"
                            Background="#3a5a3a" Foreground="#d4d4d4" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                            Command="{Binding StepIntoCommand}" ToolTip="单步进入 (F11)"/>
                    <Button Content="⬆ 跳出" Width="56" Height="22" FontSize="10"
                            Background="#3a5a3a" Foreground="#d4d4d4" BorderThickness="0" Padding="0" Margin="4,0,0,0"
                            Command="{Binding StepOutCommand}" ToolTip="单步跳出 (Shift+F11)"/>
                    <Button Content="⏹ 停止" Width="56" Height="22" FontSize="10"
                            Background="#8b3030" Foreground="#f0a0a0" BorderThickness="0" Padding="0" Margin="12,0,0,0"
                            Command="{Binding StopDebugCommand}" ToolTip="停止调试 (Shift+F5)"/>
                    <TextBlock Text="{Binding DebugStatus}" FontSize="11" Foreground="#f0c040"
                               VerticalAlignment="Center" Margin="16,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock FontSize="10" Foreground="#aaa" VerticalAlignment="Center">
                        <Run Text="🔴 断点: "/><Run Text="{Binding DebugSvc.BreakpointCount, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Content="🗑 清除断点" Width="72" Height="20" FontSize="10"
                            Background="#555" Foreground="#ddd" BorderThickness="0" Margin="8,0,0,0"
                            Click="ClearBreakpoints_Click" ToolTip="清除所有断点"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 普通状态栏（非调试时显示，Qoder风格） -->
        <Border Grid.Row="3" Background="#007acc" Height="24" Padding="0,0"
                Visibility="{Binding DebugToolbarVisible, Converter={StaticResource InverseBoolToVis}}">
            <Grid>
                <!-- 左侧：Git分支 | 光标位置 | 文件类型 | 编码 | 行尾 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <!-- Git 分支 -->
                    <TextBlock Text="{Binding GitBranchDisplay}" FontSize="11" Foreground="#aad"
                               VerticalAlignment="Center" Margin="0,0,12,0"
                               Visibility="{Binding GitBranchDisplay, Converter={StaticResource HasContentToVis}}"
                               ToolTip="{Binding GitChangeDisplay}"/>
                    <TextBlock FontSize="11" Foreground="#ddd" VerticalAlignment="Center"
                               FontFamily="Consolas,monospace">
                        <Run Text="Ln "/><Run Text="{Binding Editor.CursorLine, Mode=OneWay}"/>
                        <Run Text=", Col "/><Run Text="{Binding Editor.CursorColumn, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Editor.StatusFileType}" FontSize="11" Foreground="#aad"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <TextBlock x:Name="StatusEncoding" Text="UTF-8" FontSize="11" Foreground="#888"
                               VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <TextBlock x:Name="StatusLineEnd" Text="CRLF" FontSize="11" Foreground="#888"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <TextBlock Text="{Binding BuildLanguageDisplay}" FontSize="11" Foreground="#888"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <!-- LSP 状态 -->
                    <TextBlock x:Name="StatusLsp" Text="" FontSize="11" Foreground="#6a6"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </StackPanel>
                <!-- 右侧：后台指示 | AI状态 | 编译 | 终端 | 日志 | 设置 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <!-- 后台任务指示器 -->
                    <Border Background="#e08d00" CornerRadius="3" Padding="6,1" Margin="0,0,8,0"
                            Visibility="{Binding IsAppInBackground, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding BackgroundTaskSummary}">
                        <TextBlock FontSize="10" Foreground="#fff" VerticalAlignment="Center">
                            <Run Text="◉ "/><Run Text="{Binding BackgroundTaskCount}"/><Run Text=" 后台任务"/>
                        </TextBlock>
                    </Border>
                    <Button Content="🔨 编译" Background="Transparent" Foreground="#ddd" BorderThickness="0" FontSize="11"
                            Padding="6,0" Command="{Binding BuildCommand}" ToolTip="编译项目 (Ctrl+Shift+B)"/>
                    <TextBlock Text="{Binding Chat.AIStatus}" FontSize="11" Foreground="#ddd" VerticalAlignment="Center" Margin="8,0"/>
                    <TextBlock Text="{Binding UsageStatusText}" FontSize="10" Foreground="#8cc" VerticalAlignment="Center" Margin="12,0"
                               ToolTip="本次会话 Token 用量估算（含输入+输出）。当 API 返回速率限制信息时会显示剩余额度。"
                               Visibility="{Binding UsageStatusText, Converter={StaticResource HasContentToVis}}"/>
                    <Button Content="终端" Background="Transparent" Foreground="#ddd" BorderThickness="0" FontSize="11"
                            Padding="6,0" Command="{Binding SwitchBottomTabCommand}" CommandParameter="terminal"/>
                    <Button Content="日志" Background="Transparent" Foreground="#ddd" BorderThickness="0" FontSize="11"
                            Padding="6,0" Command="{Binding SwitchBottomTabCommand}" CommandParameter="log"/>
                    <Button Content="⚙" Background="Transparent" Foreground="#ddd" BorderThickness="0" FontSize="13"
                            Padding="6,0" Margin="4,0,0,0" Command="{Binding ShowSettingsCommand}" ToolTip="设置"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ====== 模型管理弹窗 ====== -->
        <Border x:Name="SettingsOverlay" Background="#80000000" Visibility="Collapsed"
                MouseDown="SettingsOverlay_MouseDown">
            <Border Background="#2d2d2d" BorderBrush="#555" BorderThickness="1" CornerRadius="8"
                    Width="560" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                    MouseDown="SettingsOverlay_BlockMouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="#454545" BorderThickness="0,0,1,0" Padding="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="已注册模型" FontSize="13" FontWeight="Bold"
                                       Foreground="#e0e0e0" Margin="0,0,0,8"/>
                            <ListBox x:Name="ModelListBox" Grid.Row="1" Background="#3a3a3a" Foreground="#d4d4d4"
                                     FontSize="12" BorderThickness="0"
                                     SelectionChanged="ModelList_SelectionChanged"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                        <TextBlock Text="添加 / 编辑模型" FontSize="16" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,12"/>
                        <TextBlock Text="供应商" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                        <ComboBox x:Name="SettingsProviderBox" Background="#3a3a3a" Foreground="#d4d4d4" FontSize="13"
                                  IsEditable="True" Text=""
                                  Margin="0,0,0,8" Height="30" VerticalContentAlignment="Center"/>
                        <TextBlock Text="API 接口地址" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                        <TextBox x:Name="SettingsBaseUrlBox" Background="#3a3a3a" Foreground="#d4d4d4"
                                 BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,8" Height="30"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="模型 ID" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                        <TextBox x:Name="SettingsModelIdBox" Background="#3a3a3a" Foreground="#d4d4d4"
                                 BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,8" Height="30"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="模型名称（显示用）" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                        <TextBox x:Name="SettingsModelNameBox" Background="#3a3a3a" Foreground="#d4d4d4"
                                 BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,8" Height="30"
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="API 密钥" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                        <PasswordBox x:Name="SettingsApiKeyBox" Background="#3a3a3a" Foreground="#d4d4d4"
                                     BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,8" Height="30"
                                     VerticalContentAlignment="Center"/>
                        <TextBlock Text="类型" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <CheckBox x:Name="SettingsAgentCheck" Content="智能体" Foreground="#d4d4d4"
                                      FontSize="13" VerticalContentAlignment="Center" IsChecked="True" Margin="0,0,16,0"/>
                            <CheckBox x:Name="SettingsQACheck" Content="问答" Foreground="#d4d4d4"
                                      FontSize="13" VerticalContentAlignment="Center" IsChecked="True"/>
                        </StackPanel>
                        <TextBlock x:Name="SettingsMaxTokensLabel" Text="最大令牌数（留空使用模型默认值）" Foreground="#aaa" FontSize="12" Margin="0,4,0,2"/>
                        <TextBox x:Name="SettingsMaxTokensBox" Background="#3a3a3a" Foreground="#d4d4d4"
                                 BorderThickness="0" Padding="8,6" FontSize="13" Margin="0,0,0,16" Height="30"
                                 VerticalContentAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="删除" Width="60" Background="#8b0000" Foreground="#f0a0a0"
                                    BorderThickness="0" Padding="6,6" Margin="0,0,8,0"
                                    Click="DeleteModel_Click"/>
                            <Button Content="新增/更新" Width="90" Background="#007acc" Foreground="White"
                                    BorderThickness="0" Padding="6,6" Margin="0,0,8,0"
                                    Click="AddModel_Click"/>
                            <Button Content="关闭" Width="60" Background="#555" Foreground="#d4d4d4"
                                    BorderThickness="0" Padding="6,6"
                                    Command="{Binding CloseSettingsCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
