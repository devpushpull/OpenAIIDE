<Window x:Class="AIIDEWPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AIIDEWPF.Converters"
        Title="AI IDE - 登录" Height="360" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent">
    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </Window.Resources>
    <Border Background="#2d2d2d" CornerRadius="12" BorderBrush="#454545" BorderThickness="1">
        <Grid>
            <!-- 关闭按钮（右上角） -->
            <Button x:Name="CloseButton" Content="✕" Width="32" Height="32"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Foreground="#888" BorderThickness="0"
                    FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                    Margin="0,8,8,0"
                    Click="CloseButton_Click"/>

            <Grid Margin="32,16,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="🔐 AI IDE 登录" FontSize="22" FontWeight="Bold"
                       Foreground="#e0e0e0" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- 用户名 -->
            <TextBlock Grid.Row="1" Text="用户名" Foreground="#aaa" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox" Grid.Row="2"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                     Padding="10,8" FontSize="14" Height="38"
                     VerticalContentAlignment="Center"/>

            <!-- 密码 -->
            <TextBlock Grid.Row="3" Text="密码" Foreground="#aaa" FontSize="12" Margin="0,12,0,4"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="4"
                         Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                         Padding="10,8" FontSize="14" Height="38"
                         VerticalContentAlignment="Center"/>

            <!-- 错误提示 -->
            <TextBlock Grid.Row="5" Text="{Binding ErrorMessage, Mode=OneWay}"
                       Foreground="#f44747" FontSize="12" HorizontalAlignment="Center"
                       Margin="0,8,0,4" MinHeight="20"/>

            <!-- 记住我 -->
            <CheckBox x:Name="RememberMeCheck" Grid.Row="6" Content="记住我（7天内自动登录）"
                      IsChecked="{Binding RememberMe}"
                      Foreground="#aaa" FontSize="12" Margin="0,4,0,0"
                      VerticalAlignment="Center"/>

            <!-- 登录按钮 -->
            <Button Grid.Row="7" Content="登  录" Height="40"
                    Background="#007acc" Foreground="White" BorderThickness="0"
                    FontSize="15" FontWeight="Bold" Cursor="Hand"
                    IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InverseBool}}"
                    Click="LoginButton_Click" Margin="0,8,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
