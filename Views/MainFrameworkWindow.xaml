<Window x:Class="AIIDEWPF.Views.MainFrameworkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AIIDEWPF"
        Title="{Binding WindowTitle}" Height="800" Width="1400"
        MinHeight="500" MinWidth="900"
        Background="#1e1e1e" Foreground="#d4d4d4"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ====== 顶部菜单栏 + 操作按钮 + 用户头像 ====== -->
        <Grid Grid.Row="0" Background="#333">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧菜单（Qoder/VS Code 风格） -->
            <Menu Grid.Column="0" Background="Transparent" Foreground="#d4d4d4" BorderThickness="0"
                  VerticalAlignment="Center">
                <MenuItem Header="文件(_F)">
                    <MenuItem Header="新建文件 Ctrl+N" Command="{Binding NewFileCommand}"/>
                    <MenuItem Header="新建文件夹" Command="{Binding NewFolderCommand}"/>
                    <Separator/>
                    <MenuItem Header="打开文件... Ctrl+O" Command="{Binding OpenFileCommand}"/>
                    <MenuItem Header="打开项目..." Command="{Binding OpenProjectCommand}"/>
                    <MenuItem Header="关闭文件夹" Command="{Binding CloseFolderCommand}"/>
                    <MenuItem Header="新建项目" Command="{Binding OpenProjectCommand}"/>
                    <Separator/>
                    <MenuItem Header="保存 Ctrl+S" Command="{Binding SaveFileCommand}"/>
                    <MenuItem Header="另存为..." Command="{Binding SaveFileAsCommand}"/>
                    <Separator/>
                    <MenuItem Header="退出" Command="{Binding CloseCommand}"/>
                </MenuItem>
                <MenuItem Header="编辑(_E)">
                    <MenuItem Header="撤销 Ctrl+Z"/>
                    <MenuItem Header="重做 Ctrl+Y"/>
                    <Separator/>
                    <MenuItem Header="剪切 Ctrl+X"/>
                    <MenuItem Header="复制 Ctrl+C"/>
                    <MenuItem Header="粘贴 Ctrl+V"/>
                </MenuItem>
                <MenuItem Header="选择(_S)">
                    <MenuItem Header="全选 Ctrl+A"/>
                </MenuItem>
                <MenuItem Header="视图(_V)">
                    <MenuItem Header="文件资源管理器" Command="{Binding SwitchSidebarCommand}" CommandParameter="files"/>
                    <MenuItem Header="搜索 Ctrl+Shift+F" Command="{Binding SwitchSidebarCommand}" CommandParameter="search"/>
                    <Separator/>
                    <MenuItem Header="AI 面板" Command="{Binding ToggleAIPanelCommand}"/>
                    <MenuItem Header="终端 Ctrl+`" Command="{Binding ToggleTerminalCommand}"/>
                    <Separator/>
                    <MenuItem Header="切换侧边栏 Ctrl+B" Command="{Binding ToggleSidebarCommand}"/>
                    <Separator/>
                    <MenuItem Header="重置窗口" Click="ResetWindow_Click"/>
                </MenuItem>
                <MenuItem Header="转到(_G)">
                    <MenuItem Header="转到定义 F12" Command="{Binding GoToDefinitionCommand}"/>
                    <MenuItem Header="查找引用 Shift+F12" Command="{Binding FindReferencesCommand}"/>
                </MenuItem>
                <MenuItem Header="运行(_R)">
                    <MenuItem Header="启动调试 F5" Command="{Binding StartDebugCommand}"/>
                    <MenuItem Header="停止调试 Shift+F5" Command="{Binding StopDebugCommand}"/>
                    <Separator/>
                    <MenuItem Header="编译 Ctrl+Shift+B" Command="{Binding BuildCommand}"/>
                    <MenuItem Header="打包" Command="{Binding PackageCommand}"/>
                </MenuItem>
                <MenuItem Header="终端(_T)">
                    <MenuItem Header="新建终端 Ctrl+`" Command="{Binding ToggleTerminalCommand}"/>
                </MenuItem>
                <MenuItem Header="工具(_O)">
                    <MenuItem Header="清空对话" Command="{Binding ClearChatCommand}"/>
                    <Separator/>
                    <MenuItem Header="Git 推送" Command="{Binding GitPushCommand}"/>
                    <Separator/>
                    <MenuItem Header="插件管理" Command="{Binding PluginManagerCommand}"/>
                    <MenuItem Header="MCP 管理" Command="{Binding MCPManagerCommand}"/>
                </MenuItem>
                <MenuItem Header="设置(_S)">
                    <MenuItem Header="管理模型(_M)" Command="{Binding ShowSettingsCommand}"/>
                </MenuItem>
                <MenuItem Header="帮助(_H)">
                    <MenuItem Header="快捷键参考" Click="KeyboardShortcuts_Click"/>
                    <Separator/>
                    <MenuItem Header="检查更新" Click="CheckUpdate_Click"/>
                    <Separator/>
                    <MenuItem Header="运行环境检测" Click="EnvironmentCheck_Click"/>
                </MenuItem>
            </Menu>

            <!-- 右侧操作按钮组 + 用户头像 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,4,0">
                <!-- 打开 Quest -->
                <Button x:Name="OpenQuestBtn" Content="打开Quest" Width="78" Height="28"
                        Background="#007acc" Foreground="White" BorderThickness="0"
                        FontSize="11" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,6,0"
                        ToolTip="打开 Quest 任务工作区" Click="OpenQuest_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- 分隔线 -->
                <Border Width="1" Background="#555" Margin="2,4" VerticalAlignment="Stretch"/>

                <!-- 搜索 -->
                <Button Width="28" Height="28" Background="Transparent" Foreground="#aaa"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        ToolTip="搜索 (Ctrl+Shift+F)" Click="ToolbarSearch_Click">
                    <TextBlock Text="🔍" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- 切换主侧栏 -->
                <Button Width="28" Height="28" Background="Transparent" Foreground="#aaa"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        ToolTip="切换主侧栏 (Ctrl+B)" Click="ToolbarToggleSidebar_Click">
                    <TextBlock Text="📂" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- 切换面板（底部面板 终端/日志） -->
                <Button Width="28" Height="28" Background="Transparent" Foreground="#aaa"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        ToolTip="切换面板（终端/日志）" Click="ToolbarTogglePanel_Click">
                    <TextBlock Text="📋" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- 切换AI侧栏 -->
                <Button Width="28" Height="28" Background="Transparent" Foreground="#aaa"
                        BorderThickness="0" FontSize="14" Cursor="Hand"
                        ToolTip="切换 AI 侧栏 (Ctrl+L)" Click="ToolbarToggleAI_Click">
                    <TextBlock Text="💬" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- 分隔线 -->
                <Border Width="1" Background="#555" Margin="2,4" VerticalAlignment="Stretch"/>

                <!-- 用户头像 -->
                <Button x:Name="UserAvatarBtn" Width="36" Height="36"
                        Background="#007acc" Foreground="White" BorderThickness="0"
                        FontSize="16" FontWeight="Bold" Cursor="Hand" Margin="4,2,4,2"
                        ToolTip="{Binding CurrentUsername, StringFormat='{}用户: {0}'}"
                        Click="UserAvatarBtn_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="18"/>
                        </Style>
                    </Button.Resources>
                    <TextBlock x:Name="AvatarText" Text="👤" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ====== 主内容区域 ====== -->
        <ContentControl x:Name="PageHost" Grid.Row="1"/>
    </Grid>
</Window>
