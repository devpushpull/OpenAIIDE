<Window x:Class="AIIDEWPF.Views.UserManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户管理" Height="520" Width="620"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" Background="Transparent">
    <Border Background="#2d2d2d" CornerRadius="10" BorderBrush="#454545" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="👥 用户管理" FontSize="18" FontWeight="Bold"
                       Foreground="#e0e0e0" Margin="0,0,0,12"/>

            <!-- 用户列表 -->
            <Border Grid.Row="1" Background="#252526" CornerRadius="6" Padding="8">
                <ListBox ItemsSource="{Binding Users}" Background="Transparent" BorderThickness="0"
                         Foreground="#d4d4d4" FontSize="13">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="0,2" Background="#333" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Username}" FontWeight="Bold" Foreground="#60c0ff"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding RoleDisplay}" VerticalAlignment="Center"
                                               FontSize="12" Foreground="#aaa"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CreatedAt}" VerticalAlignment="Center"
                                               FontSize="11" Foreground="#888"/>
                                    <TextBlock Grid.Column="3" Text="{Binding LastLoginAt}" VerticalAlignment="Center"
                                               FontSize="11" Foreground="#666"/>
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="🔄 角色" Width="60" Background="#555" Foreground="#ddd"
                                                BorderThickness="0" FontSize="10" Padding="4,2" Margin="0,0,4,0"
                                                Command="{Binding DataContext.ChangeRoleCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="🔑 重置" Width="60" Background="#555" Foreground="#ddd"
                                                BorderThickness="0" FontSize="10" Padding="4,2" Margin="0,0,4,0"
                                                Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="重置密码为 123456"/>
                                        <Button Content="🗑" Width="30" Background="#5a3030" Foreground="#f0a0a0"
                                                BorderThickness="0" FontSize="12" Padding="2"
                                                Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- 新建用户区域 -->
            <Border Grid.Row="2" Background="#252526" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                             Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                             Padding="8,6" FontSize="13" ToolTip="新用户名"
                             Margin="0,0,8,0"/>
                    <PasswordBox x:Name="NewUserPasswordBox" Grid.Column="1"
                                 Background="#3a3a3a" Foreground="#d4d4d4" BorderThickness="0"
                                 Padding="8,6" FontSize="13" ToolTip="初始密码（至少3位）"
                                 Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="➕ 新建用户" Width="100" Height="34"
                            Background="#007acc" Foreground="White" BorderThickness="0" FontSize="12"
                            Click="AddUser_Click"/>
                </Grid>
            </Border>

            <!-- 管理员密钥管理 -->
            <Border Grid.Row="3" Background="#252526" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="🔐 管理员密钥" FontSize="13" Foreground="#e0e0e0" FontWeight="Bold"/>
                        <TextBlock x:Name="KeyStatusText" Text="" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="🔑 生成密钥" Width="100" Height="30"
                            Background="#5a3a1a" Foreground="#e0c060" BorderThickness="0" FontSize="11"
                            Click="GenerateKey_Click" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- 错误提示 + 关闭 -->
            <Grid Grid.Row="4" Margin="0,8,0,0">
                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="#f44747"
                           FontSize="12" VerticalAlignment="Center"/>
                <Button Content="关闭" Width="80" Height="30" Background="#555" Foreground="#d4d4d4"
                        BorderThickness="0" FontSize="12" HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
